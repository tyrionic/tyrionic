def emit_linux_aarch64_int_compare_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    op = plan["op"]
    jump = "b.ne"
    if op == "<":
        jump = "b.lt"
    elif op == "<=":
        jump = "b.le"
    elif op == ">":
        jump = "b.gt"
    elif op == ">=":
        jump = "b.ge"
    elif op == "==":
        jump = "b.eq"
    lhs_expr = plan["lhs_expr"]
    rhs_expr = plan["rhs_expr"]
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; linux aarch64 integer compare/branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "x9, #" + str(lhs_expr["base_value"]) + "\n"
    if lhs_expr["delta"] > 0:
        out = out + "    " + "add" + " " + "x9, x9, #" + str(lhs_expr["delta"]) + "\n"
    elif lhs_expr["delta"] < 0:
        out = out + "    " + "sub" + " " + "x9, x9, #" + str(-lhs_expr["delta"]) + "\n"
    out = out + "    " + "mov" + " " + "x10, #" + str(rhs_expr["base_value"]) + "\n"
    if rhs_expr["delta"] > 0:
        out = out + "    " + "add" + " " + "x10, x10, #" + str(rhs_expr["delta"]) + "\n"
    elif rhs_expr["delta"] < 0:
        out = out + "    " + "sub" + " " + "x10, x10, #" + str(-rhs_expr["delta"]) + "\n"
    out = out + "    " + "cmp" + " " + "x9, x10" + "\n"
    out = out + "    " + jump + " " + true_label + "\n"
    out = out + "    " + "adr" + " " + "x0, " + false_payload_label + "\n"
    out = out + "    " + "mov" + " " + "x1, #" + str(false_payload_len) + "\n"
    out = out + "    " + "bl" + " " + runtime_print_stub_label + "\n"
    out = out + "    " + "b" + " " + done_label + "\n"
    out = out + true_label + ":\n"
    out = out + "    " + "adr" + " " + "x0, " + true_payload_label + "\n"
    out = out + "    " + "mov" + " " + "x1, #" + str(true_payload_len) + "\n"
    out = out + "    " + "bl" + " " + runtime_print_stub_label + "\n"
    out = out + done_label + ":\n"
    out = out + "    " + "mov" + " " + "x8, #93" + "\n"
    out = out + "    " + "mov" + " " + "x0, #0" + "\n"
    out = out + "    " + "svc" + " " + "#0" + "\n"
    out = out + runtime_print_stub_label + ":\n"
    out = out + "; runtime-abi print-line(ptr=x0, len=x1) -> x0" + "\n"
    out = out + "; abi-clobber-policy: preserve callee-saved registers used by stub" + "\n"
    out = out + "    " + "stp" + " " + "x29, x30, [sp, #-16]!" + "\n"
    out = out + "    " + "mov" + " " + "x29, sp" + "\n"
    out = out + "    " + "stp" + " " + "x19, x20, [sp, #-16]!" + "\n"
    out = out + "    " + "mov" + " " + "x19, x0" + "\n"
    out = out + "    " + "mov" + " " + "x20, x1" + "\n"
    out = out + "    " + "mov" + " " + "x8, #64" + "\n"
    out = out + "    " + "mov" + " " + "x0, #1" + "\n"
    out = out + "    " + "mov" + " " + "x1, x19" + "\n"
    out = out + "    " + "mov" + " " + "x2, x20" + "\n"
    out = out + "    " + "svc" + " " + "#0" + "\n"
    out = out + "    " + "ldp" + " " + "x19, x20, [sp], #16" + "\n"
    out = out + "    " + "ldp" + " " + "x29, x30, [sp], #16" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + true_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["true_text"]) + "\"" + "\n"
    out = out + false_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["false_text"]) + "\"" + "\n"
    return out


