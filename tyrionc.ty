    out = out + "    " + "b" + " " + done_label + "\n"
    out = out + true_label + ":\n"
    out = out + "    " + "adr" + " " + "x0, " + true_payload_label + "\n"
    out = out + "    " + "mov" + " " + "x1, #" + str(true_payload_len) + "\n"
    out = out + "    " + "bl" + " " + runtime_print_stub_label + "\n"
    out = out + done_label + ":\n"
    out = out + "    " + "mov" + " " + "x8, #93" + "\n"
    out = out + "    " + "mov" + " " + "x0, #0" + "\n"
    out = out + "    " + "svc" + " " + "#0" + "\n"
    out = out + runtime_print_stub_label + ":\n"
    out = out + "; runtime-abi print-line(ptr=x0, len=x1) -> x0" + "\n"
    out = out + "; abi-clobber-policy: preserve callee-saved registers used by stub" + "\n"
    out = out + "    " + "stp" + " " + "x29, x30, [sp, #-16]!" + "\n"
    out = out + "    " + "mov" + " " + "x29, sp" + "\n"
    out = out + "    " + "stp" + " " + "x19, x20, [sp, #-16]!" + "\n"
    out = out + "    " + "mov" + " " + "x19, x0" + "\n"
    out = out + "    " + "mov" + " " + "x20, x1" + "\n"
    out = out + "    " + "mov" + " " + "x8, #64" + "\n"
    out = out + "    " + "mov" + " " + "x0, #1" + "\n"
    out = out + "    " + "mov" + " " + "x1, x19" + "\n"
    out = out + "    " + "mov" + " " + "x2, x20" + "\n"
    out = out + "    " + "svc" + " " + "#0" + "\n"
    out = out + "    " + "ldp" + " " + "x19, x20, [sp], #16" + "\n"
    out = out + "    " + "ldp" + " " + "x29, x30, [sp], #16" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
