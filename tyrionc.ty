    out = out + "native-lowering-plan=" + lowering_plan["kind"] + "\n"
    if lowering_plan["kind"] == "runtime-hooks":
        out = out + "native-lowering-runtime-hooks=" + join_csv(lowering_plan["runtime_hooks"]) + "\n"
    out = out + "native-exec-mode=launcher\n"
    out = out + "native-codegen-version=v1\n"
    out = out + "native-require-direct=1\n"
    out = out + "native-link-mode=pending\n"
    out = out + "native-linking=" + link_mode + "\n"
    out = out + "native-linker-flavor=pending\n"
    ext_static_count = getenv_text("TYRION_EXT_STATIC_COUNT")
    if ext_static_count == "":
        ext_static_count = "0"
    ext_static_manifest_hash = getenv_text("TYRION_EXT_STATIC_MANIFEST_HASH")
    if ext_static_manifest_hash == "":
        ext_static_manifest_hash = "none"
    out = out + "native-static-ext-mode=" + ext_static_mode + "\n"
    out = out + "native-static-ext-dir=" + ext_static_dir + "\n"
    out = out + "native-static-ext-count=" + ext_static_count + "\n"
    out = out + "native-static-ext-manifest-hash=" + ext_static_manifest_hash + "\n"
    out = out + "native-stdlib-wrapper=" + stdlib_wrapper_path + "\n"
    out = out + "native-stdlib-wrapper-applied=" + stdlib_wrapper_applied + "\n"
    if include_compiled_payload:
        out = out + compiled_payload_section_start()
        out = out + compiled_payload + "\n"
    out = out + "---TYPED-IR---\n"
    out = out + "typed-ir-unavailable:tyrionc-native-v1\n"
    out = out + "---LOWERED-IR---\n"
    out = out + "lowered-ir-unavailable:tyrionc-native-v1\n"
    out = out + "---BACKEND-IR---\n"
    out = out + "backend-ir-tyrionc-native-v1\n"
    out = out + "---ASM---\n"
    out = out + asm
    emit_compile_progress("render_selfhost_native_artifact:done")
    return out


def selfhost_build(input_path, output_path, deterministic, stdlib_wrapper_path):
    source = read_text_file(input_path)
    stdlib_overlay = apply_stdlib_wrapper_source(input_path, source, stdlib_wrapper_path, "selfhost")
    artifact = render_selfhost_artifact(input_path, deterministic, stdlib_overlay["source"], stdlib_overlay["wrapper_path"], stdlib_overlay["applied"])
    write_text_file(output_path, artifact)


def validate_selfhost_native_link_mode_for_family(mode, target_family):
    target_family_is_linux = target_family == "linux"
    target_family_is_darwin = target_family == "darwin"
    mode_is_dynamic = mode == "dynamic"
    mode_is_static = mode == "static"
    mode_is_static_like = mode == "static-like"
    if mode_is_dynamic:
        fail("--link=dynamic is not supported for --backend=tyrionc")
    if target_family_is_linux:
        if mode_is_static:
            return mode
        fail("linux tyrionc backend requires --link=static")
    if target_family_is_darwin != True:
        fail("unsupported native target family for --link mode: " + target_family)
    # Remaining supported family is darwin.
    if mode_is_static:
        fail("darwin does not support fully static Mach-O outputs; use --link=static-like")
    if mode_is_static_like != True:
        fail("darwin tyrionc backend supports only --link=static-like")
    return mode


def validate_selfhost_native_link_mode(link_mode, target):
    raw_mode = link_mode
    mode = method_strip(raw_mode)
    if starts_with(mode, "--link="):
        parts = method_split(mode, "=")
        if len(parts) >= 2:
            raw_link_mode = parts[1]
            mode = method_strip(raw_link_mode)
    if starts_with(mode, "static") and mode != "static-like":
        mode = "static"
    target_os = target["os"]
    target_family = backend_target_family_from_os(target_os)
    if target_family == "":
        fail("unsupported native target for --link mode: " + target["triple"])
    if mode == "":
        mode = "static"
    if mode == "static":
        if target_family == "darwin":
            mode = "static-like"
    return validate_selfhost_native_link_mode_for_family(mode, target_family)


def normalize_native_link_fallback_location(symbol, location):
    # Canonical fallback marker defaults for strict fail-closed diagnostics.
    normalized_symbol = symbol
    if normalized_symbol == "":
        normalized_symbol = "<module>"
    normalized_location = location
    if normalized_location == "":
        normalized_location = "-"
    return {"symbol": normalized_symbol, "location": normalized_location}


def normalize_native_link_fallback_policy(fallback_reason, fallback_family, stage_fail_closed):
    normalized_reason = fallback_reason
    normalized_family = fallback_family
    if normalized_reason == "":
        if stage_fail_closed:
            normalized_reason = "stage-package-mode-mismatch"
        else:
            normalized_reason = "auto-launcher-fallback-disallowed"
    if normalized_family == "":
        if stage_fail_closed:
            normalized_family = "native-link/package-mode"
        else:
            normalized_family = "native-link/launcher-fallback"
    return {"reason": normalized_reason, "family": normalized_family}


# PASS CONTRACT: Driver native build orchestration
# Input: CLI build request + strict-mode policy env.
# Output: native executable + sidecar artifact markers/reports.
# Failure: strict fail-closed on feature-scan, link-mode, and package-mode mismatches.
def selfhost_native_build(input_path, output_path, deterministic, target, link_mode, native_mode, ext_static_mode, ext_static_dir, stdlib_wrapper_path):
    emit_compile_progress("selfhost_native_build:start")
    build_target_kind = native_build_target_kind(input_path)
    if build_target_kind == "stage-compiler":
        enforce_strict_stage_env_policy()
    validated_link_mode = validate_selfhost_native_link_mode(link_mode, target)
    target_family = backend_target_family_from_os(target["os"])
    if target_family == "":
        fail("unsupported native target for linker strategy: " + target["triple"])
    if target_family != "linux":
        if target_family != "darwin":
            fail("unsupported linker strategy target family: " + target_family)
    if ext_static_mode != "off":
        if ext_static_mode != "auto":
            if ext_static_mode != "required":
                fail("unsupported --ext-static: " + ext_static_mode + " (expected off, auto, or required)")
    if ext_static_dir == "":
        ext_static_dir = "./extensions"
    if validated_link_mode == "":
        fail("internal: native link strategy resolution requires validated --link mode")
    # Backend strategy ownership: resolve linker strategy/object writer once.
    backend_strategy_request = {"validated_link_mode": validated_link_mode, "target_family": target_family}
    backend_strategy_result = {}
    backend_strategy_result["link_strategy_name"] = "external-linker-v1"
    backend_strategy_result["link_object_writer"] = "external-assembler"
    object_writer_probe_metadata_map = {}
    object_writer_probe_metadata_map["enabled"] = "0"
    object_writer_probe_metadata_map["candidate_name"] = ""
    object_writer_probe_metadata_map["relocation_family"] = "none"
