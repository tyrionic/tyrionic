    false_payload_label = next_symbol(state, "false_payload")
    args = plan["args"]
    expected = plan["expected"]
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; linux aarch64 call-abi branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "x0, #" + str(args[0]) + "\n"
    out = out + "    " + "mov" + " " + "x1, #" + str(args[1]) + "\n"
    out = out + "    " + "mov" + " " + "x2, #" + str(args[2]) + "\n"
    out = out + "    " + "mov" + " " + "x3, #" + str(args[3]) + "\n"
