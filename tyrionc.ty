    out = out + "    " + "mov" + " " + "x7, #" + str(args[7]) + "\n"
    out = out + "    " + "bl" + " " + callee_label + "\n"
    out = out + "    " + "cmp" + " " + "x0, #" + str(expected) + "\n"
    out = out + "    " + "b.eq" + " " + true_label + "\n"
    out = out + "    " + "adr" + " " + "x0, " + false_payload_label + "\n"
