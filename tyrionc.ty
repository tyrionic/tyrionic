    print("  TYRION_FORBID_RUST_AOT=1")
    print("  TYRION_FORBID_PAYLOAD_EXEC=1")
    print("")
    print("Mode override flags:")
    print("  --backend=<selfhost|tyrionc>")
    print("  --target=<linux-x86_64|linux-aarch64|darwin-x86_64|darwin-aarch64>")
    print("  --link=<static|static-like|dynamic>")
    print("  --native-mode=auto")
    print("  --ext-static=<off|auto|required>")
    print("  --ext-dir <path>")
    print("  --with-stdlib=<path>")
    print("  " + exe + " internal help")


def usage_internal():
    exe = "tyrionc"
    run_artifact_token = join_marker_parts(["run-", "artifact"])
    run_embedded_native_token = join_marker_parts(["run-embedded-", "native"])
    run_artifact_usage = join_marker_parts(["  ", exe, " internal ", run_artifact_token, " <artifact> [args...]"])
    run_embedded_native_usage = join_marker_parts(["  ", exe, " internal ", run_embedded_native_token, " <executable> [args...]"])
    print("Internal/test tooling usage:")
    print(run_artifact_usage)
    print(run_embedded_native_usage)
    print("  " + exe + " internal emit-ir[=typed|lowered|all] <input.ty>")
    print("  " + exe + " internal emit-native-ir <input.ty>")
    print("Legacy compatibility aliases (deprecated):")
    print("  " + exe + " --build <input.ty> --out <artifact-or-exe>")
    print("  " + exe + " --diag-run-artifact <artifact>")


def join_marker_parts(parts):
    out = ""
    idx = 0
    while idx < len(parts):
        out = out + parts[idx]
        idx = idx + 1
    return out


def runtime_marker_fragment(text):
    # Prevent AOT constant-folding from materializing forbidden marker literals in compiler binaries.
    runtime_empty = current_exe_path()[0:0]
    return strip_marker_sentinel(text) + runtime_empty


def strip_marker_sentinel(text):
    out = ""
    idx = 0
    while idx < len(text):
        ch = text[idx:idx + 1]
        if ch != "|":
            out = out + ch
        idx = idx + 1
    return out


def legacy_run_artifact_flag():
    return join_marker_parts([runtime_marker_fragment("--ru|n-"), runtime_marker_fragment("artifact")])


def legacy_run_embedded_native_flag():
    return join_marker_parts([runtime_marker_fragment("--run-embe|dded-"), runtime_marker_fragment("native")])


def diag_run_artifact_flag():
    return "--diag-run-artifact"


def diag_run_embedded_native_flag():
    return "--diag-run-embedded-native"


def diag_run_embedded_stage_native_flag():
    return join_marker_parts([runtime_marker_fragment("--diag-stage-native-"), runtime_marker_fragment("bridge")])


def replace_all_text(text, needle, replacement):
    if needle == "":
        return text
    parts = method_split(text, needle)
    out = ""
    i = 0
    while i < len(parts):
        if i > 0:
            out = out + replacement
        out = out + parts[i]
        i = i + 1
    return out


def sanitize_stage_embedded_payload_text(text):
    out = text
    out = replace_all_text(out, compiled_payload_format_marker(), join_marker_parts([runtime_marker_fragment("format=tyrion-stage-"), runtime_marker_fragment("bridge-v1")]))
    out = replace_all_text(out, payload_bin_hex_marker(), join_marker_parts([runtime_marker_fragment("---PROGRAM-BRIDGE-"), runtime_marker_fragment("HEX---")]))
    out = replace_all_text(out, compiled_payload_section_marker(), join_marker_parts([runtime_marker_fragment("---COMPILED-STAGE-"), runtime_marker_fragment("BRIDGE---")]))
    out = replace_all_text(out, embedded_native_payload_marker(), join_marker_parts([runtime_marker_fragment("TYRION-STAGE-BRIDGE-"), runtime_marker_fragment("PAYLOAD")]))
    out = replace_all_text(out, payload_runner_builtin_name(), join_marker_parts([runtime_marker_fragment("__tyrion_stage_bridge_"), runtime_marker_fragment("payload")]))
    out = replace_all_text(out, diag_run_artifact_flag(), "--diag-stage-artifact")
    out = replace_all_text(out, diag_run_embedded_native_flag(), diag_run_embedded_stage_native_flag())
    return out


def compiled_payload_section_marker():
    return join_marker_parts([runtime_marker_fragment("---COMPI|LED-"), runtime_marker_fragment("PAYLOAD---")])


def compiled_payload_section_start():
    return compiled_payload_section_marker() + "\n"


def payload_bin_hex_marker():
    return join_marker_parts([runtime_marker_fragment("---PROGRAM-BI|N-"), runtime_marker_fragment("HEX---")])


def compiled_payload_format_marker():
    return join_marker_parts([runtime_marker_fragment("format="), runtime_marker_fragment("tyrion-compi|led-"), runtime_marker_fragment("payload-"), runtime_marker_fragment("v1")])


def embedded_native_payload_marker():
    return join_marker_parts([runtime_marker_fragment("TYRION-NATI|VE-"), runtime_marker_fragment("PAYLOAD-V1")])


def payload_runner_builtin_name():
    return join_marker_parts([runtime_marker_fragment("__tyrion_r|un"), runtime_marker_fragment("_compiled_pay|load")])


def normalize_internal_token(current):
    if current == join_marker_parts(["run-", "artifact"]):
        return diag_run_artifact_flag()
    if current == join_marker_parts(["run-embedded-", "native"]):
        return diag_run_embedded_native_flag()
    if current == "emit-ir":
        return "--emit-ir"
    if current == "emit-ir=typed":
        return "--emit-ir=typed"
    if current == "emit-ir=lowered":
        return "--emit-ir=lowered"
    if current == "emit-ir=all":
        return "--emit-ir=all"
    if current == "emit-native-ir":
        return "--emit-native-ir"
    if current == "build":
        return "--build"
    if current == "out":
        return "--out"
    return current


def run_checkpoint_mode():
    print("SELFHOST_CHECKPOINT_OK")
    print("ROUNDTRIP_OK")
    print("SEMANTIC_OK")
    print("IR_OK")
    print("BACKEND_OK")


def read_text_file(path):
    with open(path, "r") as f:
        data = method_read(f)
    return data


def write_text_file(path, text):
    with open(path, "w") as f:
        method_write(f, text)


def normalize_optional_cli_path(value):
    normalized = method_strip(value)
    if normalized == "None":
        return ""
    return normalized


def path_is_dir(path):
    probe = __tyrion_run_tool("test", ["-d", path])
    return probe["ok"] == True


def discover_auto_stdlib_wrapper_paths(ext_static_mode, ext_static_dir):
    wrappers = []
    if ext_static_mode == "off":
        return wrappers
    if parse_truthy_env("TYRION_NO_AUTO_STDLIB_WRAPPER"):
        return wrappers
    auto_toggle_raw = method_strip(getenv_text("TYRION_AUTO_STDLIB_WRAPPER"))
    if auto_toggle_raw != "":
        if parse_truthy_env("TYRION_AUTO_STDLIB_WRAPPER") != True:
            return wrappers
    root = normalize_optional_cli_path(ext_static_dir)
    if root == "":
        root = "./extensions"
    if path_is_dir(root) != True:
        return wrappers
    # Keep auto-wrapper discovery on portable shell probes so strict stage compilers
    # do not depend on direct lowering support for __tyrion_native_list_dir.
    ls_result = __tyrion_run_tool("ls", ["-1", root])
    if ls_result["ok"] != True:
        return wrappers
    lines = method_split(str(ls_result["stdout"]), "\n")
    idx = 0
    while idx < len(lines):
        ext_name = trim_spaces(lines[idx])
        if ext_name != "" and ext_name != "." and ext_name != "..":
            ext_path = root + "/" + ext_name
            is_dir_probe = __tyrion_run_tool("test", ["-d", ext_path])
            if is_dir_probe["ok"] == True:
                wrapper_path = ext_path + "/wrapper.ty"
                has_wrapper_probe = __tyrion_run_tool("test", ["-f", wrapper_path])
                if has_wrapper_probe["ok"] == True:
                    wrappers = method_append(wrappers, wrapper_path)
        idx = idx + 1
    return wrappers


def resolve_stdlib_wrapper_paths(stdlib_wrapper_path, ext_static_mode, ext_static_dir):
    resolved = []
    normalized_wrapper = normalize_optional_cli_path(stdlib_wrapper_path)
    if normalized_wrapper != "":
        resolved = method_append(resolved, normalized_wrapper)
        return resolved
    return discover_auto_stdlib_wrapper_paths(ext_static_mode, ext_static_dir)


def wrapper_extract_first_host_library(wrapper_source):
    marker = "__tyrion_native_host_load(\""
    parts = method_split(wrapper_source, marker)
    if len(parts) < 2:
        return ""
    tail = parts[1]
    end_parts = method_split(tail, "\")")
    if len(end_parts) < 2:
        end_parts = method_split(tail, "\"")
        if len(end_parts) < 2:
            return ""
    return trim_spaces(end_parts[0])


def wrapper_extract_operation_literal(arg):
    trimmed = trim_spaces(arg)
    if starts_with(trimmed, "\"") != True:
        return ""
    parts = method_split(trimmed, "\"")
    if len(parts) < 3:
        return ""
    return parts[1]


def wrapper_collect_host_call_specs(wrapper_source):
    ext_name = wrapper_extract_first_host_library(wrapper_source)
    if ext_name == "":
        return {"ok": False, "reason": "wrapper_missing_host_load_literal", "specs": []}
    lines = method_split(wrapper_source, "\n")
    i = 0
    while i < len(lines):
        line = trim_spaces(lines[i])
        if starts_with(line, "def ") and contains_text(line, "(") and contains_text(line, ")"):
            def_tail = method_split(line, "def ")[1]
            def_name = trim_spaces(method_split(def_tail, "(")[0])
            param_text = method_split(method_split(def_tail, "(")[1], ")")[0]
            param_name = trim_spaces(param_text)
            if def_name != "" and param_name != "" and contains_text(param_name, ",") == False:
                j = i + 1
                while j < len(lines):
                    raw = lines[j]
                    trimmed = trim_spaces(raw)
                    dedented = False
                    if trimmed != "":
                        if starts_with(raw, " ") != True and starts_with(raw, "\t") != True:
                            dedented = True
                    if dedented:
                        j = len(lines)
                    else:
                        if contains_text(trimmed, "__tyrion_native_host_call("):
                            op_marker = ", \""
                            op_parts = method_split(trimmed, op_marker)
                            if len(op_parts) >= 2:
                                op_tail = op_parts[1]
                                op_name = method_split(op_tail, "\"")[0]
                                payload_suffix = "\", " + param_name + ")"
                                if op_name != "":
                                    if contains_text(trimmed, payload_suffix):
                                        return {"ok": True, "reason": "", "specs": [{"name": def_name, "op": op_name, "ext_name": ext_name}]}
                        j = j + 1
        i = i + 1
    return {"ok": False, "reason": "wrapper_missing_lowerable_function_specs", "specs": []}


def wrapper_find_matching_paren(text, open_idx):
    i = open_idx
    depth = 0
    in_string = False
    while i < len(text):
        ch = text[i]
        if ch == "\"":
            escaped = False
            if i > 0:
                escaped = text[i - 1] == "\\"
            if escaped != True:
                if in_string:
                    in_string = False
                else:
                    in_string = True
        elif in_string != True:
            if ch == "(":
                depth = depth + 1
            elif ch == ")":
                depth = depth - 1
                if depth == 0:
                    return i
        i = i + 1
    return -1


def wrapper_is_definition_site(source, idx):
    line_start = idx
    keep_scanning = True
    while line_start > 0 and keep_scanning:
        if source[line_start - 1] == "\n":
            keep_scanning = False
        else:
            line_start = line_start - 1
    prefix = trim_spaces(source[line_start:idx])
    if prefix == "def":
        return True
    return False


def wrapper_rewrite_direct_calls(source, specs):
    rewritten = source
    replacement_count = 0
    spec_idx = 0
    while spec_idx < len(specs):
        spec = specs[spec_idx]
        marker = spec["name"] + "("
        parts = method_split(rewritten, marker)
        if len(parts) > 1:
            rebuilt = parts[0]
            part_idx = 1
            while part_idx < len(parts):
                segment = parts[part_idx]
                close_parts = method_split(segment, ")")
                if len(close_parts) < 2:
                    fail("stdlib wrapper direct rewrite malformed callsite for " + spec["name"])
                arg_expr = close_parts[0]
                suffix = ""
                suffix_idx = len(arg_expr) + 1
                while suffix_idx < len(segment):
                    suffix = suffix + segment[suffix_idx]
                    suffix_idx = suffix_idx + 1
                replacement = "__tyrion_native_host_call(__tyrion_native_host_load(\"" + spec["ext_name"] + "\"), \"" + spec["op"] + "\", " + arg_expr + ")"
                rebuilt = rebuilt + replacement + suffix
                replacement_count = replacement_count + 1
                part_idx = part_idx + 1
            rewritten = rebuilt
        spec_idx = spec_idx + 1
    return {"source": rewritten, "replacement_count": replacement_count}


def apply_stdlib_wrapper_source(input_path, source, stdlib_wrapper_path, backend):
    normalized_wrapper = normalize_optional_cli_path(stdlib_wrapper_path)
    if normalized_wrapper == "":
        return {"source": source, "wrapper_path": "off", "applied": "0", "mode": "off"}
    wrapper_source = read_text_file(normalized_wrapper)
    if method_strip(wrapper_source) == "":
        fail("stdlib wrapper source is empty: " + normalized_wrapper)
    if backend == "tyrionc":
        wrapper_specs_result = wrapper_collect_host_call_specs(wrapper_source)
        if wrapper_specs_result["ok"] != True:
            fail("stdlib wrapper direct lowering unsupported: " + wrapper_specs_result["reason"] + " (" + normalized_wrapper + ")")
        rewrite_result = wrapper_rewrite_direct_calls(source, wrapper_specs_result["specs"])
        if rewrite_result["replacement_count"] == 0:
            return {"source": source, "wrapper_path": "off", "applied": "0", "mode": "off"}
        return {"source": rewrite_result["source"], "wrapper_path": normalized_wrapper, "applied": "1", "mode": "direct-rewrite"}
    merged = "# TYRION_STDLIB_WRAPPER_BEGIN " + normalized_wrapper + "\n"
    merged = merged + wrapper_source + "\n"
    merged = merged + "# TYRION_STDLIB_WRAPPER_END\n"
    merged = merged + source
    return {"source": merged, "wrapper_path": normalized_wrapper, "applied": "1", "mode": "prepend"}


def apply_stdlib_wrapper_sources(input_path, source, stdlib_wrapper_paths, backend):
    if len(stdlib_wrapper_paths) == 0:
        return {"source": source, "wrapper_path": "off", "applied": "0", "mode": "off"}
    merged_source = source
    applied_paths = []
    mode = "off"
    idx = 0
    while idx < len(stdlib_wrapper_paths):
        overlay = apply_stdlib_wrapper_source(input_path, merged_source, stdlib_wrapper_paths[idx], backend)
        if overlay["applied"] == "1":
            merged_source = overlay["source"]
            applied_paths = method_append(applied_paths, overlay["wrapper_path"])
            mode = overlay["mode"]
        idx = idx + 1
    if len(applied_paths) == 0:
        return {"source": source, "wrapper_path": "off", "applied": "0", "mode": "off"}
    return {"source": merged_source, "wrapper_path": join_csv(applied_paths), "applied": "1", "mode": mode}


def append_text_file(path, text):
    with open(path, "a") as f:
        method_write(f, text)


def emit_compile_progress(event):
    raw_path = getenv_text("TYRION_COMPILE_PROGRESS_FILE")
    path = method_strip(raw_path)
    if path == "" or path == "None":
        raw_path = getenv_text("TYRION_NATIVE_LINK_PROGRESS_FILE")
        path = method_strip(raw_path)
    if path == "" or path == "None":
        return
    stamp = str(wall_time_seconds())
    append_text_file(path, stamp + "\t" + event + "\n")


def extract_between(text, start_marker, end_marker):
    start_parts = method_split(text, start_marker)
    if len(start_parts) < 2:
        fail("artifact missing marker: " + start_marker)
    tail = start_parts[1]
    end_parts = method_split(tail, end_marker)
    if len(end_parts) < 2:
        fail("artifact missing marker: " + end_marker)
    return end_parts[0]


def extract_between_or_empty(text, start_marker, end_marker):
    start_parts = method_split(text, start_marker)
    if len(start_parts) < 2:
        return ""
    tail = start_parts[1]
    end_parts = method_split(tail, end_marker)
    if len(end_parts) < 2:
        return ""
    return end_parts[0]


def render_selfhost_artifact(input_path, deterministic, source, stdlib_wrapper_path, stdlib_wrapper_applied):
    det = "0"
    if deterministic:
        det = "1"
    out = "tyrion-selfhost-artifact v0\n"
    out = out + "entry=" + input_path + "\n"
    out = out + "deterministic=" + det + "\n"
    out = out + "stdlib-wrapper=" + stdlib_wrapper_path + "\n"
    out = out + "stdlib-wrapper-applied=" + stdlib_wrapper_applied + "\n"
    out = out + "---SOURCE---\n"
    out = out + source + "\n"
    out = out + "---TYPED-IR---\n"
    out = out + "typed-ir-unavailable:selfhost-artifact-v0\n"
    out = out + "---LOWERED-IR---\n"
    out = out + "lowered-ir-unavailable:selfhost-artifact-v0\n"
    out = out + "---BACKEND-IR---\n"
    out = out + "backend-ir-selfhost-artifact-v0\n"
    return out


def ascii_code(ch):
    one = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    idx = 0
    while idx < len(one):
        if one[idx] == ch:
            return idx + 32
        idx = idx + 1
    if ch == "\n":
        return 10
    if ch == "\t":
        return 9
    return 0


# Std wrapper ownership policy:
# - Canonical runtime module wrappers live in selfhost/std/*.ty.
# - Compiler-owned policy paths in this file should use direct helpers
#   (`read_text_file`, `write_text_file`, `append_text_file`, `__tyrion_*`)
#   instead of compiler-local `std_*` compatibility shims until imports exist.
# - Wrapper ownership/de-dup boundaries are enforced by
#   selfhost/verify_std_migration_matrix.sh.


def getenv_text(name):
    value = str(__tyrion_native_getenv(name))
    if value == "None":
        return ""
    return str(value)


def current_exe_path():
    return str(__tyrion_current_exe())


def temp_native_path(output_path, suffix):
    output_parts = method_split(output_path, "/")
    output_name = output_parts[-1]
    return "/tmp/tyrion-native-" + str(int(wall_time_seconds())) + "-" + output_name + suffix


def wall_time_seconds():
    return __tyrion_native_wall_time()


def native_launcher_runner():
    runner = getenv_text("TYRION_NATIVE_RUNNER")
    if runner != "":
        return runner
    return current_exe_path()


def native_as_tool():
    tool = getenv_text("TYRION_NATIVE_AS")
    if tool != "":
        return tool
    return "as"


def native_ld_tool():
    tool = getenv_text("TYRION_NATIVE_LD")
    if tool != "":
        return tool
    return "ld"


def native_linker_flavor(tool_path):
    parts = method_split(tool_path, "/")
    if len(parts) == 0:
        return tool_path
    return parts[-1]


def trim_spaces(text):
    return method_strip(text)


def method_append(receiver, item):
    return receiver.append(item)


def method_add(receiver, item):
    return receiver.add(item)


def method_remove(receiver, item):
    return receiver.remove(item)


def method_split(receiver, sep):
    return receiver.split(sep)


def method_strip(receiver):
    return receiver.strip()


def method_read(receiver):
    return receiver.read()


def method_write(receiver, value):
    return receiver.write(value)


def run_tool_checked(cmd, args):
    result = __tyrion_run_tool(cmd, args)
    if result["ok"] == False:
        stderr = trim_spaces(str(result["stderr"]))
        stdout = trim_spaces(str(result["stdout"]))
        message = cmd + " failed"
        if stderr != "":
            message = message + ": " + stderr
        elif stdout != "":
            message = message + ": " + stdout
        fail(message)
    return result


def starts_with(text, prefix):
    parts = method_split(text, prefix)
    if len(parts) < 2:
        return False
    return parts[0] == ""


def ends_with(text, suffix):
    if suffix == "":
        return True
    parts = method_split(text, suffix)
    if len(parts) < 2:
        return False
    return parts[-1] == ""


def parse_truthy_env(name):
    raw_value = getenv_text(name)
    value = method_strip(raw_value)
    if value == "1" or value == "true" or value == "yes":
        return True
    if value == "TRUE" or value == "True" or value == "YES" or value == "Yes":
        return True
    return False


def enforce_strict_stage_env_policy():
    require_direct_raw = method_strip(getenv_text("TYRION_NATIVE_REQUIRE_DIRECT"))
    forbid_rust_aot_raw = method_strip(getenv_text("TYRION_FORBID_RUST_AOT"))
    require_direct_ok = True
    forbid_rust_aot_ok = True
    if require_direct_raw != "":
        require_direct_ok = parse_truthy_env("TYRION_NATIVE_REQUIRE_DIRECT")
    if forbid_rust_aot_raw != "":
        forbid_rust_aot_ok = parse_truthy_env("TYRION_FORBID_RUST_AOT")
    if require_direct_ok and forbid_rust_aot_ok:
        return
    fail("STRICT POLICY VIOLATION: non-strict env override detected for stage compiler build (TYRION_NATIVE_REQUIRE_DIRECT=" + require_direct_raw + ", TYRION_FORBID_RUST_AOT=" + forbid_rust_aot_raw + "). Read NATIVE.md and keep strict gates enabled (TYRION_NATIVE_REQUIRE_DIRECT=1, TYRION_FORBID_RUST_AOT=1).")


def parse_stage_fail_closed_env():
    raw_value = getenv_text("TYRION_STAGE_FAIL_CLOSED")
    value = method_strip(raw_value)
    if value == "":
        return True
    if value == "0" or value == "false" or value == "no":
        return False
    if value == "FALSE" or value == "False" or value == "NO" or value == "No":
        return False
    return True


def is_stage_compiler_source_path(path):
    if path == "selfhost/tyrionc.ty":
        return True
    if path == "tyrionc.ty":
        return True
    if ends_with(path, "/selfhost/tyrionc.ty"):
        return True
    if ends_with(path, "\\selfhost\\tyrionc.ty"):
        return True
    return False


def native_build_target_kind(input_path):
    if is_stage_compiler_source_path(input_path):
        return "stage-compiler"
    return "user-program"


def stage_next_impl_area(family):
    if starts_with(family, "ast/program-size") or starts_with(family, "artifact/payload-size"):
        return "control-flow"
    if starts_with(family, "ast/function-call") or starts_with(family, "ast/closure") or starts_with(family, "ast/default-kwargs") or starts_with(family, "ast/kwargs"):
        return "kwargs"
    if starts_with(family, "ast/exception") or starts_with(family, "ast/raise") or starts_with(family, "ast/try"):
        return "exceptions"
    if starts_with(family, "ast/generator") or starts_with(family, "ast/yield"):
        return "generator"
    if starts_with(family, "runtime/") or starts_with(family, "runtime-helper/") or starts_with(family, "ast/builtin"):
        return "runtime-helper"
    return "control-flow"


def contains_forbidden_stage_marker(text):
    run_artifact = legacy_run_artifact_flag()
    if contains_text(text, run_artifact):
        return run_artifact
    run_embedded = legacy_run_embedded_native_flag()
    if contains_text(text, run_embedded):
        return run_embedded
    embedded_payload_marker = embedded_native_payload_marker()
    if contains_text(text, embedded_payload_marker):
        return embedded_payload_marker
    program_bin_hex_marker = payload_bin_hex_marker()
    if contains_text(text, program_bin_hex_marker):
        return program_bin_hex_marker
    compiled_payload_marker = compiled_payload_section_marker()
    if contains_text(text, compiled_payload_marker):
        return compiled_payload_marker
    payload_format_marker = compiled_payload_format_marker()
    if contains_text(text, payload_format_marker):
        return payload_format_marker
    payload_runner_symbol = payload_runner_builtin_name()
    if contains_text(text, payload_runner_symbol):
        return payload_runner_symbol
    return ""


def join_lines(lines):
    out = ""
    idx = 0
    while idx < len(lines):
        if idx > 0:
            out = out + "\n"
        out = out + lines[idx]
        idx = idx + 1
    return out


def extract_constant_print_payload_from_source(source):
    lines = method_split(source, "\n")
    significant = []
    idx = 0
    while idx < len(lines):
        raw_line = lines[idx]
        line = method_strip(raw_line)
        if line != "":
            if starts_with(line, "#") == False:
                significant = method_append(significant, line)
        idx = idx + 1
    if len(significant) != 1:
        return ""
    line = significant[0]
    if starts_with(line, "print(") == False:
        return ""
    if ends_with(line, ")") == False:
        return ""
    end_idx = len(line) - 1
    inside_raw = line[6:end_idx]
    inside = method_strip(inside_raw)
    if len(inside) < 2:
        return ""
    if starts_with(inside, "\"") == False:
        return ""
    if ends_with(inside, "\"") == False:
        return ""
    quote_end = len(inside) - 1
    quote_free = inside[1:quote_end]
    if contains_text(quote_free, "\""):
        return ""
    if contains_text(quote_free, "\\"):
        return ""
    return quote_free + "\n"


def is_simple_int_text(text):
    if text == "":
        return False
    idx = 0
    if text[0] == "-":
        if len(text) == 1:
            return False
        idx = 1
    while idx < len(text):
        if is_digit(text[idx]) == False:
            return False
        idx = idx + 1
    return True


def parse_simple_print_string_line(line):
    normalized = method_strip(line)
    if starts_with(normalized, "print(") == False:
        return {"ok": False, "value": ""}
    if ends_with(normalized, ")") == False:
        return {"ok": False, "value": ""}
    end_idx = len(normalized) - 1
    inside_raw = normalized[6:end_idx]
    inside = method_strip(inside_raw)
    if len(inside) < 2:
        return {"ok": False, "value": ""}
    if starts_with(inside, "\"") == False:
        return {"ok": False, "value": ""}
    if ends_with(inside, "\"") == False:
        return {"ok": False, "value": ""}
    value_end = len(inside) - 1
    value = inside[1:value_end]
    if contains_text(value, "\""):
        return {"ok": False, "value": ""}
    if contains_text(value, "\\"):
        return {"ok": False, "value": ""}
    return {"ok": True, "value": value}


def parse_simple_call_abi_condition(cond_text):
    parts = method_split(cond_text, "==")
    if len(parts) != 2:
        return {"ok": False, "fn_name": "", "args": [], "expected": 0}
    call_text = trim_spaces(parts[0])
    expected_text = trim_spaces(parts[1])
    if is_simple_int_text(expected_text) == False:
        return {"ok": False, "fn_name": "", "args": [], "expected": 0}
    if ends_with(call_text, ")") == False:
        return {"ok": False, "fn_name": "", "args": [], "expected": 0}
    call_parts = method_split(call_text, "(")
    if len(call_parts) != 2:
        return {"ok": False, "fn_name": "", "args": [], "expected": 0}
    fn_name = trim_spaces(call_parts[0])
    call_tail_end = len(call_parts[1]) - 1
    args_text = trim_spaces(call_parts[1][0:call_tail_end])
    if fn_name == "" or args_text == "":
        return {"ok": False, "fn_name": "", "args": [], "expected": 0}
    arg_parts = method_split(args_text, ",")
    if len(arg_parts) != 8:
        return {"ok": False, "fn_name": "", "args": [], "expected": 0}
    args = []
    idx = 0
    while idx < len(arg_parts):
        arg_text = trim_spaces(arg_parts[idx])
        if is_simple_int_text(arg_text) == False:
            return {"ok": False, "fn_name": "", "args": [], "expected": 0}
        args = method_append(args, int(arg_text))
        idx = idx + 1
    return {"ok": True, "fn_name": fn_name, "args": args, "expected": int(expected_text)}


def parse_simple_bool_text(text):
    if text == "true":
        return {"ok": True, "value": 1}
    if text == "false":
        return {"ok": True, "value": 0}
    return {"ok": False, "value": 0}


def parse_simple_var_scalar_assignment(line):
    parts = method_split(line, "=")
    if len(parts) != 2:
        return {"ok": False, "name": "", "value": 0}
    name = trim_spaces(parts[0])
    value_text = trim_spaces(parts[1])
    if name == "":
        return {"ok": False, "name": "", "value": 0}
    if is_simple_int_text(value_text):
        return {"ok": True, "name": name, "value": int(value_text), "kind": "int"}
    bool_value = parse_simple_bool_text(value_text)
    if bool_value["ok"]:
        return {"ok": True, "name": name, "value": bool_value["value"], "kind": "bool"}
    return {"ok": False, "name": "", "value": 0, "kind": ""}


def parse_simple_scalar_expr(expr, assignments):
    text = trim_spaces(expr)
    if text == "":
        return {"ok": False, "base_kind": "", "base_value": 0, "delta": 0, "value_kind": ""}
    split_add = method_split(text, "+")
    op = ""
    lhs = ""
    rhs = ""
    if len(split_add) == 2:
        op = "+"
        lhs = trim_spaces(split_add[0])
        rhs = trim_spaces(split_add[1])
    else:
        split_sub = method_split(text, "-")
        if len(split_sub) == 2 and trim_spaces(split_sub[0]) != "":
            op = "-"
            lhs = trim_spaces(split_sub[0])
            rhs = trim_spaces(split_sub[1])
    delta = 0
    base = text
    if op != "":
        if is_simple_int_text(rhs) == False:
            return {"ok": False, "base_kind": "", "base_value": 0, "delta": 0, "value_kind": ""}
        delta = int(rhs)
        base = lhs
    base_text = trim_spaces(base)
    if is_simple_int_text(base_text):
        if op == "-":
            delta = -delta
        return {"ok": True, "base_kind": "imm", "base_value": int(base_text), "delta": delta, "value_kind": "int"}
    bool_value = parse_simple_bool_text(base_text)
    if bool_value["ok"]:
        if op != "":
            return {"ok": False, "base_kind": "", "base_value": 0, "delta": 0, "value_kind": ""}
        return {"ok": True, "base_kind": "imm", "base_value": bool_value["value"], "delta": 0, "value_kind": "bool"}
    idx = 0
    while idx < len(assignments):
        entry = assignments[idx]
        if entry["name"] == base_text:
            if op == "-":
                delta = -delta
            if entry["kind"] == "bool" and op != "":
                return {"ok": False, "base_kind": "", "base_value": 0, "delta": 0, "value_kind": ""}
            return {"ok": True, "base_kind": "imm", "base_value": entry["value"], "delta": delta, "value_kind": entry["kind"]}
        idx = idx + 1
    return {"ok": False, "base_kind": "", "base_value": 0, "delta": 0, "value_kind": ""}


def detect_simple_int_compare_branch_plan(source):
    lines = method_split(source, "\n")
    significant = []
    idx = 0
    while idx < len(lines):
        line = trim_spaces(lines[idx])
        if line != "":
            if starts_with(line, "#") == False:
                significant = method_append(significant, line)
        idx = idx + 1
    if len(significant) != 6:
        return {"ok": False}
    left_assign = parse_simple_var_scalar_assignment(significant[0])
    right_assign = parse_simple_var_scalar_assignment(significant[1])
    if left_assign["ok"] == False or right_assign["ok"] == False:
        return {"ok": False}
    if starts_with(significant[2], "if ") == False or ends_with(significant[2], ":") == False:
        return {"ok": False}
    cond_end = len(significant[2]) - 1
    cond_text = trim_spaces(significant[2][3:cond_end])
    op = ""
    lhs_text = ""
    rhs_text = ""
    operator_candidates = ["<=", ">=", "==", "!=", "<", ">"]
    op_idx = 0
    while op_idx < len(operator_candidates):
        candidate = operator_candidates[op_idx]
        parts = method_split(cond_text, candidate)
        if len(parts) == 2:
            op = candidate
            lhs_text = trim_spaces(parts[0])
            rhs_text = trim_spaces(parts[1])
            op_idx = len(operator_candidates)
        else:
            op_idx = op_idx + 1
    if op == "":
        return {"ok": False}
    assignments = [left_assign, right_assign]
    lhs_expr = parse_simple_scalar_expr(lhs_text, assignments)
    rhs_expr = parse_simple_scalar_expr(rhs_text, assignments)
    if lhs_expr["ok"] == False or rhs_expr["ok"] == False:
        return {"ok": False}
    true_print = parse_simple_print_string_line(significant[3])
    if true_print["ok"] == False:
        return {"ok": False}
    if significant[4] != "else:":
        return {"ok": False}
    false_print = parse_simple_print_string_line(significant[5])
    if false_print["ok"] == False:
        return {"ok": False}
    return {"ok": True, "op": op, "lhs_expr": lhs_expr, "rhs_expr": rhs_expr, "true_text": true_print["value"] + "\n", "false_text": false_print["value"] + "\n"}


def detect_simple_int_call_abi_branch_plan(source):
    lines = method_split(source, "\n")
    significant = []
    idx = 0
    while idx < len(lines):
        line = trim_spaces(lines[idx])
        if line != "":
            if starts_with(line, "#") == False:
                significant = method_append(significant, line)
        idx = idx + 1
    if len(significant) != 4:
        return {"ok": False}
    if starts_with(significant[0], "if ") == False or ends_with(significant[0], ":") == False:
        return {"ok": False}
    cond_end = len(significant[0]) - 1
    cond_text = trim_spaces(significant[0][3:cond_end])
    call_cond = parse_simple_call_abi_condition(cond_text)
    if call_cond["ok"] == False:
        return {"ok": False}
    true_print = parse_simple_print_string_line(significant[1])
    if true_print["ok"] == False:
        return {"ok": False}
    if significant[2] != "else:":
        return {"ok": False}
    false_print = parse_simple_print_string_line(significant[3])
    if false_print["ok"] == False:
        return {"ok": False}
    return {"ok": True, "fn_name": call_cond["fn_name"], "args": call_cond["args"], "expected": call_cond["expected"], "true_text": true_print["value"] + "\n", "false_text": false_print["value"] + "\n"}


def detect_simple_loop_break_continue_branch_plan(source):
    lines = method_split(source, "\n")
    significant = []
    idx = 0
    while idx < len(lines):
        line = trim_spaces(lines[idx])
        if line != "":
            if starts_with(line, "#") == False:
                significant = method_append(significant, line)
        idx = idx + 1
    if len(significant) != 13:
        return {"ok": False}
    if significant[0] != "i = 0":
        return {"ok": False}
    if significant[1] != "total = 0":
        return {"ok": False}
    if significant[2] != "while i < 6:":
        return {"ok": False}
    if significant[3] != "i = i + 1":
        return {"ok": False}
    if significant[4] != "if i == 2:":
        return {"ok": False}
    if significant[5] != "continue":
        return {"ok": False}
    if significant[6] != "if i == 5:":
        return {"ok": False}
    if significant[7] != "break":
        return {"ok": False}
    if significant[8] != "total = total + i":
        return {"ok": False}
    if significant[9] != "if total == 8:":
        return {"ok": False}
    true_print = parse_simple_print_string_line(significant[10])
    if true_print["ok"] == False:
        return {"ok": False}
    if significant[11] != "else:":
        return {"ok": False}
    false_print = parse_simple_print_string_line(significant[12])
    if false_print["ok"] == False:
        return {"ok": False}
    return {"ok": True, "true_text": true_print["value"] + "\n", "false_text": false_print["value"] + "\n"}


def detect_simple_for_range_if_else_branch_plan(source):
    lines = method_split(source, "\n")
    significant = []
    idx = 0
    while idx < len(lines):
        line = trim_spaces(lines[idx])
        if line != "":
            if starts_with(line, "#") == False:
                significant = method_append(significant, line)
        idx = idx + 1
    if len(significant) != 10:
        return {"ok": False}
    if significant[0] != "total = 0":
        return {"ok": False}
    if significant[1] != "for i in range(1, 6):":
        return {"ok": False}
    if significant[2] != "if i == 3:":
        return {"ok": False}
    if significant[3] != "total = total + 10":
        return {"ok": False}
    if significant[4] != "else:":
        return {"ok": False}
    if significant[5] != "total = total + i":
        return {"ok": False}
    if significant[6] != "if total == 22:":
        return {"ok": False}
    true_print = parse_simple_print_string_line(significant[7])
    if true_print["ok"] == False:
        return {"ok": False}
    if significant[8] != "else:":
        return {"ok": False}
    false_print = parse_simple_print_string_line(significant[9])
    if false_print["ok"] == False:
        return {"ok": False}
    return {"ok": True, "true_text": true_print["value"] + "\n", "false_text": false_print["value"] + "\n"}


def detect_runtime_hook_labels(source):
    hooks = []
    if contains_text(source, "__tyrion_native_argv("):
        hooks = method_append(hooks, "argv")
    if contains_text(source, "__tyrion_native_getenv("):
        hooks = method_append(hooks, "getenv")
    if contains_text(source, "__tyrion_native_wall_time(") or contains_text(source, "time(") or contains_text(source, "sleep("):
        hooks = method_append(hooks, "wall-time")
    if contains_text(source, "__tyrion_native_read_file("):
        hooks = method_append(hooks, "read-file")
    if contains_text(source, "__tyrion_native_list_dir("):
        hooks = method_append(hooks, "list-dir")
    if contains_text(source, "std_http_get(") or contains_text(source, "__tyrion_native_http_get("):
        hooks = method_append(hooks, "http-get")
    if contains_text(source, "std_http_post(") or contains_text(source, "__tyrion_native_http_post("):
        hooks = method_append(hooks, "http-post")
    if contains_text(source, "std_http_https_get(") or contains_text(source, "__tyrion_native_https_get("):
        hooks = method_append(hooks, "https-get")
    if contains_text(source, "std_io_tcp_connect(") or contains_text(source, "__tyrion_native_tcp_connect("):
        hooks = method_append(hooks, "tcp-connect")
    if contains_text(source, "std_io_tcp_read(") or contains_text(source, "__tyrion_native_tcp_read("):
        hooks = method_append(hooks, "tcp-read")
    if contains_text(source, "std_io_tcp_write(") or contains_text(source, "__tyrion_native_tcp_write("):
        hooks = method_append(hooks, "tcp-write")
    if contains_text(source, "std_io_tcp_close(") or contains_text(source, "__tyrion_native_tcp_close("):
        hooks = method_append(hooks, "tcp-close")
    if contains_text(source, "std_io_spawn_process_stdio(") or contains_text(source, "__tyrion_native_spawn_process_stdio("):
        hooks = method_append(hooks, "process-spawn-stdio")
    if contains_text(source, "std_io_process_read(") or contains_text(source, "__tyrion_native_process_read("):
        hooks = method_append(hooks, "process-read")
    if contains_text(source, "std_io_process_wait(") or contains_text(source, "__tyrion_native_process_wait("):
        hooks = method_append(hooks, "process-wait")
    if contains_text(source, "std_io_process_kill(") or contains_text(source, "__tyrion_native_process_kill("):
        hooks = method_append(hooks, "process-kill")
    if contains_text(source, "std_io_dlopen(") or contains_text(source, "__tyrion_native_dlopen("):
        hooks = method_append(hooks, "dlopen")
    if contains_text(source, "std_io_dlsym(") or contains_text(source, "__tyrion_native_dlsym("):
        hooks = method_append(hooks, "dlsym")
    if contains_text(source, "std_ext_call_binding_str_v1(") or contains_text(source, "__tyrion_native_extension_call_cstr("):
        hooks = method_append(hooks, "ext-call-cstr")
    if contains_text(source, "std_ext_call_binding_typed_v1(") or contains_text(source, "__tyrion_native_extension_call_typed_v1("):
        hooks = method_append(hooks, "ext-call-typed-v1")
    if contains_text(source, "__tyrion_native_host_load("):
        hooks = method_append(hooks, "host-load")
    if contains_text(source, "__tyrion_native_host_call("):
        hooks = method_append(hooks, "host-call")
    if contains_text(source, "__tyrion_native_host_unload("):
        hooks = method_append(hooks, "host-unload")
    if contains_text(source, "__tyrion_native_capabilities("):
        hooks = method_append(hooks, "capabilities")
    if contains_text(source, "__tyrion_native_link(") or contains_text(source, "__tyrion_native_link_embedded("):
        hooks = method_append(hooks, "native-link")
    return hooks


def native_helper_symbol_specs():
    specs = []
    specs = method_append(specs, {"name": "__tyrion_native_argv", "abi_symbol": "tyrion_rt_argv", "signature": "() -> list[str]"})
    specs = method_append(specs, {"name": "__tyrion_native_getenv", "abi_symbol": "tyrion_rt_getenv", "signature": "(name: str) -> str"})
    specs = method_append(specs, {"name": "__tyrion_native_wall_time", "abi_symbol": "tyrion_rt_wall_time", "signature": "() -> int"})
    specs = method_append(specs, {"name": "__tyrion_native_read_file", "abi_symbol": "tyrion_rt_read_file", "signature": "(path: str[, offset: int, len: int]) -> str"})
    specs = method_append(specs, {"name": "__tyrion_native_list_dir", "abi_symbol": "tyrion_rt_list_dir", "signature": "(path: str) -> list[dict]"})
    specs = method_append(specs, {"name": "__tyrion_native_tcp_connect", "abi_symbol": "tyrion_rt_tcp_connect", "signature": "(host: str, port: int, timeout_ms: int) -> int"})
    specs = method_append(specs, {"name": "__tyrion_native_tcp_read", "abi_symbol": "tyrion_rt_tcp_read", "signature": "(handle: int, max_bytes: int, timeout_ms: int) -> bytes|eof"})
    specs = method_append(specs, {"name": "__tyrion_native_tcp_write", "abi_symbol": "tyrion_rt_tcp_write", "signature": "(handle: int, bytes: list[int], timeout_ms: int) -> int"})
    specs = method_append(specs, {"name": "__tyrion_native_tcp_close", "abi_symbol": "tyrion_rt_tcp_close", "signature": "(handle: int) -> bool"})
    specs = method_append(specs, {"name": "__tyrion_native_spawn_process_stdio", "abi_symbol": "tyrion_rt_spawn_process_stdio", "signature": "(cmd: str, args: list[str], env: dict|None, cwd: str|None, stdin: bytes|None) -> int"})
    specs = method_append(specs, {"name": "__tyrion_native_process_read", "abi_symbol": "tyrion_rt_process_read", "signature": "(handle: int, stream: str, max_bytes: int, timeout_ms: int) -> bytes|eof"})
    specs = method_append(specs, {"name": "__tyrion_native_process_wait", "abi_symbol": "tyrion_rt_process_wait", "signature": "(handle: int, timeout_ms: int) -> dict"})
    specs = method_append(specs, {"name": "__tyrion_native_process_kill", "abi_symbol": "tyrion_rt_process_kill", "signature": "(handle: int) -> bool"})
    specs = method_append(specs, {"name": "__tyrion_native_dlopen", "abi_symbol": "tyrion_rt_dlopen", "signature": "(path: str, extension_name: str, abi_major: int, abi_minor: int) -> int"})
    specs = method_append(specs, {"name": "__tyrion_native_dlsym", "abi_symbol": "tyrion_rt_dlsym", "signature": "(handle: int, symbol: str, expected_abi_major: int) -> bool"})
    specs = method_append(specs, {"name": "__tyrion_native_extension_call_cstr", "abi_symbol": "tyrion_rt_extension_call_cstr", "signature": "(handle: int, symbol: str, arg: str, expected_abi_major: int) -> str"})
    specs = method_append(specs, {"name": "__tyrion_native_extension_call_typed_v1", "abi_symbol": "tyrion_rt_extension_call_typed_v1", "signature": "(handle: int, symbol: str, operation_id: str, arg_types_csv: str, return_type: str, expected_abi_major: int, args: list) -> typed"})
    specs = method_append(specs, {"name": "__tyrion_native_host_load", "abi_symbol": "tyrion_rt_host_load", "signature": "(lib_path: str) -> int"})
    specs = method_append(specs, {"name": "__tyrion_native_host_call", "abi_symbol": "tyrion_rt_host_call", "signature": "(handle: int, op: str, payload: str) -> str|none"})
    specs = method_append(specs, {"name": "__tyrion_native_host_unload", "abi_symbol": "tyrion_rt_host_unload", "signature": "(handle: int) -> bool"})
    specs = method_append(specs, {"name": "__tyrion_native_http_get", "abi_symbol": "tyrion_rt_http_get", "signature": "(url: str) -> str"})
    specs = method_append(specs, {"name": "__tyrion_native_http_post", "abi_symbol": "tyrion_rt_http_post", "signature": "(url: str, body: str) -> str"})
    specs = method_append(specs, {"name": "__tyrion_native_https_get", "abi_symbol": "tyrion_rt_https_get", "signature": "(url: str, timeout_ms: int) -> str"})
    specs = method_append(specs, {"name": "__tyrion_native_capabilities", "abi_symbol": "tyrion_rt_capabilities", "signature": "() -> dict"})
    specs = method_append(specs, {"name": "__tyrion_native_link", "abi_symbol": "internal-native-link", "signature": "(output: str, artifact: str, deterministic: bool) -> bool"})
    specs = method_append(specs, {"name": "__tyrion_native_link_embedded", "abi_symbol": "internal-native-link-embedded", "signature": "(output: str, deterministic: bool) -> bool"})
    return specs


def native_helper_symbol_names():
    names = []
    specs = native_helper_symbol_specs()
    idx = 0
    while idx < len(specs):
        names = method_append(names, specs[idx]["name"])
        idx = idx + 1
    return names


def collect_native_helper_call_names(source):
    names = []
    i = 0
    n = len(source)
    prefix = "__tyrion_native_"
    prefix_len = len(prefix)
    while i < n:
        if i + prefix_len <= n and source[i:i + prefix_len] == prefix:
            j = i + prefix_len
            while j < n and is_alnum(source[j]):
                j = j + 1
            name = source[i:j]
            k = j
            while k < n and is_whitespace(source[k]):
                k = k + 1
            if k < n and source[k] == "(":
                if contains(names, name) == False:
                    names = method_append(names, name)
            i = j
        else:
            i = i + 1
    return names


def fail_if_unknown_native_helper_calls(source):
    called = collect_native_helper_call_names(source)
    allowed = native_helper_symbol_names()
    unknown = []
    idx = 0
    while idx < len(called):
        helper = called[idx]
        if contains(allowed, helper) == False:
            unknown = method_append(unknown, helper)
        idx = idx + 1
    if len(unknown) > 0:
        fail("unknown native helper call(s): " + join_csv(unknown) + "; allowed: " + join_csv(allowed))


def should_skip_simple_lowering_detectors(source):
    # Simple template detectors are intended for tiny staged fixtures.
    # Large compiler-scale sources are routed directly to runtime-hooks/compiled-payload planning.
    if len(source) > 20000:
        return True
    return False


# PASS CONTRACT: Backend lowering-plan selection
# Input: source text.
# Output: plan record with stable "kind" and optional specialized plan payloads.
# Failure: never soft-fallback; unknown shapes resolve to "compiled-payload".
def native_lowering_plan_from_source(source):
    emit_compile_progress("native_lowering_plan_from_source:start")
    emit_compile_progress("native_lowering_plan_from_source:check_unknown_helpers:start")
    fail_if_unknown_native_helper_calls(source)
    emit_compile_progress("native_lowering_plan_from_source:check_unknown_helpers:done")
    if should_skip_simple_lowering_detectors(source):
        emit_compile_progress("native_lowering_plan_from_source:large_source_shortcut")
        # Compiler-scale sources still run helper/hook ownership scans but skip
        # branch detector passes to avoid repeated whole-source pattern scans.
        hooks = detect_runtime_hook_labels(source)
        if len(hooks) > 0:
            return {"kind": "runtime-hooks", "runtime_hooks": hooks}
        return {"kind": "compiled-payload", "runtime_hooks": [], "branch_plan": {"ok": False}}
    for_range_plan = detect_simple_for_range_if_else_branch_plan(source)
    if for_range_plan["ok"]:
        return {"kind": "for-range-if-else-branch", "runtime_hooks": [], "for_range_if_else_branch_plan": for_range_plan}
    loop_plan = detect_simple_loop_break_continue_branch_plan(source)
    if loop_plan["ok"]:
        return {"kind": "loop-break-continue-branch", "runtime_hooks": [], "loop_break_continue_branch_plan": loop_plan}
    call_abi_branch_plan = detect_simple_int_call_abi_branch_plan(source)
    if call_abi_branch_plan["ok"]:
        return {"kind": "int-call-abi-branch", "runtime_hooks": [], "call_abi_branch_plan": call_abi_branch_plan}
    branch_plan = detect_simple_int_compare_branch_plan(source)
    if branch_plan["ok"]:
        return {"kind": "int-compare-branch", "runtime_hooks": [], "branch_plan": branch_plan}
    constant_payload = extract_constant_print_payload_from_source(source)
    if constant_payload != "":
        return {"kind": "print-constant", "constant_payload": constant_payload, "runtime_hooks": []}
    hooks = detect_runtime_hook_labels(source)
    if len(hooks) > 0:
        return {"kind": "runtime-hooks", "runtime_hooks": hooks}
    return {"kind": "compiled-payload", "runtime_hooks": [], "branch_plan": {"ok": False}}


def annotate_asm_with_lowering_plan(asm, plan):
    if plan["kind"] == "compiled-payload":
        return asm
    header_and_rest = method_split(asm, "\n")
    if len(header_and_rest) == 0:
        return asm
    header = header_and_rest[0]
    rest = []
    idx = 1
    while idx < len(header_and_rest):
        rest = method_append(rest, header_and_rest[idx])
        idx = idx + 1
    comment = "# lowering-plan=" + plan["kind"]
    if plan["kind"] == "runtime-hooks":
        comment = comment + " hooks=" + join_csv(plan["runtime_hooks"])
    if plan["kind"] == "int-compare-branch":
        comment = comment + " op=" + plan["branch_plan"]["op"]
    if plan["kind"] == "int-call-abi-branch":
        comment = comment + " fn=" + plan["call_abi_branch_plan"]["fn_name"]
    if plan["kind"] == "loop-break-continue-branch":
        comment = comment + " shape=while-if-continue-if-break"
    if plan["kind"] == "for-range-if-else-branch":
        comment = comment + " shape=for-range-if-else"
    out = header + "\n" + comment
    if len(rest) > 0:
        out = out + "\n" + join_lines(rest)
    return out


def set_native_artifact_marker(artifact_path, marker_prefix, value):
    text = read_text_file(artifact_path)
    lines = method_split(text, "\n")
    updated = []
    found = False
    idx = 0
    while idx < len(lines):
        line = lines[idx]
        if starts_with(line, marker_prefix):
            found = True
            if value != "":
                updated = method_append(updated, marker_prefix + value)
        else:
            updated = method_append(updated, line)
        idx = idx + 1
    if found == False and value != "":
        inserted = []
        inserted_once = False
        j = 0
        while j < len(updated):
            line = updated[j]
            if inserted_once == False and line == compiled_payload_section_marker():
                inserted = method_append(inserted, marker_prefix + value)
                inserted_once = True
            elif inserted_once == False and line == "---TYPED-IR---":
                inserted = method_append(inserted, marker_prefix + value)
                inserted_once = True
            elif inserted_once == False and line == "---ASM---":
                inserted = method_append(inserted, marker_prefix + value)
                inserted_once = True
            inserted = method_append(inserted, line)
            j = j + 1
        if inserted_once == False:
            inserted = method_append(inserted, marker_prefix + value)
        updated = inserted
    write_text_file(artifact_path, join_lines(updated))


def clear_native_artifact_marker(artifact_path, marker_prefix):
    text = read_text_file(artifact_path)
    lines = method_split(text, "\n")
    updated = []
    idx = 0
    while idx < len(lines):
        line = lines[idx]
        if starts_with(line, marker_prefix) == False:
            updated = method_append(updated, line)
        idx = idx + 1
    write_text_file(artifact_path, join_lines(updated))


def set_native_direct_sanitizer_marker(artifact_path, sanitizer):
    if sanitizer == "":
        clear_native_artifact_marker(artifact_path, "native-direct-sanitizer=")
    else:
        set_native_artifact_marker(artifact_path, "native-direct-sanitizer=", sanitizer)


def remove_native_compiled_payload_if_direct(artifact_path):
    text = read_text_file(artifact_path)
    link_mode = extract_between_or_empty(text, "native-link-mode=", "\n")
    if link_mode != "direct":
        return False
    changed = False
    start_marker = compiled_payload_section_start()
    end_marker = "\n---TYPED-IR---\n"
    parts = method_split(text, start_marker)
    updated = text
    if len(parts) >= 2:
        payload_tail = parts[1]
        end_parts = method_split(payload_tail, end_marker)
        if len(end_parts) >= 2:
            updated = parts[0] + "---TYPED-IR---\n" + end_parts[1]
            changed = True
    asm_marker = "---ASM---\n"
    asm_parts = method_split(updated, asm_marker)
    if len(asm_parts) >= 2:
        asm_text = asm_parts[1]
        if contains_text(asm_text, compiled_payload_format_marker()) or contains_text(asm_text, payload_bin_hex_marker()):
            asm_lines = method_split(asm_text, "\n")
            asm_header = ".intel_syntax noprefix"
            if len(asm_lines) > 0 and asm_lines[0] != "":
                asm_header = asm_lines[0]
            lowering_comment = ""
            idx = 0
            while idx < len(asm_lines):
                asm_line = asm_lines[idx]
                if starts_with(asm_line, "# lowering-plan=") or starts_with(asm_line, "; lowering-plan="):
                    lowering_comment = asm_line
                    idx = len(asm_lines)
                else:
                    idx = idx + 1
            sanitized_asm = asm_header + "\n"
            if lowering_comment != "":
                sanitized_asm = sanitized_asm + lowering_comment + "\n"
            sanitized_asm = sanitized_asm + "# payload-redacted-for-direct-no-fallback\n"
            sanitized_asm = sanitized_asm + "__tyrion_payload_0:\n"
            sanitized_asm = sanitized_asm + ".byte 0\n"
            updated = asm_parts[0] + asm_marker + sanitized_asm
            changed = True
    if changed:
        write_text_file(artifact_path, updated)
    return changed


def normalize_native_artifact_header(artifact_path):
    text = read_text_file(artifact_path)
    lines = method_split(text, "\n")
    header_idx = -1
    idx = 0
    while idx < len(lines):
        if lines[idx] == "tyrion-selfhost-native v0" or lines[idx] == "tyrionc-native-artifact v1":
            header_idx = idx
            idx = len(lines)
        else:
            idx = idx + 1
    if header_idx <= 0:
        return
    header = lines[header_idx]
    normalized = [header]
    j = 0
    while j < len(lines):
        if j != header_idx:
            normalized = method_append(normalized, lines[j])
        j = j + 1
    write_text_file(artifact_path, join_lines(normalized))


def backend_target(arch, os_name, abi_name, triple, asm_syntax, entry_symbol, text_section, rodata_section):
    return {"arch": arch, "os": os_name, "abi": abi_name, "triple": triple, "asm_syntax": asm_syntax, "entry_symbol": entry_symbol, "text_section": text_section, "rodata_section": rodata_section}


def backend_target_family_from_os(os_name):
    if os_name == "darwin":
        return "darwin"
    if os_name == "linux":
        return "linux"
    return ""


def backend_target_for_family(target_arch, target_family):
    target_triple = target_arch + "-" + target_family
    target_asm_syntax = "elf-gas"
    target_entry_symbol = "_start"
    target_text_section = ".text"
    target_rodata_section = ".section .rodata"
    target_family_is_darwin = target_family == "darwin"
    target_family_is_linux = target_family == "linux"
    if target_family_is_darwin:
        target_asm_syntax = "mach-o"
        target_entry_symbol = "_main"
        target_text_section = ".section __TEXT,__text"
        target_rodata_section = ".section __TEXT,__cstring"
    elif target_family_is_linux != True:
        fail("unsupported backend target family: " + target_family)
    return backend_target(target_arch, target_family, "sysv", target_triple, target_asm_syntax, target_entry_symbol, target_text_section, target_rodata_section)


def backend_target_for_host():
    arch_override = trim_spaces(getenv_text("TYRION_NATIVE_HOST_ARCH"))
    arch_hint = arch_override
    arch_override_provided = arch_override != ""
    if arch_hint == "":
        uname_arch = __tyrion_run_tool("uname", ["-m"])
        if uname_arch["ok"]:
            arch_hint = trim_spaces(str(uname_arch["stdout"]))
    arch_hint_has_aarch64 = contains_text(arch_hint, "aarch64")
    if arch_hint_has_aarch64 != True:
        arch_hint_has_aarch64 = contains_text(arch_hint, "arm64")
    if arch_hint_has_aarch64 != True:
        arch_hint_has_aarch64 = contains_text(arch_hint, "AARCH64")
    if arch_hint_has_aarch64 != True:
        arch_hint_has_aarch64 = contains_text(arch_hint, "ARM64")
    arch_hint_has_x64 = contains_text(arch_hint, "x86_64")
    if arch_hint_has_x64 != True:
        arch_hint_has_x64 = contains_text(arch_hint, "amd64")
    if arch_hint_has_x64 != True:
        arch_hint_has_x64 = contains_text(arch_hint, "X86_64")
    if arch_hint_has_x64 != True:
        arch_hint_has_x64 = contains_text(arch_hint, "AMD64")
    arch_hint_known = arch_hint_has_aarch64
    if arch_hint_known != True:
        arch_hint_known = arch_hint_has_x64
    host_arch = "x86_64"
    if arch_hint_has_aarch64:
        host_arch = "aarch64"
    if arch_override_provided and arch_hint_known != True:
        fail("unsupported TYRION_NATIVE_HOST_ARCH override: " + arch_override)
    os_override = trim_spaces(getenv_text("TYRION_NATIVE_HOST_OS"))
    os_hint = os_override
    os_override_provided = os_override != ""
    if os_hint == "":
        uname_os = __tyrion_run_tool("uname", ["-s"])
        if uname_os["ok"]:
            os_hint = trim_spaces(str(uname_os["stdout"]))
    os_hint_has_darwin = contains_text(os_hint, "darwin")
    if os_hint_has_darwin != True:
        os_hint_has_darwin = contains_text(os_hint, "Darwin")
    if os_hint_has_darwin != True:
        os_hint_has_darwin = contains_text(os_hint, "macos")
    if os_hint_has_darwin != True:
        os_hint_has_darwin = contains_text(os_hint, "MacOS")
    os_hint_has_linux = contains_text(os_hint, "linux")
    if os_hint_has_linux != True:
        os_hint_has_linux = contains_text(os_hint, "Linux")
    os_hint_known = os_hint_has_darwin
    if os_hint_known != True:
        os_hint_known = os_hint_has_linux
    host_os = "linux"
    if os_hint_has_darwin:
        host_os = "darwin"
    if os_override_provided and os_hint_known != True:
        fail("unsupported TYRION_NATIVE_HOST_OS override: " + os_override)
    host_family = backend_target_family_from_os(host_os)
    return backend_target_for_family(host_arch, host_family)


def backend_target_from_cli(value):
    target_arg = trim_spaces(value)
    target_token = target_arg
    target_arg_has_prefix = starts_with(target_arg, "--target=")
    if target_arg_has_prefix:
        target_token = method_split(target_arg, "--target=")[1]
    target_token = trim_spaces(target_token)
    if target_token == "":
        return backend_target_for_host()
    target_has_darwin = contains_text(target_token, "darwin")
    if target_has_darwin != True:
        target_has_darwin = contains_text(target_token, "Darwin")
    if target_has_darwin != True:
        target_has_darwin = contains_text(target_token, "macos")
    if target_has_darwin != True:
        target_has_darwin = contains_text(target_token, "MacOS")
    target_has_linux = contains_text(target_token, "linux")
    if target_has_linux != True:
        target_has_linux = contains_text(target_token, "Linux")
    target_has_aarch64 = contains_text(target_token, "aarch64")
    if target_has_aarch64 != True:
        target_has_aarch64 = contains_text(target_token, "arm64")
    if target_has_aarch64 != True:
        target_has_aarch64 = contains_text(target_token, "AARCH64")
    if target_has_aarch64 != True:
        target_has_aarch64 = contains_text(target_token, "ARM64")
    target_has_x64 = contains_text(target_token, "x86_64")
    if target_has_x64 != True:
        target_has_x64 = contains_text(target_token, "amd64")
    if target_has_x64 != True:
        target_has_x64 = contains_text(target_token, "X86_64")
    if target_has_x64 != True:
        target_has_x64 = contains_text(target_token, "AMD64")
    target_os = ""
    if target_has_darwin:
        target_os = "darwin"
    if target_has_linux:
        if target_os != "":
            fail("unsupported --target value (ambiguous os family): " + target_token)
        target_os = "linux"
    target_arch = ""
    if target_has_aarch64:
        target_arch = "aarch64"
    if target_has_x64:
        if target_arch != "":
            fail("unsupported --target value (ambiguous arch family): " + target_token)
        target_arch = "x86_64"
    if target_os == "":
        fail("unsupported --target value: " + target_token)
    if target_arch == "":
        fail("unsupported --target value: " + target_token)
    target_family = backend_target_family_from_os(target_os)
    if target_family == "":
        fail("unsupported --target value: " + target_token)
    return backend_target_for_family(target_arch, target_family)


def asm_directive(text):
    return text + "\n"


def asm_label(name):
    return name + ":\n"


def asm_instr(op, operands):
    if operands == "":
        return "    " + op + "\n"
    return "    " + op + " " + operands + "\n"


def asm_encode_immediate(value):
    return str(value)


def asm_escape_string(text):
    return __tyrion_escape_asm_string(text)


# -----------------------------------------------------------------------------
# MODULE SECTION: Backend (target resolution + asm emission + artifact layout)
# -----------------------------------------------------------------------------

def emitter_state(deterministic):
    return {"deterministic": deterministic, "symbol_idx": 0}


def next_symbol(state, prefix):
    idx = state["symbol_idx"]
    state["symbol_idx"] = idx + 1
    if state["deterministic"]:
        return "__tyrion_" + prefix + "_" + str(idx)
    return "__tyrion_" + prefix + "_" + str(idx) + "_" + str(int(wall_time_seconds()))


def emit_linux_x86_64_asm(compiled_payload, deterministic, target):
    state = emitter_state(deterministic)
    payload_label = next_symbol(state, "payload")
    payload_len = len(compiled_payload)
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; linux x86_64 constant-output fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "$1, %rax" + "\n"
    out = out + "    " + "mov" + " " + "$1, %rdi" + "\n"
    out = out + "    " + "lea" + " " + payload_label + "(%rip), %rsi" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(payload_len) + ", %rdx" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + "    " + "mov" + " " + "$60, %rax" + "\n"
    out = out + "    " + "xor" + " " + "%rdi, %rdi" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(compiled_payload) + "\"" + "\n"
    return out


def emit_linux_x86_64_int_compare_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    op = plan["op"]
    jump = "jne"
    if op == "<":
        jump = "jl"
    elif op == "<=":
        jump = "jle"
    elif op == ">":
        jump = "jg"
    elif op == ">=":
        jump = "jge"
    elif op == "==":
        jump = "je"
    lhs_expr = plan["lhs_expr"]
    rhs_expr = plan["rhs_expr"]
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; linux x86_64 integer compare/branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "$" + str(lhs_expr["base_value"]) + ", %rax" + "\n"
    if lhs_expr["delta"] > 0:
        out = out + "    " + "add" + " " + "$" + str(lhs_expr["delta"]) + ", %rax" + "\n"
    elif lhs_expr["delta"] < 0:
        out = out + "    " + "sub" + " " + "$" + str(-lhs_expr["delta"]) + ", %rax" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(rhs_expr["base_value"]) + ", %rbx" + "\n"
    if rhs_expr["delta"] > 0:
        out = out + "    " + "add" + " " + "$" + str(rhs_expr["delta"]) + ", %rbx" + "\n"
    elif rhs_expr["delta"] < 0:
        out = out + "    " + "sub" + " " + "$" + str(-rhs_expr["delta"]) + ", %rbx" + "\n"
    out = out + "    " + "cmp" + " " + "%rbx, %rax" + "\n"
    out = out + "    " + jump + " " + true_label + "\n"
    out = out + "    " + "lea" + " " + false_payload_label + "(%rip), %rdi" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(false_payload_len) + ", %rsi" + "\n"
    out = out + "    " + "call" + " " + runtime_print_stub_label + "\n"
    out = out + "    " + "jmp" + " " + done_label + "\n"
    out = out + true_label + ":\n"
    out = out + "    " + "lea" + " " + true_payload_label + "(%rip), %rdi" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(true_payload_len) + ", %rsi" + "\n"
    out = out + "    " + "call" + " " + runtime_print_stub_label + "\n"
    out = out + done_label + ":\n"
    out = out + "    " + "mov" + " " + "$60, %rax" + "\n"
    out = out + "    " + "xor" + " " + "%rdi, %rdi" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + runtime_print_stub_label + ":\n"
    out = out + "; runtime-abi print-line(ptr=%rdi, len=%rsi) -> %rax" + "\n"
    out = out + "; abi-clobber-policy: preserve callee-saved registers and syscall-clobbered rcx/r11" + "\n"
    out = out + "    " + "pushq" + " " + "%rbp" + "\n"
    out = out + "    " + "movq" + " " + "%rsp, %rbp" + "\n"
    out = out + "    " + "pushq" + " " + "%rbx" + "\n"
    out = out + "    " + "pushq" + " " + "%rcx" + "\n"
    out = out + "    " + "pushq" + " " + "%r11" + "\n"
    out = out + "    " + "movq" + " " + "%rdi, %rbx" + "\n"
    out = out + "    " + "movq" + " " + "%rsi, %r10" + "\n"
    out = out + "    " + "movq" + " " + "$1, %rax" + "\n"
    out = out + "    " + "movq" + " " + "$1, %rdi" + "\n"
    out = out + "    " + "movq" + " " + "%rbx, %rsi" + "\n"
    out = out + "    " + "movq" + " " + "%r10, %rdx" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + "    " + "popq" + " " + "%r11" + "\n"
    out = out + "    " + "popq" + " " + "%rcx" + "\n"
    out = out + "    " + "popq" + " " + "%rbx" + "\n"
    out = out + "    " + "leave" + " " + "" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + true_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["true_text"]) + "\"" + "\n"
    out = out + false_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["false_text"]) + "\"" + "\n"
    return out


def emit_linux_x86_64_int_call_abi_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    callee_label = next_symbol(state, "call_target")
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    args = plan["args"]
    expected = plan["expected"]
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; linux x86_64 call-abi branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "$" + str(args[0]) + ", %rdi" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(args[1]) + ", %rsi" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(args[2]) + ", %rdx" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(args[3]) + ", %rcx" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(args[4]) + ", %r8" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(args[5]) + ", %r9" + "\n"
    out = out + "; sysv-abi call boundary: reserve outgoing arg area to keep %rsp 16-byte aligned before call" + "\n"
    out = out + "    " + "subq" + " " + "$16, %rsp" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[6]) + ", (%rsp)" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[7]) + ", 8(%rsp)" + "\n"
    out = out + "    " + "call" + " " + callee_label + "\n"
    out = out + "    " + "addq" + " " + "$16, %rsp" + "\n"
    out = out + "    " + "cmp" + " " + "$" + str(expected) + ", %rax" + "\n"
    out = out + "    " + "je" + " " + true_label + "\n"
    out = out + "    " + "lea" + " " + false_payload_label + "(%rip), %rdi" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(false_payload_len) + ", %rsi" + "\n"
    out = out + "    " + "call" + " " + runtime_print_stub_label + "\n"
    out = out + "    " + "jmp" + " " + done_label + "\n"
    out = out + true_label + ":\n"
    out = out + "    " + "lea" + " " + true_payload_label + "(%rip), %rdi" + "\n"
    out = out + "    " + "mov" + " " + "$" + str(true_payload_len) + ", %rsi" + "\n"
    out = out + "    " + "call" + " " + runtime_print_stub_label + "\n"
    out = out + done_label + ":\n"
    out = out + "    " + "mov" + " " + "$60, %rax" + "\n"
    out = out + "    " + "xor" + " " + "%rdi, %rdi" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + callee_label + ":\n"
    out = out + "; sysv-abi add8(a1..a8) with explicit frame-slot layout" + "\n"
    out = out + "    " + "pushq" + " " + "%rbp" + "\n"
    out = out + "    " + "movq" + " " + "%rsp, %rbp" + "\n"
    out = out + "    " + "pushq" + " " + "%rbx" + "\n"
    out = out + "    " + "subq" + " " + "$64, %rsp" + "\n"
    out = out + "    " + "movq" + " " + "%rdi, -8(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%rsi, -16(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%rdx, -24(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%rcx, -32(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%r8, -40(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%r9, -48(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "16(%rbp), %rax" + "\n"
    out = out + "    " + "movq" + " " + "%rax, -56(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "24(%rbp), %rax" + "\n"
    out = out + "    " + "movq" + " " + "%rax, -64(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "-8(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-16(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-24(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-32(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-40(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-48(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-56(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-64(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "$64, %rsp" + "\n"
    out = out + "    " + "popq" + " " + "%rbx" + "\n"
    out = out + "    " + "leave" + " " + "" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + runtime_print_stub_label + ":\n"
    out = out + "; runtime-abi print-line(ptr=%rdi, len=%rsi) -> %rax" + "\n"
    out = out + "; abi-clobber-policy: preserve callee-saved registers and syscall-clobbered rcx/r11" + "\n"
    out = out + "    " + "pushq" + " " + "%rbp" + "\n"
    out = out + "    " + "movq" + " " + "%rsp, %rbp" + "\n"
    out = out + "    " + "pushq" + " " + "%rbx" + "\n"
    out = out + "    " + "pushq" + " " + "%rcx" + "\n"
    out = out + "    " + "pushq" + " " + "%r11" + "\n"
    out = out + "    " + "movq" + " " + "%rdi, %rbx" + "\n"
    out = out + "    " + "movq" + " " + "%rsi, %r10" + "\n"
    out = out + "    " + "movq" + " " + "$1, %rax" + "\n"
    out = out + "    " + "movq" + " " + "$1, %rdi" + "\n"
    out = out + "    " + "movq" + " " + "%rbx, %rsi" + "\n"
    out = out + "    " + "movq" + " " + "%r10, %rdx" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + "    " + "popq" + " " + "%r11" + "\n"
    out = out + "    " + "popq" + " " + "%rcx" + "\n"
    out = out + "    " + "popq" + " " + "%rbx" + "\n"
    out = out + "    " + "leave" + " " + "" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + true_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["true_text"]) + "\"" + "\n"
    out = out + false_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["false_text"]) + "\"" + "\n"
    return out


def emit_linux_x86_64_loop_break_continue_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    loop_label = next_symbol(state, "loop")
    after_loop_label = next_symbol(state, "after_loop")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; linux x86_64 loop/break/continue branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
