    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "binding_kind")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "visibility")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "visibility_origin")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "visibility_kind")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "type")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "type_origin")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "type_kind")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "section_index")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "section_index_origin")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "section_index_kind")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "name_offset")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "name_offset_origin")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "name_offset_kind")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "size")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "size_origin")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "size_kind")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "value")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "value_origin")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "value_kind")
    object_writer_probe_defaults_request["symbol_entry_suffixes"] = method_append(object_writer_probe_defaults_request["symbol_entry_suffixes"], "table_offset")
    object_writer_probe_defaults_result = {"applied_key_count": 0}
    object_writer_probe_defaults_slot = 0
    while object_writer_probe_defaults_slot < object_writer_probe_defaults_request["section_header_slots"]:
        object_writer_probe_defaults_suffix_idx = 0
        while object_writer_probe_defaults_suffix_idx < len(object_writer_probe_defaults_request["section_header_suffixes"]):
            object_writer_probe_defaults_suffix = object_writer_probe_defaults_request["section_header_suffixes"][object_writer_probe_defaults_suffix_idx]
            object_writer_probe_defaults_key = "object_section_header_" + str(object_writer_probe_defaults_slot) + "_" + object_writer_probe_defaults_suffix
            object_writer_probe_metadata_map[object_writer_probe_defaults_key] = object_writer_probe_defaults_request["default_value"]
            object_writer_probe_defaults_result["applied_key_count"] = object_writer_probe_defaults_result["applied_key_count"] + 1
            object_writer_probe_defaults_suffix_idx = object_writer_probe_defaults_suffix_idx + 1
        object_writer_probe_defaults_slot = object_writer_probe_defaults_slot + 1
    object_writer_probe_defaults_slot = 0
    while object_writer_probe_defaults_slot < object_writer_probe_defaults_request["relocation_entry_slots"]:
        object_writer_probe_defaults_suffix_idx = 0
        while object_writer_probe_defaults_suffix_idx < len(object_writer_probe_defaults_request["relocation_entry_suffixes"]):
            object_writer_probe_defaults_suffix = object_writer_probe_defaults_request["relocation_entry_suffixes"][object_writer_probe_defaults_suffix_idx]
            object_writer_probe_defaults_key = "object_relocation_entry_" + str(object_writer_probe_defaults_slot) + "_" + object_writer_probe_defaults_suffix
            object_writer_probe_metadata_map[object_writer_probe_defaults_key] = object_writer_probe_defaults_request["default_value"]
            object_writer_probe_defaults_result["applied_key_count"] = object_writer_probe_defaults_result["applied_key_count"] + 1
            object_writer_probe_defaults_suffix_idx = object_writer_probe_defaults_suffix_idx + 1
        object_writer_probe_defaults_slot = object_writer_probe_defaults_slot + 1
    object_writer_probe_defaults_slot = 0
    while object_writer_probe_defaults_slot < object_writer_probe_defaults_request["symbol_entry_slots"]:
        object_writer_probe_defaults_suffix_idx = 0
        while object_writer_probe_defaults_suffix_idx < len(object_writer_probe_defaults_request["symbol_entry_suffixes"]):
            object_writer_probe_defaults_suffix = object_writer_probe_defaults_request["symbol_entry_suffixes"][object_writer_probe_defaults_suffix_idx]
            object_writer_probe_defaults_key = "object_symbol_entry_" + str(object_writer_probe_defaults_slot) + "_" + object_writer_probe_defaults_suffix
            object_writer_probe_metadata_map[object_writer_probe_defaults_key] = object_writer_probe_defaults_request["default_value"]
            object_writer_probe_defaults_result["applied_key_count"] = object_writer_probe_defaults_result["applied_key_count"] + 1
            object_writer_probe_defaults_suffix_idx = object_writer_probe_defaults_suffix_idx + 1
        object_writer_probe_defaults_slot = object_writer_probe_defaults_slot + 1
    object_writer_probe_defaults_result["expected_key_count"] = (object_writer_probe_defaults_request["section_header_slots"] * len(object_writer_probe_defaults_request["section_header_suffixes"])) + (object_writer_probe_defaults_request["relocation_entry_slots"] * len(object_writer_probe_defaults_request["relocation_entry_suffixes"])) + (object_writer_probe_defaults_request["symbol_entry_slots"] * len(object_writer_probe_defaults_request["symbol_entry_suffixes"]))
    if object_writer_probe_defaults_result["applied_key_count"] != object_writer_probe_defaults_result["expected_key_count"]:
        fail("internal: object-writer probe metadata default-map key coverage mismatch")
    # Backend/object-writer probe ownership: resolve env request once, enforce once.
    object_writer_probe_request = {}
    object_writer_probe_request["probe_metadata"] = parse_truthy_env("TYRION_NATIVE_OBJECT_WRITER_PROBE_METADATA")
    object_writer_probe_request["activate"] = parse_truthy_env("TYRION_NATIVE_OBJECT_WRITER_ACTIVATE")
    object_writer_probe_request["candidate_name"] = ""
    object_writer_probe_request["candidate_required"] = object_writer_probe_request["probe_metadata"]
    if object_writer_probe_request["candidate_required"] != True:
        object_writer_probe_request["candidate_required"] = object_writer_probe_request["activate"]
    if object_writer_probe_request["candidate_required"]:
        object_writer_probe_request["candidate_name"] = trim_spaces(getenv_text("TYRION_NATIVE_OBJECT_WRITER"))
        if object_writer_probe_request["candidate_name"] == "":
            if object_writer_probe_request["activate"]:
                if target_family == "linux":
                    object_writer_probe_request["candidate_name"] = "elf-v1"
                elif target_family == "darwin":
                    object_writer_probe_request["candidate_name"] = "macho-v1"
        if object_writer_probe_request["candidate_name"] == "":
            fail("TYRION_NATIVE_OBJECT_WRITER_PROBE_METADATA=1 or TYRION_NATIVE_OBJECT_WRITER_ACTIVATE=1 requires TYRION_NATIVE_OBJECT_WRITER=<candidate>")
    object_writer_probe_result = {}
    object_writer_probe_result["probe_metadata"] = object_writer_probe_request["probe_metadata"]
    object_writer_probe_result["activate"] = object_writer_probe_request["activate"]
    object_writer_probe_result["candidate_name"] = object_writer_probe_request["candidate_name"]
    object_writer_probe_result["active_writer"] = backend_strategy_result["link_object_writer"]
    if object_writer_probe_result["activate"]:
        object_writer_probe_result["probe_metadata"] = True
    if object_writer_probe_result["activate"]:
        if object_writer_probe_result["candidate_name"] != "elf-v1":
            if object_writer_probe_result["candidate_name"] != "macho-v1":
                fail("TYRION_NATIVE_OBJECT_WRITER_ACTIVATE=1 requires TYRION_NATIVE_OBJECT_WRITER=elf-v1 or macho-v1")
        object_writer_probe_result["active_writer"] = "elf-v1"
        if object_writer_probe_result["candidate_name"] == "macho-v1":
            object_writer_probe_result["active_writer"] = "macho-v1"
    # First-class strict stage candidate policy:
    # stage compiler builds must publish a real target-family object-writer
    # candidate path without requiring probe-activation env toggles.
    stage_writer_request = {}
    # Keep Linux strict-stage behavior stable; only enforce first-class object-writer
    # candidate selection for Darwin stage compilers.
    stage_writer_request["first_class_stage_candidate"] = False
    if build_target_kind == "stage-compiler":
        if target_family == "darwin":
            stage_writer_request["first_class_stage_candidate"] = True
    stage_writer_request["required_candidate_name"] = ""
    if stage_writer_request["first_class_stage_candidate"]:
        stage_writer_request["required_candidate_name"] = "macho-v1"
    if stage_writer_request["required_candidate_name"] != "":
        if object_writer_probe_result["candidate_name"] == "":
            object_writer_probe_result["candidate_name"] = stage_writer_request["required_candidate_name"]
        if object_writer_probe_result["candidate_name"] != stage_writer_request["required_candidate_name"]:
            fail(target_family + " strict stage compiler builds require TYRION_NATIVE_OBJECT_WRITER=" + stage_writer_request["required_candidate_name"] + " when object-writer candidate is explicitly selected")
        object_writer_probe_result["probe_metadata"] = True
        object_writer_probe_result["active_writer"] = stage_writer_request["required_candidate_name"]
    backend_strategy_result["link_object_writer"] = object_writer_probe_result["active_writer"]
    native_mode_is_auto = native_mode == "auto"
    if native_mode_is_auto == False:
        fail("unsupported --native-mode: " + native_mode + " (expected auto)")
    # Backend/stage fail-closed ownership: derive strict stage gate from one request/result pair.
    stage_fail_closed_request = {}
    stage_fail_closed_request["requested"] = parse_stage_fail_closed_env()
    stage_fail_closed_request["is_compiler_source"] = is_stage_compiler_source_path(input_path)
    stage_fail_closed_result = {}
    stage_fail_closed_result["enabled"] = False
    if stage_fail_closed_request["requested"]:
        if stage_fail_closed_request["is_compiler_source"]:
            stage_fail_closed_result["enabled"] = True
    stage_fail_closed = stage_fail_closed_result["enabled"]
    artifact_path = output_path + ".tyn"
    # Frontend handoff: source ingestion ownership for downstream middle/backend phases.
    frontend_source_request = {"input_path": input_path}
    emit_compile_progress("selfhost_native_build:read_source:start")
    source = read_text_file(frontend_source_request["input_path"])
    emit_compile_progress("selfhost_native_build:read_source:done")
    stdlib_wrapper_paths = resolve_stdlib_wrapper_paths(stdlib_wrapper_path, ext_static_mode, ext_static_dir)
    stdlib_overlay = apply_stdlib_wrapper_sources(frontend_source_request["input_path"], source, stdlib_wrapper_paths, "tyrionc")
    frontend_source_result = {"input_path": frontend_source_request["input_path"], "source": stdlib_overlay["source"], "stdlib_wrapper_path": stdlib_overlay["wrapper_path"], "stdlib_wrapper_applied": stdlib_overlay["applied"], "stdlib_wrapper_mode": stdlib_overlay["mode"]}
    native_codegen_input_path = temp_native_path(output_path, ".native_codegen_input.ty")
    write_text_file(native_codegen_input_path, frontend_source_result["source"])
    emit_compile_progress("selfhost_native_build:feature_scan:start")
    # Middle-end handoff: compile-time feature-scan request/result ownership.
    middle_feature_scan_request = {"input_path": frontend_source_result["input_path"], "output_path": output_path, "source": frontend_source_result["source"]}
    feature_scan_report_path_raw = trim_spaces(getenv_text("TYRION_COMPILE_FEATURE_SCAN_REPORT"))
    feature_scan_report_auto = parse_truthy_env("TYRION_COMPILE_FEATURE_SCAN_REPORT_AUTO")
    # Strict scan report path policy is fail-closed for empty/None inputs.
    feature_scan_report_path = ""
    feature_scan_report_path_raw_present = feature_scan_report_path_raw != ""
    feature_scan_report_path_raw_none = feature_scan_report_path_raw == "None"
    feature_scan_report_path_rejected = feature_scan_report_path_raw_present != True
    if feature_scan_report_path_rejected != True:
        feature_scan_report_path_rejected = feature_scan_report_path_raw_none
    if feature_scan_report_path_rejected == False:
        feature_scan_report_path = feature_scan_report_path_raw
    feature_scan_report_path_missing = feature_scan_report_path == ""
    if feature_scan_report_path_missing:
        if feature_scan_report_auto == True:
            feature_scan_report_path = middle_feature_scan_request["output_path"] + ".feature_scan.env"
    feature_scan_hooks = []
    feature_scan_called = []
    if build_target_kind == "stage-compiler":
        feature_scan_hooks = []
        feature_scan_called = []
    else:
        feature_scan_hooks = detect_runtime_hook_labels(middle_feature_scan_request["source"])
        feature_scan_called = collect_native_helper_call_names(middle_feature_scan_request["source"])
    feature_scan_allowed = native_helper_symbol_names()
    feature_scan_unknown_helpers = []
    feature_scan_called_count = len(feature_scan_called)
    feature_scan_idx = 0
    while feature_scan_idx < feature_scan_called_count:
        feature_scan_helper = feature_scan_called[feature_scan_idx]
        feature_scan_helper_supported = contains(feature_scan_allowed, feature_scan_helper)
        if feature_scan_helper_supported != True:
            feature_scan_unknown_helpers = method_append(feature_scan_unknown_helpers, feature_scan_helper)
        feature_scan_idx = feature_scan_idx + 1
    feature_scan_hook_count = len(feature_scan_hooks)
    feature_scan_unknown_count = len(feature_scan_unknown_helpers)
    feature_scan_has_unknown_family = feature_scan_unknown_count > 0
    feature_scan_unknown_family_name = "native-helper/unknown-symbol"
    feature_scan_primary_reason = "direct-supported-program"
    feature_scan_primary_family = "none"
    feature_scan_primary_symbol = "-"
    feature_scan_runtime_dynamic_family = "none"
    feature_scan_has_runtime_hooks = feature_scan_hook_count > 0
    if feature_scan_has_runtime_hooks:
        feature_scan_runtime_dynamic_family = "runtime/hooks"
    feature_scan_unknown_primary_symbol = "<module>"
    feature_scan_unknown_family_summary = ""
    feature_scan_direct_fastpath_ready = True
    feature_scan_unsupported_family_count = 0
    feature_scan_unsupported_family_unique_count = 0
    if feature_scan_has_unknown_family:
        feature_scan_unknown_primary_symbol = feature_scan_unknown_helpers[0]
        feature_scan_unknown_family_summary = feature_scan_unknown_family_name + ":1"
        feature_scan_primary_reason = "direct-unsupported-program"
        feature_scan_primary_family = feature_scan_unknown_family_name
        feature_scan_primary_symbol = feature_scan_unknown_primary_symbol
        feature_scan_direct_fastpath_ready = False
        feature_scan_unsupported_family_count = 1
        feature_scan_unsupported_family_unique_count = 1
    feature_scan_observed_nodes = str(len(middle_feature_scan_request["source"]))
    feature_scan_hook_count_text = str(feature_scan_hook_count)
    feature_scan_called_count_text = str(feature_scan_called_count)
    feature_scan_unknown_count_text = str(feature_scan_unknown_count)
    feature_scan_unsupported_family_count_text = str(feature_scan_unsupported_family_count)
    feature_scan_unsupported_family_unique_count_text = str(feature_scan_unsupported_family_unique_count)
    feature_scan_fastpath_ready_text = "0"
    if feature_scan_direct_fastpath_ready:
        feature_scan_fastpath_ready_text = "1"
    middle_feature_scan_result = {"primary_family": feature_scan_primary_family, "primary_symbol": feature_scan_primary_symbol, "has_unknown_family": feature_scan_has_unknown_family, "report_path": feature_scan_report_path}
    if middle_feature_scan_result["report_path"] != "":
        feature_scan_lines = []
        feature_scan_line_scan_version = "scan_version=selfhost-compile-feature-scan-v1"
        feature_scan_line_input = "input=" + middle_feature_scan_request["input_path"]
        feature_scan_line_guard_limit = "guard_limit=none"
        feature_scan_line_observed_nodes = "observed_nodes=" + feature_scan_observed_nodes
        feature_scan_line_observed_nodes_kind = "observed_nodes_kind=source-bytes"
        feature_scan_line_observed_nodes_cmp = "observed_nodes_cmp=ok"
        feature_scan_line_complexity_exceeded = "complexity_exceeded=0"
        feature_scan_line_runtime_dynamic_family = "runtime_dynamic_family=" + feature_scan_runtime_dynamic_family
