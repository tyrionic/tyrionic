    out = out + "    " + "mov" + " " + "x1, x19" + "\n"
    out = out + "    " + "mov" + " " + "x2, x20" + "\n"
    out = out + "    " + "svc" + " " + "#0" + "\n"
    out = out + "    " + "ldp" + " " + "x19, x20, [sp], #16" + "\n"
    out = out + "    " + "ldp" + " " + "x29, x30, [sp], #16" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + true_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["true_text"]) + "\"" + "\n"
    out = out + false_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["false_text"]) + "\"" + "\n"
    return out


def emit_linux_aarch64_for_range_if_else_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    loop_label = next_symbol(state, "loop")
    then_label = next_symbol(state, "then")
    else_label = next_symbol(state, "else")
    after_if_label = next_symbol(state, "after_if")
    after_loop_label = next_symbol(state, "after_loop")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
