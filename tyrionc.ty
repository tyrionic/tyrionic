    # Backend/object-writer default metadata ownership: initialize deterministic
    # probe-map defaults by grouped key families instead of one-off staging.
    object_writer_probe_defaults_request = {}
    object_writer_probe_defaults_request["default_value"] = "-"
    object_writer_probe_defaults_request["section_header_slots"] = 8
    object_writer_probe_defaults_request["section_header_suffixes"] = []
