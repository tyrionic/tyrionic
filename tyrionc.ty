    post_link_policy_request["fallback_location_marker"] = "native-link-fallback-location="
    post_link_policy_request["resolved_ext_static_mode_marker"] = "native-static-ext-mode="
    post_link_policy_request["resolved_ext_static_count_marker"] = "native-static-ext-count="
    post_link_policy_result = {}
    post_link_policy_result["resolved_link_mode"] = extract_between_or_empty(post_link_request["artifact_text"], post_link_policy_request["resolved_link_mode_marker"], "\n")
    post_link_policy_result["resolved_exec_mode"] = extract_between_or_empty(post_link_request["artifact_text"], post_link_policy_request["resolved_exec_mode_marker"], "\n")
    post_link_policy_result["fallback_reason"] = extract_between_or_empty(post_link_request["artifact_text"], post_link_policy_request["fallback_reason_marker"], "\n")
    post_link_policy_result["fallback_family"] = extract_between_or_empty(post_link_request["artifact_text"], post_link_policy_request["fallback_family_marker"], "\n")
    post_link_policy_result["fallback_symbol"] = extract_between_or_empty(post_link_request["artifact_text"], post_link_policy_request["fallback_symbol_marker"], "\n")
    post_link_policy_result["fallback_location"] = extract_between_or_empty(post_link_request["artifact_text"], post_link_policy_request["fallback_location_marker"], "\n")
    post_link_policy_result["resolved_ext_static_mode"] = extract_between_or_empty(post_link_request["artifact_text"], post_link_policy_request["resolved_ext_static_mode_marker"], "\n")
    post_link_policy_result["resolved_ext_static_count"] = extract_between_or_empty(post_link_request["artifact_text"], post_link_policy_request["resolved_ext_static_count_marker"], "\n")
    if post_link_policy_result["resolved_ext_static_mode"] == "required":
        if post_link_policy_result["resolved_ext_static_count"] == "":
            fail("stage fail-closed build rejected (direct-unsupported-program; family=native-link/direct-emitter-gap/static-extension-lowering-missing; symbol=__tyrion_native_host_call; location=-; next-area=runtime-helper)")
        if post_link_policy_result["resolved_ext_static_count"] == "0":
            fail("stage fail-closed build rejected (direct-unsupported-program; family=native-link/direct-emitter-gap/static-extension-lowering-missing; symbol=__tyrion_native_host_call; location=-; next-area=runtime-helper)")
    post_link_resolution = {}
    post_link_resolution["resolved_direct_native"] = post_link_policy_result["resolved_link_mode"] == "direct"
    post_link_resolution["resolved_native_exec_mode"] = post_link_policy_result["resolved_exec_mode"] == "user-program-native"
    post_link_policy_result["native_mode_rejected"] = post_link_resolution["resolved_direct_native"] != True
    if post_link_policy_result["native_mode_rejected"] == False:
        post_link_policy_result["native_mode_rejected"] = post_link_resolution["resolved_native_exec_mode"] != True
    post_link_rejection = {}
    post_link_rejection["active"] = post_link_policy_result["native_mode_rejected"]
    post_link_rejection["prefix"] = "auto native-mode rejected launcher fallback ("
    if post_link_request["stage_fail_closed"]:
        post_link_rejection["prefix"] = "stage fail-closed build rejected ("
    if post_link_rejection["active"]:
        post_link_rejection["fallback_location_state"] = normalize_native_link_fallback_location(post_link_policy_result["fallback_symbol"], post_link_policy_result["fallback_location"])
        post_link_rejection["rejection_policy"] = normalize_native_link_fallback_policy(post_link_policy_result["fallback_reason"], post_link_policy_result["fallback_family"], post_link_request["stage_fail_closed"])
        post_link_rejection["reason"] = post_link_rejection["rejection_policy"]["reason"]
        post_link_rejection["family"] = post_link_rejection["rejection_policy"]["family"]
        post_link_rejection["symbol"] = post_link_rejection["fallback_location_state"]["symbol"]
        post_link_rejection["location"] = post_link_rejection["fallback_location_state"]["location"]
        post_link_rejection["next_area"] = stage_next_impl_area(post_link_rejection["family"])
        post_link_rejection["payload"] = post_link_rejection["reason"] + "; family=" + post_link_rejection["family"] + "; symbol=" + post_link_rejection["symbol"] + "; location=" + post_link_rejection["location"] + "; next-area=" + post_link_rejection["next_area"]
    # One rejection path emits either stage-fail-closed or auto fallback diagnostics.
    if post_link_rejection["active"]:
        fail(post_link_rejection["prefix"] + post_link_rejection["payload"] + ")")

    # Stage fail-closed marker policy is enforced only for compiler-source stage builds.
    stage_marker_scan_request = {"required": False, "artifact_text": post_link_request["artifact_text"]}
    if post_link_request["stage_fail_closed"]:
        if build_target_kind != "stage-compiler":
            stage_marker_scan_request["required"] = True
    stage_marker_scan_result = {"forbidden_marker": "", "stage_marker_rejected": False}
    if stage_marker_scan_request["required"]:
        stage_marker_scan_result["forbidden_marker"] = contains_forbidden_stage_marker(stage_marker_scan_request["artifact_text"])
        stage_marker_scan_result["stage_marker_rejected"] = stage_marker_scan_result["forbidden_marker"] != ""
    if stage_marker_scan_result["stage_marker_rejected"]:
        fail("stage fail-closed build rejected (reason=stage-marker-present; family=native-link/stage-marker-scan; symbol=<module>; location=-; next-area=runtime-helper; marker=" + stage_marker_scan_result["forbidden_marker"] + ")")

    # Diagnostic payload marker policy:
    # - explicit keep request => marker `diagnostic-payload-kept`
    # - direct payload redaction applied => marker `payload-redaction-v1`
    # - otherwise empty marker (nothing retained/redacted)
    sanitizer_request = {"artifact_path": post_link_request["artifact_path"], "diagnostic_payload_requested": render_policy["include_compiled_payload"]}
    if build_target_kind == "stage-compiler":
        sanitizer_request["diagnostic_payload_requested"] = True
    sanitizer_policy = {}
    sanitizer_policy["keep_marker"] = "diagnostic-payload-kept"
    sanitizer_policy["redacted_marker"] = "payload-redaction-v1"
    sanitizer_result = {"marker": "", "remove_payload": False, "payload_removed": False}
    if sanitizer_request["diagnostic_payload_requested"]:
        sanitizer_result["marker"] = sanitizer_policy["keep_marker"]
    else:
        sanitizer_result["remove_payload"] = True
    if sanitizer_result["remove_payload"]:
        sanitizer_result["payload_removed"] = remove_native_compiled_payload_if_direct(sanitizer_request["artifact_path"])
        if sanitizer_result["payload_removed"]:
            sanitizer_result["marker"] = sanitizer_policy["redacted_marker"]
    sanitizer_result["apply_marker"] = True
    if sanitizer_result["apply_marker"]:
        set_native_direct_sanitizer_marker(sanitizer_request["artifact_path"], sanitizer_result["marker"])


def run_selfhost_artifact(path, forwarded_args):
    artifact = read_text_file(path)
    compiled_payload = extract_between_or_empty(artifact, compiled_payload_section_start(), "\n---TYPED-IR---\n")
    if compiled_payload != "":
        __tyrion_diag_run_payload(compiled_payload, forwarded_args)
        return
    if contains_text(artifact, "tyrionc-native-artifact v1\n") or contains_text(artifact, "tyrion-selfhost-native v0\n"):
        fail("tyrionc artifact missing compiled payload section")
    source = extract_between(artifact, "---SOURCE---\n", "\n---TYPED-IR---\n")
    tmp_path = "/tmp/tyrion_selfhost_artifact_run.ty"
    write_text_file(tmp_path, source)
    __tyrion_run_file_args(tmp_path, forwarded_args)


# -----------------------------------------------------------------------------
# MODULE SECTION: Driver (CLI parsing + mode dispatch + build orchestration)
# -----------------------------------------------------------------------------

# PASS CONTRACT: CLI driver entry
# Input: argv tokens.
# Output: interpretation, artifact run, IR print, or native build path dispatch.
# Failure: deterministic fail diagnostics for invalid flags/missing args/forbidden modes.
def cli_main(args):
    if len(args) == 0:
        usage()
        return
    if len(args) == 1 and is_stage_compiler_source_path(args[0]):
        usage()
        return

    interpret_mode = True
    internal_mode = False
    deterministic = True
    emit_ir_stage = ""
    emit_native_ir = False
    backend = "tyrionc"
    native_target = backend_target_for_host()
    native_link_mode = "static"
    if native_target["os"] == "darwin":
        native_link_mode = "static-like"
    native_mode = "auto"
    ext_static_mode = "auto"
    ext_static_dir = "./extensions"
    stdlib_wrapper_path = ""
    run_embedded_mode = False
    run_path = ""
    artifact_args = []
    input_path = ""
    output_path = ""
    diag_run_artifact = diag_run_artifact_flag()
    diag_run_embedded_native = diag_run_embedded_native_flag()
    diag_run_embedded_stage_native = diag_run_embedded_stage_native_flag()
    legacy_run_artifact = legacy_run_artifact_flag()
    legacy_run_embedded_native = legacy_run_embedded_native_flag()

    i = 0
    while i < len(args):
        current = args[i]
        if run_path != "":
            artifact_args = method_append(artifact_args, current)
            i = i + 1
        else:
            if current == "internal":
                if i != 0:
                    fail("internal subcommand must appear before other arguments")
                internal_mode = True
            else:
                canonical_current = current
                if canonical_current == "-h" or (internal_mode and canonical_current == "help"):
                    canonical_current = "--help"
                if canonical_current == "--help":
                    if internal_mode:
                        usage_internal()
                    else:
                        usage()
                    return
                if internal_mode:
                    canonical_current = normalize_internal_token(canonical_current)
                if starts_with(canonical_current, "--run-"):
                    if canonical_current == legacy_run_embedded_native:
                        canonical_current = diag_run_embedded_native
                    elif canonical_current == legacy_run_artifact:
                        canonical_current = diag_run_artifact
                elif canonical_current == "-V" or canonical_current == "version":
                    canonical_current = "--version"
                elif canonical_current == "--backend=selfhost-native":
                    canonical_current = "--backend=tyrionc"
                elif canonical_current == "-o" or canonical_current == "--output":
                    canonical_current = "--out"
                elif canonical_current == "--emit-ir":
                    canonical_current = "--emit-ir=all"
                elif canonical_current == "target":
                    canonical_current = "--target"
                elif canonical_current == "link":
                    canonical_current = "--link"
                elif canonical_current == "native-mode":
                    canonical_current = "--native-mode"
                elif canonical_current == "ext-static":
                    canonical_current = "--ext-static"
                elif canonical_current == "ext-dir":
                    canonical_current = "--ext-dir"
                elif canonical_current == "with-stdlib":
                    canonical_current = "--with-stdlib"
                option_key = canonical_current
                option_value = ""
                if contains_text(canonical_current, "="):
                    canonical_option_parts = method_split(canonical_current, "=")
                    option_key = canonical_option_parts[0]
                    option_value = canonical_option_parts[1]
                option_is_emit_ir = option_key == "--emit-ir"
                option_is_backend = option_key == "--backend"
                option_is_build = option_key == "--build"
                option_is_input = option_key == "--input"
                option_is_output = option_key == "--out"
                option_is_diag_run_embedded = False
                option_is_diag_run_artifact = False
                if starts_with(option_key, "--diag-"):
                    option_is_diag_run_embedded = option_key == diag_run_embedded_native
                    if option_is_diag_run_embedded != True:
                        option_is_diag_run_embedded = option_key == diag_run_embedded_stage_native
                    option_is_diag_run_artifact = option_key == diag_run_artifact
                option_is_version = canonical_current == "--version"
                option_is_deterministic = canonical_current == "--deterministic"
                option_is_emit_native_ir = canonical_current == "--emit-native-ir"
                option_is_single_file_native = canonical_current == "--single-file-native"
                option_is_rust_aot_backend = canonical_current == "--backend=rust-aot"
                option_is_ext_dir = option_key == "--ext-dir"
                option_is_ext_static = option_key == "--ext-static"
                option_is_with_stdlib = option_key == "--with-stdlib"
                option_value_supported = False
                if option_is_emit_ir:
                    option_value_supported = contains(["typed", "lowered", "all"], option_value)
                elif option_is_backend:
                    option_value_supported = contains(["selfhost", "tyrionc"], option_value)
                known_simple_option = contains(["--version", "--deterministic", "--emit-native-ir", "--single-file-native", "--backend=rust-aot"], canonical_current)
                known_keyed_option = option_value_supported
                if known_keyed_option != True and contains(["--target", "--link", "--native-mode", "--ext-static", "--with-stdlib"], option_key):
                    known_keyed_option = True
                known_non_value_option = known_keyed_option
                if known_non_value_option != True and known_simple_option:
                    known_non_value_option = True
                value_option_kind = ""
                if option_is_diag_run_embedded:
                    value_option_kind = "run_embedded"
                elif option_is_diag_run_artifact:
                    value_option_kind = "run_artifact"
                elif option_is_output:
                    value_option_kind = "output"
                elif option_is_build or option_is_input:
                    value_option_kind = "input"
                elif option_is_ext_dir:
                    value_option_kind = "ext_dir"
                elif option_is_with_stdlib:
                    value_option_kind = "with_stdlib"
                value_option_requires_value = value_option_kind != ""
                value_option_missing_label = "input path"
                if value_option_kind == "run_embedded":
                    value_option_missing_label = "executable path"
                elif value_option_kind == "run_artifact":
                    value_option_missing_label = "artifact path"
                elif value_option_kind == "output":
                    value_option_missing_label = "output path"
                elif value_option_kind == "ext_dir":
                    value_option_missing_label = "extension directory path"
                elif value_option_kind == "with_stdlib":
                    value_option_missing_label = "stdlib wrapper path"
                value_option_forces_build = option_is_build
                if value_option_forces_build != True and value_option_kind == "output":
                    value_option_forces_build = True
                if option_is_version:
                    print("tyrionc0 selfhost-native v0")
                    return
                elif option_is_deterministic:
                    deterministic = True
                elif option_is_emit_ir and option_value_supported:
                    emit_ir_stage = option_value
                elif option_is_emit_native_ir:
                    emit_native_ir = True
                elif option_is_backend and option_value_supported:
                    backend = option_value
                elif option_key == "--target":
                    target_name = option_value
                    native_target = backend_target_from_cli(target_name)
                elif option_key == "--link":
                    native_link_mode = option_value
                elif option_key == "--native-mode":
                    native_mode = option_value
                elif option_key == "--ext-static":
                    ext_static_mode = option_value
                elif option_is_ext_dir and option_value != "":
                    ext_static_dir = option_value
                elif option_is_with_stdlib and option_value != "":
                    stdlib_wrapper_path = option_value
                elif option_is_with_stdlib:
                    i = i + 1
                    if i >= len(args):
                        fail("missing stdlib wrapper path after " + canonical_current)
                    stdlib_wrapper_path = args[i]
                elif option_is_single_file_native:
                    fail("--single-file-native is disabled in fresh strict mode")
                elif option_is_rust_aot_backend:
                    fail("backend rust-aot is disabled in fresh strict mode")
                else:
                    if value_option_requires_value != True and known_non_value_option:
                        _ignored_known_non_value_option = True
                    elif value_option_requires_value:
                        if value_option_forces_build:
                            interpret_mode = False
                        i = i + 1
                        if i >= len(args):
                            fail("missing " + value_option_missing_label + " after " + canonical_current)
                        option_arg = args[i]
                        if value_option_kind == "run_embedded":
                            run_path = option_arg
                            run_embedded_mode = True
                        elif value_option_kind == "run_artifact":
                            run_path = option_arg
                            run_embedded_mode = False
                        elif value_option_kind == "output":
                            output_path = option_arg
                        elif value_option_kind == "input":
                            input_path = option_arg
                        elif value_option_kind == "ext_dir":
                            ext_static_dir = option_arg
                        elif value_option_kind == "with_stdlib":
                            stdlib_wrapper_path = option_arg
                        else:
                            fail("internal: unsupported value option routing for " + canonical_current)
                    else:
                        input_path = canonical_current
            i = i + 1

    if run_path != "":
        if run_embedded_mode != True:
            run_selfhost_artifact(run_path, artifact_args)
            return
        if len(artifact_args) > 0:
            cli_main(artifact_args)
            return
        # Prefer no-payload execution for normal CLI operations so bootstrap-stage
        # compilers remain usable in clean shells.
        # No forwarded args means this is a launcher-style user binary invocation.
        # Run embedded payload by default so no-arg binaries do not recurse into CLI
        # parsing and fail with "Missing input path".
        compiled_payload = __tyrion_extract_native_payload(run_path)
        __tyrion_diag_run_payload(compiled_payload, artifact_args)
        return

    if input_path == "":
        fail("Missing input path")

    if emit_ir_stage != "":
        if normalize_optional_cli_path(stdlib_wrapper_path) != "":
            fail("--with-stdlib currently supports build mode only")
        print(__tyrion_emit_ir(input_path, emit_ir_stage, deterministic))
        return
    if emit_native_ir:
        if normalize_optional_cli_path(stdlib_wrapper_path) != "":
            fail("--with-stdlib currently supports build mode only")
        print(emit_native_codegen_ir(input_path, deterministic, native_target))
        return

    if interpret_mode:
        if normalize_optional_cli_path(stdlib_wrapper_path) != "":
            fail("--with-stdlib currently supports build mode only")
        __tyrion_run_file(input_path)
        return

    if output_path == "":
        fail("Missing --out for build")

    if backend == "selfhost":
        selfhost_build(input_path, output_path, deterministic, stdlib_wrapper_path)
        print("Compiled (selfhost artifact) " + input_path + " -> " + output_path)
    elif backend == "tyrionc":
        selfhost_native_build(input_path, output_path, deterministic, native_target, native_link_mode, native_mode, ext_static_mode, ext_static_dir, stdlib_wrapper_path)
        print("Compiled (tyrionc executable) " + input_path + " -> " + output_path)
    else:
        fail("unknown backend: " + backend)


cli_main(argv())
