    out = out + "    " + "mov" + " " + "x29, sp" + "\n"
    out = out + "    " + "stp" + " " + "x19, x20, [sp, #-16]!" + "\n"
    out = out + "    " + "mov" + " " + "x19, x0" + "\n"
    out = out + "    " + "mov" + " " + "x20, x1" + "\n"
    out = out + "    " + "mov" + " " + "x16, #4" + "\n"
    out = out + "    " + "mov" + " " + "x0, #1" + "\n"
    out = out + "    " + "mov" + " " + "x1, x19" + "\n"
    out = out + "    " + "mov" + " " + "x2, x20" + "\n"
    out = out + "    " + "svc" + " " + "#0x80" + "\n"
    out = out + "    " + "ldp" + " " + "x19, x20, [sp], #16" + "\n"
    out = out + "    " + "ldp" + " " + "x29, x30, [sp], #16" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + true_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["true_text"]) + "\"" + "\n"
    out = out + false_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["false_text"]) + "\"" + "\n"
    return out


def emit_darwin_aarch64_for_range_if_else_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    loop_label = next_symbol(state, "loop")
    then_label = next_symbol(state, "then")
    else_label = next_symbol(state, "else")
    after_if_label = next_symbol(state, "after_if")
    after_loop_label = next_symbol(state, "after_loop")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; darwin aarch64 for-range/if-else branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "x19, #1" + "\n"
    out = out + "    " + "mov" + " " + "x20, #0" + "\n"
    out = out + loop_label + ":\n"
    out = out + "    " + "cmp" + " " + "x19, #6" + "\n"
    out = out + "    " + "b.ge" + " " + after_loop_label + "\n"
    out = out + "    " + "cmp" + " " + "x19, #3" + "\n"
    out = out + "    " + "b.eq" + " " + then_label + "\n"
    out = out + "    " + "b" + " " + else_label + "\n"
    out = out + then_label + ":\n"
    out = out + "    " + "add" + " " + "x20, x20, #10" + "\n"
    out = out + "    " + "b" + " " + after_if_label + "\n"
    out = out + else_label + ":\n"
    out = out + "    " + "add" + " " + "x20, x20, x19" + "\n"
    out = out + after_if_label + ":\n"
    out = out + "    " + "add" + " " + "x19, x19, #1" + "\n"
    out = out + "    " + "b" + " " + loop_label + "\n"
    out = out + after_loop_label + ":\n"
    out = out + "    " + "cmp" + " " + "x20, #22" + "\n"
    out = out + "    " + "b.eq" + " " + true_label + "\n"
    out = out + "    " + "adr" + " " + "x0, " + false_payload_label + "\n"
    out = out + "    " + "mov" + " " + "x1, #" + str(false_payload_len) + "\n"
    out = out + "    " + "bl" + " " + runtime_print_stub_label + "\n"
    out = out + "    " + "b" + " " + done_label + "\n"
    out = out + true_label + ":\n"
    out = out + "    " + "adr" + " " + "x0, " + true_payload_label + "\n"
    out = out + "    " + "mov" + " " + "x1, #" + str(true_payload_len) + "\n"
    out = out + "    " + "bl" + " " + runtime_print_stub_label + "\n"
    out = out + done_label + ":\n"
    out = out + "    " + "mov" + " " + "x16, #1" + "\n"
    out = out + "    " + "mov" + " " + "x0, #0" + "\n"
    out = out + "    " + "svc" + " " + "#0x80" + "\n"
    out = out + runtime_print_stub_label + ":\n"
    out = out + "; runtime-abi print-line(ptr=x0, len=x1) -> x0" + "\n"
    out = out + "; abi-clobber-policy: preserve callee-saved registers used by stub" + "\n"
    out = out + "    " + "stp" + " " + "x29, x30, [sp, #-16]!" + "\n"
    out = out + "    " + "mov" + " " + "x29, sp" + "\n"
    out = out + "    " + "stp" + " " + "x19, x20, [sp, #-16]!" + "\n"
    out = out + "    " + "mov" + " " + "x19, x0" + "\n"
    out = out + "    " + "mov" + " " + "x20, x1" + "\n"
    out = out + "    " + "mov" + " " + "x16, #4" + "\n"
    out = out + "    " + "mov" + " " + "x0, #1" + "\n"
    out = out + "    " + "mov" + " " + "x1, x19" + "\n"
    out = out + "    " + "mov" + " " + "x2, x20" + "\n"
    out = out + "    " + "svc" + " " + "#0x80" + "\n"
    out = out + "    " + "ldp" + " " + "x19, x20, [sp], #16" + "\n"
    out = out + "    " + "ldp" + " " + "x29, x30, [sp], #16" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + true_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["true_text"]) + "\"" + "\n"
    out = out + false_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["false_text"]) + "\"" + "\n"
    return out


def emit_darwin_x86_64_asm(compiled_payload, deterministic, target):
    state = emitter_state(deterministic)
    payload_label = next_symbol(state, "payload")
    payload_len = len(compiled_payload)
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; darwin x86_64 Mach-O section template" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "movq" + " " + "$0x2000004, %rax" + "\n"
    out = out + "    " + "movq" + " " + "$1, %rdi" + "\n"
    out = out + "    " + "leaq" + " " + payload_label + "(%rip), %rsi" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(payload_len) + ", %rdx" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + "    " + "movq" + " " + "$0x2000001, %rax" + "\n"
    out = out + "    " + "xorq" + " " + "%rdi, %rdi" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(compiled_payload) + "\"" + "\n"
    return out


def emit_darwin_aarch64_asm(compiled_payload, deterministic, target):
    state = emitter_state(deterministic)
    payload_label = next_symbol(state, "payload")
    payload_len = len(compiled_payload)
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; darwin aarch64 Mach-O section template" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "x16, #" + asm_encode_immediate(4) + "\n"
    out = out + "    " + "mov" + " " + "x0, #1" + "\n"
    out = out + "    " + "adrp" + " " + "x1, " + payload_label + "@PAGE" + "\n"
    out = out + "    " + "add" + " " + "x1, x1, " + payload_label + "@PAGEOFF" + "\n"
    out = out + "    " + "ldr" + " " + "x2, =" + str(payload_len) + "\n"
    out = out + "    " + "svc" + " " + "#0x80" + "\n"
    out = out + "    " + "mov" + " " + "x16, #" + asm_encode_immediate(1) + "\n"
    out = out + "    " + "mov" + " " + "x0, #0" + "\n"
    out = out + "    " + "svc" + " " + "#0x80" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(compiled_payload) + "\"" + "\n"
    return out


def emit_native_launcher_asm(artifact_path, target):
    runner = native_launcher_runner()
    if target["arch"] == "aarch64":
        out = ""
        out = out + ".global _start" + "\n"
        out = out + ".text" + "\n"
        out = out + "_start" + ":\n"
        out = out + "    " + "adr" + " " + "x9, argv_data" + "\n"
        out = out + "    " + "adr" + " " + "x0, runner_path" + "\n"
        out = out + "    " + "str" + " " + "x0, [x9]" + "\n"
        out = out + "    " + "adr" + " " + "x0, run_artifact_flag" + "\n"
        out = out + "    " + "str" + " " + "x0, [x9, #8]" + "\n"
        out = out + "    " + "adr" + " " + "x0, artifact_path_data" + "\n"
        out = out + "    " + "str" + " " + "x0, [x9, #16]" + "\n"
        out = out + "    " + "mov" + " " + "x4, #1" + "\n"
        out = out + "copy_argv_loop" + ":\n"
        out = out + "    " + "ldr" + " " + "x3, [sp]" + "\n"
        out = out + "    " + "cmp" + " " + "x4, x3" + "\n"
        out = out + "    " + "b.ge" + " " + "copy_argv_done" + "\n"
        out = out + "    " + "add" + " " + "x6, sp, #8" + "\n"
        out = out + "    " + "add" + " " + "x6, x6, x4, lsl #3" + "\n"
        out = out + "    " + "ldr" + " " + "x5, [x6]" + "\n"
        out = out + "    " + "add" + " " + "x7, x9, #16" + "\n"
        out = out + "    " + "add" + " " + "x7, x7, x4, lsl #3" + "\n"
        out = out + "    " + "str" + " " + "x5, [x7]" + "\n"
        out = out + "    " + "add" + " " + "x4, x4, #1" + "\n"
        out = out + "    " + "b" + " " + "copy_argv_loop" + "\n"
        out = out + "copy_argv_done" + ":\n"
        out = out + "    " + "add" + " " + "x7, x9, #16" + "\n"
        out = out + "    " + "add" + " " + "x7, x7, x3, lsl #3" + "\n"
        out = out + "    " + "mov" + " " + "x0, #0" + "\n"
        out = out + "    " + "str" + " " + "x0, [x7]" + "\n"
        out = out + "    " + "adr" + " " + "x0, runner_path" + "\n"
        out = out + "    " + "adr" + " " + "x1, argv_data" + "\n"
        out = out + "    " + "add" + " " + "x2, sp, #16" + "\n"
        out = out + "    " + "add" + " " + "x2, x2, x3, lsl #3" + "\n"
        out = out + "    " + "mov" + " " + "x8, #221" + "\n"
        out = out + "    " + "svc" + " " + "#0" + "\n"
        out = out + "    " + "mov" + " " + "x0, #127" + "\n"
        out = out + "    " + "mov" + " " + "x8, #93" + "\n"
        out = out + "    " + "svc" + " " + "#0" + "\n"
        out = out + ".section .rodata" + "\n"
        out = out + "runner_path" + ":\n"
        out = out + ".asciz \"" + asm_escape_string(runner) + "\"" + "\n"
        out = out + "run_artifact_flag" + ":\n"
        out = out + ".asciz \"" + asm_escape_string(diag_run_artifact_flag()) + "\"" + "\n"
        out = out + "artifact_path_data" + ":\n"
        out = out + ".asciz \"" + asm_escape_string(artifact_path) + "\"" + "\n"
        out = out + ".section .bss" + "\n"
        out = out + ".align 3" + "\n"
        out = out + "argv_data" + ":\n"
        out = out + ".space 4096" + "\n"
        return out
    out = ""
    out = out + ".global _start" + "\n"
    out = out + ".section .text" + "\n"
    out = out + "_start" + ":\n"
    out = out + "    " + "lea" + " " + "argv_data(%rip), %rax" + "\n"
    out = out + "    " + "lea" + " " + "runner_path(%rip), %rdi" + "\n"
    out = out + "    " + "mov" + " " + "%rdi, 0(%rax)" + "\n"
    out = out + "    " + "lea" + " " + "run_artifact_flag(%rip), %rdi" + "\n"
    out = out + "    " + "mov" + " " + "%rdi, 8(%rax)" + "\n"
    out = out + "    " + "lea" + " " + "artifact_path(%rip), %rdi" + "\n"
    out = out + "    " + "mov" + " " + "%rdi, 16(%rax)" + "\n"
    out = out + "    " + "movq" + " " + "$1, %r8" + "\n"
    out = out + "copy_argv_loop" + ":\n"
    out = out + "    " + "mov" + " " + "(%rsp), %rcx" + "\n"
    out = out + "    " + "cmp" + " " + "%rcx, %r8" + "\n"
    out = out + "    " + "jge" + " " + "copy_argv_done" + "\n"
    out = out + "    " + "mov" + " " + "8(%rsp,%r8,8), %r9" + "\n"
    out = out + "    " + "mov" + " " + "%r9, 16(%rax,%r8,8)" + "\n"
    out = out + "    " + "inc" + " " + "%r8" + "\n"
    out = out + "    " + "jmp" + " " + "copy_argv_loop" + "\n"
    out = out + "copy_argv_done" + ":\n"
    out = out + "    " + "movq" + " " + "$0, 16(%rax,%rcx,8)" + "\n"
    out = out + "    " + "lea" + " " + "runner_path(%rip), %rdi" + "\n"
    out = out + "    " + "lea" + " " + "argv_data(%rip), %rsi" + "\n"
    out = out + "    " + "lea" + " " + "16(%rsp,%rcx,8), %rdx" + "\n"
    out = out + "    " + "movq" + " " + "$59, %rax" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + "    " + "movq" + " " + "$127, %rdi" + "\n"
    out = out + "    " + "movq" + " " + "$60, %rax" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + ".section .rodata" + "\n"
    out = out + "runner_path" + ":\n"
    out = out + ".asciz \"" + asm_escape_string(runner) + "\"" + "\n"
    out = out + "run_artifact_flag" + ":\n"
    out = out + ".asciz \"" + asm_escape_string(diag_run_artifact_flag()) + "\"" + "\n"
    out = out + "artifact_path" + ":\n"
    out = out + ".asciz \"" + asm_escape_string(artifact_path) + "\"" + "\n"
    out = out + ".section .bss" + "\n"
    out = out + ".align 8" + "\n"
    out = out + "argv_data" + ":\n"
    out = out + ".zero 4096" + "\n"
    return out


