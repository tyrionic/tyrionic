module selfhost.tyrionc
from compiler.contracts.compiler_policy import canonical_compiler_builtin_symbols

# tyrionc.ty
# Checkpoint scaffold for self-host bootstrap work.
# This file intentionally implements a compact compiler pipeline:
# lexer -> parser -> AST -> semantic check -> typed IR -> lowered IR.


def fail(msg):
    raise msg


def assert_true(cond, msg):
    if cond == False:
        fail(msg)


def contains(items, needle):
    for item in items:
        if item == needle:
            return True
    return False


def contains_text(haystack, needle):
    parts = method_split(haystack, needle)
    return len(parts) > 1


def is_builtin_symbol(name):
    return contains(canonical_compiler_builtin_symbols(), name)


def join_csv(parts):
    out = ""
    first = True
    for part in parts:
        if first == False:
            out = out + ", "
        out = out + part
        first = False
    return out


def repeat_char(ch, count):
    out = ""
    idx = 0
    while idx < count:
        out = out + ch
        idx = idx + 1
    return out


def is_whitespace(ch):
    if ch == " ":
        return True
    if ch == "\n":
        return True
    if ch == "\t":
        return True
    return False


def node_program(module_decl, imports, exports, functions):
    return {"kind": "Program", "module_decl": module_decl, "imports": imports, "exports": exports, "functions": functions}


def node_function(name, params, body):
    return {"kind": "Function", "name": name, "params": params, "body": body}


def node_let(name, expr):
    return {"kind": "Let", "name": name, "expr": expr}


def node_assign(name, expr):
    return {"kind": "Assign", "name": name, "expr": expr}


def node_return(expr):
    return {"kind": "Return", "expr": expr}


def node_expr_stmt(expr):
    return {"kind": "ExprStmt", "expr": expr}


def node_if(cond, then_body, else_body):
    return {"kind": "If", "cond": cond, "then_body": then_body, "else_body": else_body}


def node_while(cond, body):
    return {"kind": "While", "cond": cond, "body": body}


def node_for(name, iter_expr, body):
    return {"kind": "For", "name": name, "iter": iter_expr, "body": body}


def node_var(name):
    return {"kind": "Var", "name": name}


def node_int(value):
    return {"kind": "Int", "value": value}


def node_float(value):
    return {"kind": "Float", "value": value}


def node_str(value):
    return {"kind": "String", "value": value}


def node_bool(value):
    return {"kind": "Bool", "value": value}


def node_unary(op, expr):
    return {"kind": "Unary", "op": op, "expr": expr}


def node_binary(op, left, right):
    return {"kind": "Binary", "op": op, "left": left, "right": right}


def node_call(callee, args):
    return {"kind": "Call", "callee": callee, "args": args}


def node_list(items):
    return {"kind": "List", "items": items}


def node_dict(items):
    return {"kind": "Dict", "items": items}


def node_index(value, index):
    return {"kind": "Index", "value": value, "index": index}


def token(kind, text):
    return {"kind": kind, "text": text}


def is_alpha(ch):
    if ch >= "a":
        if ch <= "z":
            return True
    if ch >= "A":
        if ch <= "Z":
            return True
    if ch == "_":
        return True
    return False


def is_digit(ch):
    if ch >= "0":
        if ch <= "9":
            return True
    return False


def is_alnum(ch):
    if is_alpha(ch):
        return True
    return is_digit(ch)


# -----------------------------------------------------------------------------
# MODULE SECTION: Frontend (lexing + parsing + AST construction)
# -----------------------------------------------------------------------------

# PASS CONTRACT: Frontend lexing
# Input: full source text.
# Output: token list consumable by parse_program(); no semantic assumptions.
# Failure: hard fail only for malformed literals (e.g. unterminated string).
def lex(source):
    tokens = []
    i = 0
    n = len(source)
    while i < n:
        ch = source[i]
        if is_whitespace(ch):
            i = i + 1
        elif ch == "#":
            scanning_comment = True
            while scanning_comment:
                if i >= n:
                    scanning_comment = False
                elif source[i] == "\n":
                    scanning_comment = False
                else:
                    i = i + 1
        elif is_alpha(ch):
            start = i
            i = i + 1
            scanning_ident = True
            while scanning_ident:
                if i >= n:
                    scanning_ident = False
                elif is_alnum(source[i]):
                    i = i + 1
                else:
                    scanning_ident = False
            word = source[start:i]
            if word == "fn":
                tokens = method_append(tokens, token("KW_FN", word))
            elif word == "let":
                tokens = method_append(tokens, token("KW_LET", word))
            elif word == "return":
                tokens = method_append(tokens, token("KW_RETURN", word))
            elif word == "if":
                tokens = method_append(tokens, token("KW_IF", word))
            elif word == "else":
                tokens = method_append(tokens, token("KW_ELSE", word))
            elif word == "while":
                tokens = method_append(tokens, token("KW_WHILE", word))
            elif word == "for":
                tokens = method_append(tokens, token("KW_FOR", word))
            elif word == "in":
                tokens = method_append(tokens, token("KW_IN", word))
            elif word == "module":
                tokens = method_append(tokens, token("KW_MODULE", word))
            elif word == "import":
                tokens = method_append(tokens, token("KW_IMPORT", word))
            elif word == "from":
                tokens = method_append(tokens, token("KW_FROM", word))
            elif word == "export":
                tokens = method_append(tokens, token("KW_EXPORT", word))
            elif word == "as":
                tokens = method_append(tokens, token("KW_AS", word))
            elif word == "and":
                tokens = method_append(tokens, token("KW_AND", word))
            elif word == "or":
                tokens = method_append(tokens, token("KW_OR", word))
            elif word == "not":
                tokens = method_append(tokens, token("KW_NOT", word))
            elif word == "true":
                tokens = method_append(tokens, token("BOOL", word))
            elif word == "false":
                tokens = method_append(tokens, token("BOOL", word))
            else:
                tokens = method_append(tokens, token("IDENT", word))
        elif is_digit(ch):
            start = i
            saw_dot = False
            i = i + 1
            scanning_number = True
            while scanning_number:
                if i >= n:
                    scanning_number = False
                else:
                    c2 = source[i]
                    if is_digit(c2):
                        i = i + 1
                    elif c2 == ".":
                        if saw_dot == False:
                            saw_dot = True
                            i = i + 1
                        else:
                            scanning_number = False
                    else:
                        scanning_number = False
            tokens = method_append(tokens, token("NUMBER", source[start:i]))
        elif ch == "\"":
            i = i + 1
            value = ""
            scanning_string = True
            while scanning_string:
                if i >= n:
                    scanning_string = False
                elif source[i] == "\"":
                    scanning_string = False
                else:
                    value = value + source[i]
                    i = i + 1
            if i >= n:
                fail("unterminated string")
            i = i + 1
            tokens = method_append(tokens, token("STRING", value))
        elif ch == "(":
            tokens = method_append(tokens, token("LPAREN", ch))
            i = i + 1
        elif ch == ")":
            tokens = method_append(tokens, token("RPAREN", ch))
            i = i + 1
        elif ch == "{":
            tokens = method_append(tokens, token("LBRACE", ch))
            i = i + 1
        elif ch == "}":
            tokens = method_append(tokens, token("RBRACE", ch))
            i = i + 1
        elif ch == ",":
            tokens = method_append(tokens, token("COMMA", ch))
            i = i + 1
        elif ch == ".":
            tokens = method_append(tokens, token("DOT", ch))
            i = i + 1
        elif ch == ":":
            tokens = method_append(tokens, token("COLON", ch))
            i = i + 1
        elif ch == "[":
            tokens = method_append(tokens, token("LBRACKET", ch))
            i = i + 1
        elif ch == "]":
            tokens = method_append(tokens, token("RBRACKET", ch))
            i = i + 1
        elif ch == ";":
            tokens = method_append(tokens, token("SEMI", ch))
            i = i + 1
        elif ch == "+":
            tokens = method_append(tokens, token("PLUS", ch))
            i = i + 1
        elif ch == "-":
            tokens = method_append(tokens, token("MINUS", ch))
            i = i + 1
        elif ch == "*":
            tokens = method_append(tokens, token("STAR", ch))
            i = i + 1
        elif ch == "/":
            tokens = method_append(tokens, token("SLASH", ch))
            i = i + 1
        elif ch == "=":
            if i + 1 < n:
                if source[i + 1] == "=":
                    tokens = method_append(tokens, token("EQEQ", "=="))
                    i = i + 2
                else:
                    tokens = method_append(tokens, token("ASSIGN", ch))
                    i = i + 1
            else:
                tokens = method_append(tokens, token("ASSIGN", ch))
                i = i + 1
        elif ch == "!":
            if i + 1 < n:
                if source[i + 1] == "=":
                    tokens = method_append(tokens, token("BANGEQ", "!="))
                    i = i + 2
                else:
                    fail("unknown character: " + ch)
            else:
                fail("unknown character: " + ch)
        elif ch == "<":
            if i + 1 < n:
                if source[i + 1] == "=":
                    tokens = method_append(tokens, token("LTE", "<="))
                    i = i + 2
                else:
                    tokens = method_append(tokens, token("LT", "<"))
                    i = i + 1
            else:
                tokens = method_append(tokens, token("LT", "<"))
                i = i + 1
        elif ch == ">":
            if i + 1 < n:
                if source[i + 1] == "=":
                    tokens = method_append(tokens, token("GTE", ">="))
                    i = i + 2
                else:
                    tokens = method_append(tokens, token("GT", ">"))
                    i = i + 1
            else:
                tokens = method_append(tokens, token("GT", ">"))
                i = i + 1
        else:
            fail("unknown character: " + ch)

    tokens = method_append(tokens, token("EOF", ""))
    return tokens


def parser_state(tokens):
    return {"tokens": tokens, "idx": 0}


def peek(state):
    return state["tokens"][state["idx"]]


def lookahead(state, delta):
    return state["tokens"][state["idx"] + delta]


def at_end(state):
    return peek(state)["kind"] == "EOF"


def advance(state):
    t = peek(state)
    state["idx"] = state["idx"] + 1
    return t


def expect(state, kind):
    t = peek(state)
    if t["kind"] != kind:
        fail("expected " + kind + " got " + t["kind"])
    return advance(state)


def match(state, kind):
    if peek(state)["kind"] == kind:
        advance(state)
        return True
    return False


# PASS CONTRACT: Frontend parsing
# Input: token stream from lex().
# Output: Program AST root ({kind:"Program"}) for typed_ir().
# Failure: fail-closed syntax diagnostics via expect()/fail().
def parse_program(tokens):
    st = parser_state(tokens)
    module_decl = None
    imports = []
    exports = []
    parsing_prelude = True
    while parsing_prelude:
        prelude_kind = peek(st)["kind"]
        if prelude_kind == "KW_MODULE":
            advance(st)
            if module_decl != None:
                fail("duplicate module declaration")
            module_path = []
            module_path = method_append(module_path, expect(st, "IDENT")["text"])
            while match(st, "DOT"):
                module_path = method_append(module_path, expect(st, "IDENT")["text"])
            module_decl = {"kind": "ModuleDecl", "path": module_path}
        elif prelude_kind == "KW_IMPORT":
            advance(st)
            keep_parsing_import = True
            while keep_parsing_import:
                import_path = []
                import_path = method_append(import_path, expect(st, "IDENT")["text"])
                while match(st, "DOT"):
                    import_path = method_append(import_path, expect(st, "IDENT")["text"])
                import_alias = None
                if match(st, "KW_AS"):
                    import_alias = expect(st, "IDENT")["text"]
                imports = method_append(imports, {"kind": "ImportModule", "path": import_path, "alias": import_alias})
                keep_parsing_import = match(st, "COMMA")
        elif prelude_kind == "KW_FROM":
            advance(st)
            from_module_path = []
            from_module_path = method_append(from_module_path, expect(st, "IDENT")["text"])
            while match(st, "DOT"):
                from_module_path = method_append(from_module_path, expect(st, "IDENT")["text"])
            expect(st, "KW_IMPORT")
            from_items = []
            if match(st, "STAR"):
                from_items = method_append(from_items, {"name": "*", "alias": None})
            else:
                keep_parsing_from_items = True
                while keep_parsing_from_items:
                    item_name = expect(st, "IDENT")["text"]
                    item_alias = None
                    if match(st, "KW_AS"):
                        item_alias = expect(st, "IDENT")["text"]
                    from_items = method_append(from_items, {"name": item_name, "alias": item_alias})
                    keep_parsing_from_items = match(st, "COMMA")
            imports = method_append(imports, {"kind": "ImportFrom", "module_path": from_module_path, "items": from_items})
        elif prelude_kind == "KW_EXPORT":
            advance(st)
            export_names = []
            export_names = method_append(export_names, expect(st, "IDENT")["text"])
            while match(st, "COMMA"):
                export_names = method_append(export_names, expect(st, "IDENT")["text"])
            exports = method_append(exports, {"kind": "ExportDecl", "names": export_names})
        else:
            parsing_prelude = False
    functions = []
    while at_end(st) == False:
        function_phase_kind = peek(st)["kind"]
        if function_phase_kind == "KW_MODULE" or function_phase_kind == "KW_IMPORT" or function_phase_kind == "KW_FROM" or function_phase_kind == "KW_EXPORT":
            fail("module/import/export declarations must appear before functions")
        functions = method_append(functions, parse_function(st))
    return node_program(module_decl, imports, exports, functions)


def parse_function(st):
    expect(st, "KW_FN")
    name = expect(st, "IDENT")["text"]
    expect(st, "LPAREN")
    params = []
    if peek(st)["kind"] != "RPAREN":
        has_more = True
        while has_more:
            params = method_append(params, expect(st, "IDENT")["text"])
            has_more = match(st, "COMMA")
    expect(st, "RPAREN")
    expect(st, "LBRACE")
    body = []
    while peek(st)["kind"] != "RBRACE":
        body = method_append(body, parse_stmt(st))
    expect(st, "RBRACE")
    return node_function(name, params, body)


def parse_stmt(st):
    if match(st, "KW_IF"):
        cond = parse_expr(st)
        expect(st, "LBRACE")
        then_body = []
        while peek(st)["kind"] != "RBRACE":
            then_body = method_append(then_body, parse_stmt(st))
        expect(st, "RBRACE")
        else_body = []
        if match(st, "KW_ELSE"):
            expect(st, "LBRACE")
            while peek(st)["kind"] != "RBRACE":
                else_body = method_append(else_body, parse_stmt(st))
            expect(st, "RBRACE")
        return node_if(cond, then_body, else_body)

    if match(st, "KW_WHILE"):
        cond = parse_expr(st)
        expect(st, "LBRACE")
        body = []
        while peek(st)["kind"] != "RBRACE":
            body = method_append(body, parse_stmt(st))
        expect(st, "RBRACE")
        return node_while(cond, body)

    if match(st, "KW_FOR"):
        name = expect(st, "IDENT")["text"]
        expect(st, "KW_IN")
        iter_expr = parse_expr(st)
        expect(st, "LBRACE")
        body = []
        while peek(st)["kind"] != "RBRACE":
            body = method_append(body, parse_stmt(st))
        expect(st, "RBRACE")
        return node_for(name, iter_expr, body)

    if match(st, "KW_LET"):
        name = expect(st, "IDENT")["text"]
        expect(st, "ASSIGN")
        expr = parse_expr(st)
        expect(st, "SEMI")
        return node_let(name, expr)

    if match(st, "KW_RETURN"):
        expr = parse_expr(st)
        expect(st, "SEMI")
        return node_return(expr)

    if peek(st)["kind"] == "IDENT":
        if lookahead(st, 1)["kind"] == "ASSIGN":
            name = advance(st)["text"]
            expect(st, "ASSIGN")
            expr = parse_expr(st)
            expect(st, "SEMI")
            return node_assign(name, expr)

    expr = parse_expr(st)
    expect(st, "SEMI")
    return node_expr_stmt(expr)


def parse_expr(st):
    return parse_or(st)


def parse_or(st):
    left = parse_and(st)
    while match(st, "KW_OR"):
        right = parse_and(st)
        left = node_binary("or", left, right)
    return left


def parse_and(st):
    left = parse_cmp(st)
    while match(st, "KW_AND"):
        right = parse_cmp(st)
        left = node_binary("and", left, right)
    return left


def is_cmp_token(kind):
    if kind == "EQEQ":
        return True
    if kind == "BANGEQ":
        return True
    if kind == "LT":
        return True
    if kind == "LTE":
        return True
    if kind == "GT":
        return True
    if kind == "GTE":
        return True
    return False


def parse_cmp(st):
    left = parse_add(st)
    while is_cmp_token(peek(st)["kind"]):
        op = advance(st)["text"]
        right = parse_add(st)
        left = node_binary(op, left, right)
    return left


def parse_add(st):
    left = parse_mul(st)
    keep_parsing = True
    while keep_parsing:
        if peek(st)["kind"] == "PLUS":
            op = advance(st)["text"]
            right = parse_mul(st)
            left = node_binary(op, left, right)
        elif peek(st)["kind"] == "MINUS":
            op = advance(st)["text"]
            right = parse_mul(st)
            left = node_binary(op, left, right)
        else:
            keep_parsing = False
    return left


def parse_mul(st):
    left = parse_unary(st)
    keep_parsing = True
    while keep_parsing:
        if peek(st)["kind"] == "STAR":
            op = advance(st)["text"]
            right = parse_unary(st)
            left = node_binary(op, left, right)
        elif peek(st)["kind"] == "SLASH":
            op = advance(st)["text"]
            right = parse_unary(st)
            left = node_binary(op, left, right)
        else:
            keep_parsing = False
    return left


def parse_unary(st):
    if match(st, "KW_NOT"):
        return node_unary("not", parse_unary(st))
    if match(st, "MINUS"):
        return node_unary("-", parse_unary(st))
    return parse_postfix(st)


def parse_postfix(st):
    expr = parse_primary(st)
    keep_parsing = True
    while keep_parsing:
        if match(st, "LPAREN"):
            args = []
            if peek(st)["kind"] != "RPAREN":
                has_more = True
                while has_more:
                    args = method_append(args, parse_expr(st))
                    has_more = match(st, "COMMA")
            expect(st, "RPAREN")
            expr = node_call(expr, args)
        elif match(st, "LBRACKET"):
            idx_expr = parse_expr(st)
            expect(st, "RBRACKET")
            expr = node_index(expr, idx_expr)
        else:
            keep_parsing = False
    return expr


def parse_primary(st):
    t = peek(st)

    if t["kind"] == "NUMBER":
        advance(st)
        if contains(t["text"], "."):
            return node_float(float(t["text"]))
        return node_int(int(t["text"]))

    if t["kind"] == "STRING":
        advance(st)
        return node_str(t["text"])

    if t["kind"] == "BOOL":
        advance(st)
        return node_bool(t["text"] == "true")

    if t["kind"] == "IDENT":
        name = advance(st)["text"]
        return node_var(name)

    if match(st, "LBRACKET"):
        items = []
        if peek(st)["kind"] != "RBRACKET":
            has_more = True
            while has_more:
                items = method_append(items, parse_expr(st))
                has_more = match(st, "COMMA")
        expect(st, "RBRACKET")
        return node_list(items)

    if match(st, "LBRACE"):
        items = []
        if peek(st)["kind"] != "RBRACE":
            has_more = True
            while has_more:
                key_expr = parse_expr(st)
                expect(st, "COLON")
                value_expr = parse_expr(st)
                items = method_append(items, [key_expr, value_expr])
                has_more = match(st, "COMMA")
        expect(st, "RBRACE")
        return node_dict(items)

    if match(st, "LPAREN"):
        inner = parse_expr(st)
        expect(st, "RPAREN")
        return inner

    fail("unexpected token in expression: " + t["kind"])


def pp_expr(expr):
    k = expr["kind"]
    if k == "Int":
        return str(expr["value"])
    if k == "Float":
        return str(expr["value"])
    if k == "String":
        return "\"" + expr["value"] + "\""
    if k == "Bool":
        if expr["value"]:
            return "true"
        return "false"
    if k == "Var":
        return expr["name"]
    if k == "Unary":
        return expr["op"] + pp_expr(expr["expr"])
    if k == "Binary":
        return "(" + pp_expr(expr["left"]) + " " + expr["op"] + " " + pp_expr(expr["right"]) + ")"
    if k == "Call":
        arg_texts = []
        for arg in expr["args"]:
            arg_texts = method_append(arg_texts, pp_expr(arg))
        return pp_expr(expr["callee"]) + "(" + join_csv(arg_texts) + ")"
    if k == "List":
        item_texts = []
        for item in expr["items"]:
            item_texts = method_append(item_texts, pp_expr(item))
        return "[" + join_csv(item_texts) + "]"
    if k == "Dict":
        pair_texts = []
        for pair in expr["items"]:
            pair_texts = method_append(pair_texts, pp_expr(pair[0]) + ": " + pp_expr(pair[1]))
        return "{" + join_csv(pair_texts) + "}"
    if k == "Index":
        return pp_expr(expr["value"]) + "[" + pp_expr(expr["index"]) + "]"
    fail("pretty printer does not support expr kind: " + k)


def pp_stmt(stmt, indent):
    k = stmt["kind"]
    if k == "Let":
        return indent + "let " + stmt["name"] + " = " + pp_expr(stmt["expr"]) + ";"
    if k == "Assign":
        return indent + stmt["name"] + " = " + pp_expr(stmt["expr"]) + ";"
    if k == "Return":
        return indent + "return " + pp_expr(stmt["expr"]) + ";"
    if k == "ExprStmt":
        return indent + pp_expr(stmt["expr"]) + ";"
    if k == "If":
        out = indent + "if " + pp_expr(stmt["cond"]) + " {\n"
        for body_stmt in stmt["then_body"]:
            out = out + pp_stmt(body_stmt, indent + "    ") + "\n"
        out = out + indent + "}"
        if len(stmt["else_body"]) > 0:
            out = out + " else {\n"
            for body_stmt in stmt["else_body"]:
                out = out + pp_stmt(body_stmt, indent + "    ") + "\n"
            out = out + indent + "}"
        return out
    if k == "While":
        out = indent + "while " + pp_expr(stmt["cond"]) + " {\n"
        for body_stmt in stmt["body"]:
            out = out + pp_stmt(body_stmt, indent + "    ") + "\n"
        return out + indent + "}"
    if k == "For":
        out = indent + "for " + stmt["name"] + " in " + pp_expr(stmt["iter"]) + " {\n"
        for body_stmt in stmt["body"]:
            out = out + pp_stmt(body_stmt, indent + "    ") + "\n"
        return out + indent + "}"
    fail("pretty printer does not support stmt kind: " + k)


def pretty_program(program):
    out = ""
    for function in program["functions"]:
        out = out + "fn " + function["name"] + "(" + join_csv(function["params"]) + ") {\n"
        for stmt in function["body"]:
            out = out + pp_stmt(stmt, "    ") + "\n"
        out = out + "}\n"
    return out


def check_expr(expr, locals, fn_names):
    k = expr["kind"]
    if k == "Int":
        return
    if k == "Float":
        return
    if k == "String":
        return
    if k == "Bool":
        return
    if k == "Var":
        if contains(locals, expr["name"]) == False:
            if contains(fn_names, expr["name"]) == False:
                if is_builtin_symbol(expr["name"]) == False:
                    fail("undefined symbol: " + expr["name"])
        return
    if k == "Unary":
        check_expr(expr["expr"], locals, fn_names)
        return
    if k == "Binary":
        check_expr(expr["left"], locals, fn_names)
        check_expr(expr["right"], locals, fn_names)
        return
    if k == "Call":
        check_expr(expr["callee"], locals, fn_names)
        for arg in expr["args"]:
            check_expr(arg, locals, fn_names)
        return
    if k == "List":
        for item in expr["items"]:
            check_expr(item, locals, fn_names)
        return
    if k == "Dict":
        for pair in expr["items"]:
            check_expr(pair[0], locals, fn_names)
            check_expr(pair[1], locals, fn_names)
        return
    if k == "Index":
        check_expr(expr["value"], locals, fn_names)
        check_expr(expr["index"], locals, fn_names)
        return
    fail("semantic checker does not support expr kind: " + k)


def check_stmt(stmt, locals, fn_names):
    k = stmt["kind"]
    if k == "Let":
        check_expr(stmt["expr"], locals, fn_names)
        locals = method_append(locals, stmt["name"])
        return locals
    if k == "Assign":
        if contains(locals, stmt["name"]) == False:
            fail("assignment before declaration: " + stmt["name"])
        check_expr(stmt["expr"], locals, fn_names)
        return locals
    if k == "Return":
        check_expr(stmt["expr"], locals, fn_names)
        return locals
    if k == "ExprStmt":
        check_expr(stmt["expr"], locals, fn_names)
        return locals
    if k == "If":
        check_expr(stmt["cond"], locals, fn_names)
        then_locals = locals
        for body_stmt in stmt["then_body"]:
            then_locals = check_stmt(body_stmt, then_locals, fn_names)
        else_locals = locals
        for body_stmt in stmt["else_body"]:
            else_locals = check_stmt(body_stmt, else_locals, fn_names)
        return locals
    if k == "While":
        check_expr(stmt["cond"], locals, fn_names)
        loop_locals = locals
        for body_stmt in stmt["body"]:
            loop_locals = check_stmt(body_stmt, loop_locals, fn_names)
        return locals
    if k == "For":
        check_expr(stmt["iter"], locals, fn_names)
        loop_locals = locals
        if contains(loop_locals, stmt["name"]) == False:
            loop_locals = method_append(loop_locals, stmt["name"])
        for body_stmt in stmt["body"]:
            loop_locals = check_stmt(body_stmt, loop_locals, fn_names)
        return locals
    fail("semantic checker does not support stmt kind: " + k)


def semantic_check(program):
    fn_names = []
    for function in program["functions"]:
        if contains(fn_names, function["name"]):
            fail("duplicate function: " + function["name"])
        fn_names = method_append(fn_names, function["name"])

    for function in program["functions"]:
        locals = []
        for p in function["params"]:
            locals = method_append(locals, p)
        for stmt in function["body"]:
            locals = check_stmt(stmt, locals, fn_names)


# -----------------------------------------------------------------------------
# MODULE SECTION: Middle-end (typed/lowered IR + backend IR shaping)
# -----------------------------------------------------------------------------

# PASS CONTRACT: Middle-end typed IR emission
# Input: validated Program AST from parse_program().
# Output: deterministic textual typed IR (schema: typed-ir-selfhost v0).
# Failure: fail on unsupported AST node forms.
def typed_ir(program):
    out = "typed-ir-selfhost v0\n"
    for function in program["functions"]:
        out = out + "fn " + function["name"] + "(" + join_csv(function["params"]) + ")\n"
        for stmt in function["body"]:
            if stmt["kind"] == "Let":
                out = out + "  let " + stmt["name"] + " : any = " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "Assign":
                out = out + "  set " + stmt["name"] + " = " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "Return":
                out = out + "  ret " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "If":
                out = out + "  if " + pp_expr(stmt["cond"]) + " then ...\n"
            elif stmt["kind"] == "While":
                out = out + "  while " + pp_expr(stmt["cond"]) + " do ...\n"
            elif stmt["kind"] == "For":
                out = out + "  for " + stmt["name"] + " in " + pp_expr(stmt["iter"]) + " do ...\n"
            else:
                out = out + "  eval " + pp_expr(stmt["expr"]) + "\n"
    return out


# PASS CONTRACT: Middle-end lowering
# Input: Program AST from parse_program().
# Output: deterministic textual lowered IR (schema: lowered-ir-selfhost v0).
# Failure: fail on unsupported AST node forms.
def lowered_ir(program):
    out = "lowered-ir-selfhost v0\n"
    for function in program["functions"]:
        out = out + "proc " + function["name"] + "\n"
        line_no = 0
        for stmt in function["body"]:
            if stmt["kind"] == "Let":
                out = out + "  l" + str(line_no) + ": alloc " + stmt["name"] + " <- " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "Assign":
                out = out + "  l" + str(line_no) + ": store " + stmt["name"] + " <- " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "Return":
                out = out + "  l" + str(line_no) + ": return " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "If":
                out = out + "  l" + str(line_no) + ": branch " + pp_expr(stmt["cond"]) + " then-block else-block\n"
            elif stmt["kind"] == "While":
                out = out + "  l" + str(line_no) + ": loop-while " + pp_expr(stmt["cond"]) + "\n"
            elif stmt["kind"] == "For":
                out = out + "  l" + str(line_no) + ": loop-for " + stmt["name"] + " in " + pp_expr(stmt["iter"]) + "\n"
            else:
                out = out + "  l" + str(line_no) + ": eval " + pp_expr(stmt["expr"]) + "\n"
            line_no = line_no + 1
    return out


def backend_ir(program):
    out = "backend-ir-selfhost v0 abi=tyrion-aot-rt/v0\n"
    out = out + "entry-signature fn(args, env, globals) -> Result<Value, RuntimeError>\n"
    for function in program["functions"]:
        out = out + "fn " + function["name"] + "(args, env, globals)\n"
        out = out + "  bind-params " + join_csv(function["params"]) + "\n"
        line_no = 0
        for stmt in function["body"]:
            if stmt["kind"] == "Let":
                out = out + "  b" + str(line_no) + ": env.set " + stmt["name"] + " <- " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "Assign":
                out = out + "  b" + str(line_no) + ": env.assign " + stmt["name"] + " <- " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "Return":
                out = out + "  b" + str(line_no) + ": flow.return " + pp_expr(stmt["expr"]) + "\n"
            elif stmt["kind"] == "If":
                out = out + "  b" + str(line_no) + ": flow.if " + pp_expr(stmt["cond"]) + "\n"
            elif stmt["kind"] == "While":
                out = out + "  b" + str(line_no) + ": flow.while " + pp_expr(stmt["cond"]) + "\n"
            elif stmt["kind"] == "For":
                out = out + "  b" + str(line_no) + ": flow.for " + stmt["name"] + " in " + pp_expr(stmt["iter"]) + "\n"
            else:
                out = out + "  b" + str(line_no) + ": flow.eval " + pp_expr(stmt["expr"]) + "\n"
            line_no = line_no + 1
    return out


def extract_after_prefix_or_empty(text, prefix):
    parts = method_split(text, prefix)
    if len(parts) < 2:
        return ""
    return parts[1]


def extract_before_or_same(text, sep):
    parts = method_split(text, sep)
    if len(parts) < 2:
        return text
    return parts[0]


def native_ir_emit_const_lines(text, reg_idx):
    lines = []
    current = reg_idx
    if contains_text(text, "int("):
        lines = method_append(lines, "    v" + str(current) + " = const.int")
        current = current + 1
    if contains_text(text, "float("):
        lines = method_append(lines, "    v" + str(current) + " = const.float")
        current = current + 1
    if contains_text(text, "str("):
        lines = method_append(lines, "    v" + str(current) + " = const.str")
        current = current + 1
    if contains_text(text, "bool("):
        lines = method_append(lines, "    v" + str(current) + " = const.bool")
        current = current + 1
    return {"lines": lines, "next_reg": current}


def is_ascii_digit(ch):
    if ch < "0":
        return False
    if ch > "9":
        return False
    return True


def is_vreg_symbol_char(ch):
    if is_ascii_digit(ch):
        return True
    if ch >= "a":
        if ch <= "z":
            return True
    if ch >= "A":
        if ch <= "Z":
            return True
    if ch == "_":
        return True
    return False


def parse_vreg_tokens(line):
    tokens = []
    idx = 0
    while idx < len(line):
        ch = line[idx]
        if ch == "v":
            next_idx = idx + 1
            digits = ""
            while next_idx < len(line) and is_ascii_digit(line[next_idx]):
                digits = digits + line[next_idx]
                next_idx = next_idx + 1
            if digits != "":
                prev_ok = True
                if idx > 0:
                    prev_ok = is_vreg_symbol_char(line[idx - 1]) == False
                next_ok = True
                if next_idx < len(line):
                    next_ok = is_vreg_symbol_char(line[next_idx]) == False
                if prev_ok and next_ok:
                    tokens = method_append(tokens, "v" + digits)
                    idx = next_idx
                else:
                    idx = idx + 1
            else:
                idx = idx + 1
        else:
            idx = idx + 1
    return tokens


def parse_vreg_def(line):
    eq_idx = -1
    i = 0
    while i < len(line):
        if line[i] == "=":
            eq_idx = i
            i = len(line)
        else:
            i = i + 1
    if eq_idx <= 0:
        return ""
    lhs = trim_spaces(line[0:eq_idx])
    if starts_with(lhs, "v") == False:
        return ""
    if len(lhs) < 2:
        return ""
    j = 1
    while j < len(lhs):
        if is_ascii_digit(lhs[j]) == False:
            return ""
        j = j + 1
    return lhs


def is_canonical_vreg_name(value):
    if starts_with(value, "v") == False:
        return False
    if len(value) < 2:
        return False
    idx = 1
    while idx < len(value):
        if is_ascii_digit(value[idx]) == False:
            return False
        idx = idx + 1
    return True


def vreg_index_of(vregs, vreg):
    idx = 0
    while idx < len(vregs):
        if vregs[idx] == vreg:
            return idx
        idx = idx + 1
    return -1


def update_vreg_interval(vregs, starts, ends, vreg, pc):
    if is_canonical_vreg_name(vreg) == False:
        return {"vregs": vregs, "starts": starts, "ends": ends}
    existing = vreg_index_of(vregs, vreg)
    if existing < 0:
        vregs = method_append(vregs, vreg)
        starts = method_append(starts, pc)
        ends = method_append(ends, pc)
        return {"vregs": vregs, "starts": starts, "ends": ends}
    if pc < starts[existing]:
        starts[existing] = pc
    if pc > ends[existing]:
        ends[existing] = pc
    return {"vregs": vregs, "starts": starts, "ends": ends}


def analyze_native_ir_liveness_for_function(lines, start_idx, end_idx):
    vregs = []
    starts = []
    ends = []
    pc = 0
    idx = start_idx
    while idx < end_idx:
        line = lines[idx]
        trimmed = trim_spaces(line)
        if trimmed != "":
            def_reg = parse_vreg_def(trimmed)
            uses = parse_vreg_tokens(trimmed)
            if def_reg != "":
                interval = update_vreg_interval(vregs, starts, ends, def_reg, pc)
                vregs = interval["vregs"]
                starts = interval["starts"]
                ends = interval["ends"]
            u = 0
            while u < len(uses):
                use_reg = uses[u]
                if use_reg != def_reg:
                    interval = update_vreg_interval(vregs, starts, ends, use_reg, pc)
                    vregs = interval["vregs"]
                    starts = interval["starts"]
                    ends = interval["ends"]
                u = u + 1
            pc = pc + 1
        idx = idx + 1
    return {"vregs": vregs, "starts": starts, "ends": ends}


def append_native_ir_liveness_section(out_lines):
    lines = out_lines
    summary_lines = []
    idx = 0
    while idx < len(lines):
        line = lines[idx]
        if line == "liveness-analysis=v1":
            idx = len(lines)
        elif line == "regalloc-linear-scan=v1":
            idx = len(lines)
        elif starts_with(line, "fn "):
            fn_name = trim_spaces(extract_after_prefix_or_empty(line, "fn "))
            body_start = idx + 1
            body_end = len(lines)
            probe = body_start
            while probe < len(lines):
                if lines[probe] == "liveness-analysis=v1":
                    if body_end == len(lines):
                        body_end = probe
                elif lines[probe] == "regalloc-linear-scan=v1":
                    if body_end == len(lines):
                        body_end = probe
                elif starts_with(lines[probe], "fn "):
                    if body_end == len(lines):
                        body_end = probe
                probe = probe + 1
            live = analyze_native_ir_liveness_for_function(lines, body_start, body_end)
            summary_lines = method_append(summary_lines, "fn " + fn_name)
            if len(live["vregs"]) == 0:
                summary_lines = method_append(summary_lines, "  live.none")
            else:
                j = 0
                while j < len(live["vregs"]):
                    line_text = "  live.range " + live["vregs"][j] + " start=" + str(live["starts"][j]) + " end=" + str(live["ends"][j])
                    summary_lines = method_append(summary_lines, line_text)
                    j = j + 1
            idx = body_end
        else:
            idx = idx + 1
    if len(summary_lines) == 0:
        return out_lines
    out_lines = method_append(out_lines, "")
    out_lines = method_append(out_lines, "liveness-analysis=v1")
    j = 0
    while j < len(summary_lines):
        out_lines = method_append(out_lines, summary_lines[j])
        j = j + 1
    return out_lines


def list_remove_at(items, idx):
    if idx < 0:
        return items
    if idx >= len(items):
        return items
    out = []
    i = 0
    while i < len(items):
        if i != idx:
            out = method_append(out, items[i])
        i = i + 1
    return out


def find_interval_with_max_end(ends):
    if len(ends) == 0:
        return -1
    best_idx = 0
    idx = 1
    while idx < len(ends):
        if ends[idx] > ends[best_idx]:
            best_idx = idx
        idx = idx + 1
    return best_idx


def spill_slot_for_vreg(spill_vregs, spill_slots, vreg):
    idx = vreg_index_of(spill_vregs, vreg)
    if idx >= 0:
        return {"spill_vregs": spill_vregs, "spill_slots": spill_slots, "slot": spill_slots[idx]}
    slot = "spill" + str(len(spill_slots))
    spill_vregs = method_append(spill_vregs, vreg)
    spill_slots = method_append(spill_slots, slot)
    return {"spill_vregs": spill_vregs, "spill_slots": spill_slots, "slot": slot}


def append_regalloc_assignment(assign_vregs, assign_regs, vreg, reg):
    idx = vreg_index_of(assign_vregs, vreg)
    if idx < 0:
        assign_vregs = method_append(assign_vregs, vreg)
        assign_regs = method_append(assign_regs, reg)
    else:
        assign_regs[idx] = reg
    return {"assign_vregs": assign_vregs, "assign_regs": assign_regs}


def append_native_ir_spill_events_for_function(lines, start_idx, end_idx, spill_vregs, spill_slots, summary_lines):
    if len(spill_vregs) == 0:
        return summary_lines
    pc = 0
    idx = start_idx
    while idx < end_idx:
        line = trim_spaces(lines[idx])
        if line != "":
            def_reg = parse_vreg_def(line)
            uses = parse_vreg_tokens(line)
            u = 0
            while u < len(uses):
                use_reg = uses[u]
                spill_idx = vreg_index_of(spill_vregs, use_reg)
                if spill_idx >= 0 and use_reg != def_reg:
                    summary_lines = method_append(summary_lines, "  spill.reload " + use_reg + " slot=" + spill_slots[spill_idx] + " pc=" + str(pc))
                u = u + 1
            if def_reg != "":
                spill_idx = vreg_index_of(spill_vregs, def_reg)
                if spill_idx >= 0:
                    summary_lines = method_append(summary_lines, "  spill.store " + def_reg + " slot=" + spill_slots[spill_idx] + " pc=" + str(pc))
            pc = pc + 1
        idx = idx + 1
    return summary_lines


def linear_scan_allocate_native_ir(live, phys_regs):
    starts = live["starts"]
    ends = live["ends"]
    vregs = live["vregs"]

    active_vregs = []
    active_ends = []
    active_regs = []
    free_regs = phys_regs

    assign_vregs = []
    assign_regs = []
    spill_vregs = []
    spill_slots = []

    done = []
    d = 0
    while d < len(vregs):
        done = method_append(done, False)
        d = d + 1

    processed = 0
    while processed < len(vregs):
        pick = -1
        i = 0
        while i < len(vregs):
            if done[i] == False:
                if pick < 0:
                    pick = i
                elif starts[i] < starts[pick]:
                    pick = i
                elif starts[i] == starts[pick] and vregs[i] < vregs[pick]:
                    pick = i
            i = i + 1

        done[pick] = True
        processed = processed + 1
        cur_vreg = vregs[pick]
        cur_start = starts[pick]
        cur_end = ends[pick]

        a = 0
        while a < len(active_vregs):
            if active_ends[a] < cur_start:
                free_regs = method_append(free_regs, active_regs[a])
                active_vregs = list_remove_at(active_vregs, a)
                active_ends = list_remove_at(active_ends, a)
                active_regs = list_remove_at(active_regs, a)
            else:
                a = a + 1

        if len(free_regs) > 0:
            assigned_reg = free_regs[0]
            free_regs = list_remove_at(free_regs, 0)
            assigned = append_regalloc_assignment(assign_vregs, assign_regs, cur_vreg, assigned_reg)
            assign_vregs = assigned["assign_vregs"]
            assign_regs = assigned["assign_regs"]
            active_vregs = method_append(active_vregs, cur_vreg)
            active_ends = method_append(active_ends, cur_end)
            active_regs = method_append(active_regs, assigned_reg)
        else:
            spill_idx = find_interval_with_max_end(active_ends)
            if spill_idx < 0:
                spill_info = spill_slot_for_vreg(spill_vregs, spill_slots, cur_vreg)
                spill_vregs = spill_info["spill_vregs"]
                spill_slots = spill_info["spill_slots"]
            elif active_ends[spill_idx] > cur_end:
                stolen_reg = active_regs[spill_idx]
                evicted_vreg = active_vregs[spill_idx]
                spill_info = spill_slot_for_vreg(spill_vregs, spill_slots, evicted_vreg)
                spill_vregs = spill_info["spill_vregs"]
                spill_slots = spill_info["spill_slots"]
                active_vregs[spill_idx] = cur_vreg
                active_ends[spill_idx] = cur_end
                active_regs[spill_idx] = stolen_reg
                assigned = append_regalloc_assignment(assign_vregs, assign_regs, cur_vreg, stolen_reg)
                assign_vregs = assigned["assign_vregs"]
                assign_regs = assigned["assign_regs"]
            else:
                spill_info = spill_slot_for_vreg(spill_vregs, spill_slots, cur_vreg)
                spill_vregs = spill_info["spill_vregs"]
                spill_slots = spill_info["spill_slots"]

    return {"assign_vregs": assign_vregs, "assign_regs": assign_regs, "spill_vregs": spill_vregs, "spill_slots": spill_slots}


def append_native_ir_regalloc_section(out_lines):
    lines = out_lines
    summary_lines = []
    phys_regs = ["rax", "rbx", "rcx", "rdx", "r8", "r9"]
    idx = 0
    while idx < len(lines):
        line = lines[idx]
        if line == "liveness-analysis=v1":
            idx = len(lines)
        elif line == "regalloc-linear-scan=v1":
            idx = len(lines)
        elif starts_with(line, "fn "):
            fn_name = trim_spaces(extract_after_prefix_or_empty(line, "fn "))
            body_start = idx + 1
            body_end = len(lines)
            probe = body_start
            while probe < len(lines):
                if lines[probe] == "liveness-analysis=v1":
                    if body_end == len(lines):
                        body_end = probe
                elif lines[probe] == "regalloc-linear-scan=v1":
                    if body_end == len(lines):
                        body_end = probe
                elif starts_with(lines[probe], "fn "):
                    if body_end == len(lines):
                        body_end = probe
                probe = probe + 1
            live = analyze_native_ir_liveness_for_function(lines, body_start, body_end)
            alloc = linear_scan_allocate_native_ir(live, phys_regs)
            summary_lines = method_append(summary_lines, "fn " + fn_name)
            if len(alloc["assign_vregs"]) == 0 and len(alloc["spill_vregs"]) == 0:
                summary_lines = method_append(summary_lines, "  regalloc.none")
            else:
                j = 0
                while j < len(alloc["assign_vregs"]):
                    summary_lines = method_append(summary_lines, "  reg.assign " + alloc["assign_vregs"][j] + " -> %" + alloc["assign_regs"][j])
                    j = j + 1
                j = 0
                while j < len(alloc["spill_vregs"]):
                    summary_lines = method_append(summary_lines, "  spill.slot " + alloc["spill_vregs"][j] + " -> " + alloc["spill_slots"][j])
                    j = j + 1
                summary_lines = append_native_ir_spill_events_for_function(lines, body_start, body_end, alloc["spill_vregs"], alloc["spill_slots"], summary_lines)
            idx = body_end
        else:
            idx = idx + 1

    if len(summary_lines) == 0:
        return out_lines
    out_lines = method_append(out_lines, "")
    out_lines = method_append(out_lines, "regalloc-linear-scan=v1")
    j = 0
    while j < len(summary_lines):
        out_lines = method_append(out_lines, summary_lines[j])
        j = j + 1
    return out_lines


def native_ir_cfg_label_allocator(start_idx):
    return {"next_idx": start_idx}


def native_ir_cfg_alloc_label(allocator):
    next_idx = allocator["next_idx"]
    return {"allocator": {"next_idx": next_idx + 1}, "label": "b" + str(next_idx)}


def parse_cfg_block_label_or_empty(trimmed):
    if starts_with(trimmed, "cfg.block ") == False:
        return ""
    prefix_len = len("cfg.block ")
    rest = trim_spaces(trimmed[prefix_len:])
    token = extract_before_or_same(rest, " ")
    if starts_with(token, "b") == False:
        return ""
    if len(token) < 2:
        return ""
    idx = 1
    while idx < len(token):
        if is_ascii_digit(token[idx]) == False:
            return ""
        idx = idx + 1
    return token


def parse_cfg_branch_or_empty(trimmed):
    if starts_with(trimmed, "branch ") == False:
        return {"ok": False}
    branch_parts = method_split(trimmed, " -> ")
    if len(branch_parts) != 2:
        return {"ok": False}
    cond = trim_spaces(extract_after_prefix_or_empty(branch_parts[0], "branch "))
    target_parts = method_split(branch_parts[1], ",")
    if len(target_parts) != 2:
        return {"ok": False}
    then_target = trim_spaces(target_parts[0])
    else_target = trim_spaces(target_parts[1])
    if parse_cfg_block_label_or_empty("cfg.block " + then_target) == "":
        return {"ok": False}
    if parse_cfg_block_label_or_empty("cfg.block " + else_target) == "":
        return {"ok": False}
    return {"ok": True, "cond": cond, "then": then_target, "else": else_target}


def canonicalize_native_ir_cfg_branches(lines):
    block_labels = []
    idx = 0
    while idx < len(lines):
        label = parse_cfg_block_label_or_empty(trim_spaces(lines[idx]))
        if label != "":
            if contains(block_labels, label) == False:
                block_labels = method_append(block_labels, label)
        idx = idx + 1

    updated = []
    idx = 0
    while idx < len(lines):
        line = lines[idx]
        trimmed = trim_spaces(line)
        branch = parse_cfg_branch_or_empty(trimmed)
        if branch["ok"]:
            if contains(block_labels, branch["then"]) == False:
                fail("native-ir branch references unknown cfg block: " + branch["then"])
            if contains(block_labels, branch["else"]) == False:
                fail("native-ir branch references unknown cfg block: " + branch["else"])
            updated = method_append(updated, "    branch " + branch["cond"] + " -> " + branch["then"] + ", " + branch["else"])
        else:
            updated = method_append(updated, line)
        idx = idx + 1
    return updated


def parse_cfg_block_label_and_kind_or_empty(trimmed):
    if starts_with(trimmed, "cfg.block ") == False:
        return {"ok": False, "label": "", "kind": ""}
    prefix_len = len("cfg.block ")
    rest = trim_spaces(trimmed[prefix_len:])
    label = extract_before_or_same(rest, " ")
    if parse_cfg_block_label_or_empty("cfg.block " + label) == "":
        return {"ok": False, "label": "", "kind": ""}
    kind = trim_spaces(extract_after_prefix_or_empty(rest, label))
    return {"ok": True, "label": label, "kind": kind}


def lookup_cfg_block_kind_or_empty(block_infos, label):
    idx = 0
    while idx < len(block_infos):
        entry = block_infos[idx]
        if entry["label"] == label:
            return entry["kind"]
        idx = idx + 1
    return ""


def find_cfg_branch_record_or_empty(branch_records, label):
    idx = 0
    while idx < len(branch_records):
        entry = branch_records[idx]
        if entry["from"] == label:
            return entry
        idx = idx + 1
    return {"ok": False}


def validate_native_ir_loop_targets(lines):
    block_infos = []
    branch_target_labels = []
    branch_records = []
    current_block = ""

    idx = 0
    while idx < len(lines):
        trimmed = trim_spaces(lines[idx])
        parsed_block = parse_cfg_block_label_and_kind_or_empty(trimmed)
        if parsed_block["ok"]:
            current_block = parsed_block["label"]
            block_infos = method_append(block_infos, parsed_block)
        else:
            parsed_branch = parse_cfg_branch_or_empty(trimmed)
            if parsed_branch["ok"]:
                if current_block == "":
                    fail("native-ir loop validation: branch outside cfg block")
                if contains(branch_target_labels, parsed_branch["then"]) == False:
                    branch_target_labels = method_append(branch_target_labels, parsed_branch["then"])
                if contains(branch_target_labels, parsed_branch["else"]) == False:
                    branch_target_labels = method_append(branch_target_labels, parsed_branch["else"])
                branch_records = method_append(branch_records, {"ok": True, "from": current_block, "then": parsed_branch["then"], "else": parsed_branch["else"]})
        idx = idx + 1

    idx = 0
    while idx < len(block_infos):
        entry = block_infos[idx]
        label = entry["label"]
        kind = entry["kind"]
        if kind == "while.cond":
            branch = find_cfg_branch_record_or_empty(branch_records, label)
            if branch["ok"] == False:
                fail("native-ir loop validation: while.cond missing branch for " + label)
            then_kind = lookup_cfg_block_kind_or_empty(block_infos, branch["then"])
            else_kind = lookup_cfg_block_kind_or_empty(block_infos, branch["else"])
            if branch["then"] != label:
                fail("native-ir loop validation: while.cond must continue to self block " + label)
            if then_kind != "while.cond":
                fail("native-ir loop validation: while.cond branch then-target kind mismatch for " + label)
            if else_kind != "while.exit":
                fail("native-ir loop validation: while.cond branch else-target must be while.exit for " + label)
        elif kind == "while.exit":
            if contains(branch_target_labels, label) == False:
                fail("native-ir loop validation: while.exit is unreachable " + label)
        elif kind == "for.header":
            branch = find_cfg_branch_record_or_empty(branch_records, label)
            if branch["ok"] == False:
                fail("native-ir loop validation: for.header missing branch for " + label)
            then_kind = lookup_cfg_block_kind_or_empty(block_infos, branch["then"])
            else_kind = lookup_cfg_block_kind_or_empty(block_infos, branch["else"])
            if then_kind != "for.body":
                fail("native-ir loop validation: for.header branch then-target must be for.body for " + label)
            if else_kind != "for.exit":
                fail("native-ir loop validation: for.header branch else-target must be for.exit for " + label)
        elif kind == "for.body":
            if contains(branch_target_labels, label) == False:
                fail("native-ir loop validation: for.body is unreachable " + label)
        elif kind == "for.exit":
            if contains(branch_target_labels, label) == False:
                fail("native-ir loop validation: for.exit is unreachable " + label)
        idx = idx + 1

    return lines


def render_native_codegen_ir_from_lowered(input_path, deterministic, target, lowered_text):
    det = "0"
    if deterministic:
        det = "1"
    out_lines = []
    out_lines = method_append(out_lines, "native-codegen-ir-selfhost v1")
    out_lines = method_append(out_lines, "schema=native-codegen-ir/v1")
    out_lines = method_append(out_lines, "entry=" + input_path)
    out_lines = method_append(out_lines, "deterministic=" + det)
    out_lines = method_append(out_lines, "target=" + target["triple"])
    out_lines = method_append(out_lines, "target-abi=" + target["abi"])
    out_lines = method_append(out_lines, "runtime-abi=tyrion-aot-rt/v0")
    out_lines = method_append(out_lines, "ops=cfg.block,vreg,stack.slot,const,call,branch,cmp,load,store,runtime.call")
    out_lines = method_append(out_lines, "cfg-builder=v1")
    out_lines = method_append(out_lines, "cfg-label-allocator=v1")
    out_lines = method_append(out_lines, "cfg-branch-canonicalization=v1")
    out_lines = method_append(out_lines, "cfg-loop-target-validation=v1")
    out_lines = method_append(out_lines, "")

    lines = method_split(lowered_text, "\n")
    reg_idx = 0
    has_fn = False
    block_alloc = native_ir_cfg_label_allocator(0)

    out_lines = method_append(out_lines, "fn __module_entry")
    alloc = native_ir_cfg_alloc_label(block_alloc)
    block_alloc = alloc["allocator"]
    out_lines = method_append(out_lines, "  cfg.block " + alloc["label"] + " entry")
    out_lines = method_append(out_lines, "    stack.slot s0 spill.temp")
    out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = load s0")
    reg_idx = reg_idx + 1

    idx = 0
    while idx < len(lines):
        line = trim_spaces(lines[idx])
        if line != "" and starts_with(line, "lowered-ir v1") == False:
            if contains_text(line, "STMT function | name="):
                has_fn = True
                fn_part = extract_after_prefix_or_empty(line, "name=")
                fn_name = extract_before_or_same(fn_part, " ")
                out_lines = method_append(out_lines, "")
                out_lines = method_append(out_lines, "fn " + fn_name)
                block_alloc = native_ir_cfg_label_allocator(0)
                reg_idx = 0
                alloc = native_ir_cfg_alloc_label(block_alloc)
                block_alloc = alloc["allocator"]
                out_lines = method_append(out_lines, "  cfg.block " + alloc["label"] + " entry")
                out_lines = method_append(out_lines, "    stack.slot s0 spill.temp")
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = load s0")
                reg_idx = reg_idx + 1
            elif contains_text(line, "STMT assign |"):
                target_text = extract_after_prefix_or_empty(line, "target=")
                target_text = extract_before_or_same(target_text, " expr=")
                expr_text = extract_after_prefix_or_empty(line, "expr=")
                consts = native_ir_emit_const_lines(expr_text, reg_idx)
                const_lines = consts["lines"]
                reg_idx = consts["next_reg"]
                for c in const_lines:
                    out_lines = method_append(out_lines, c)
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = call lower.expr " + expr_text)
                out_lines = method_append(out_lines, "    store s0 <- v" + str(reg_idx) + " ; " + target_text)
                reg_idx = reg_idx + 1
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = load s0 ; " + target_text)
                reg_idx = reg_idx + 1
            elif contains_text(line, "STMT print |"):
                args_text = extract_after_prefix_or_empty(line, "args=")
                consts = native_ir_emit_const_lines(args_text, reg_idx)
                const_lines = consts["lines"]
                reg_idx = consts["next_reg"]
                for c in const_lines:
                    out_lines = method_append(out_lines, c)
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = runtime.call print " + args_text)
                reg_idx = reg_idx + 1
            elif contains_text(line, "STMT return |"):
                ret_text = extract_after_prefix_or_empty(line, "STMT return |")
                if ret_text != "":
                    consts = native_ir_emit_const_lines(ret_text, reg_idx)
                    const_lines = consts["lines"]
                    reg_idx = consts["next_reg"]
                    for c in const_lines:
                        out_lines = method_append(out_lines, c)
                    out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = call lower.ret " + trim_spaces(ret_text))
                    out_lines = method_append(out_lines, "    call abi.return v" + str(reg_idx))
                    reg_idx = reg_idx + 1
                else:
                    out_lines = method_append(out_lines, "    call abi.return void")
            elif contains_text(line, "STMT if_branch | compare("):
                cmp_text = extract_after_prefix_or_empty(line, "compare(")
                cmp_text = extract_before_or_same(cmp_text, ")")
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = cmp " + cmp_text)
                cmp_reg = reg_idx
                reg_idx = reg_idx + 1
                then_alloc = native_ir_cfg_alloc_label(block_alloc)
                block_alloc = then_alloc["allocator"]
                else_alloc = native_ir_cfg_alloc_label(block_alloc)
                block_alloc = else_alloc["allocator"]
                out_lines = method_append(out_lines, "    branch v" + str(cmp_reg) + " -> " + then_alloc["label"] + ", " + else_alloc["label"])
                out_lines = method_append(out_lines, "  cfg.block " + then_alloc["label"] + " if.then")
                out_lines = method_append(out_lines, "  cfg.block " + else_alloc["label"] + " if.else")
            elif contains_text(line, "STMT while |"):
                cond_text = extract_after_prefix_or_empty(line, "STMT while |")
                loop_alloc = native_ir_cfg_alloc_label(block_alloc)
                block_alloc = loop_alloc["allocator"]
                exit_alloc = native_ir_cfg_alloc_label(block_alloc)
                block_alloc = exit_alloc["allocator"]
                out_lines = method_append(out_lines, "  cfg.block " + loop_alloc["label"] + " while.cond")
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = cmp " + trim_spaces(cond_text))
                cmp_reg = reg_idx
                reg_idx = reg_idx + 1
                out_lines = method_append(out_lines, "    branch v" + str(cmp_reg) + " -> " + loop_alloc["label"] + ", " + exit_alloc["label"])
                out_lines = method_append(out_lines, "  cfg.block " + exit_alloc["label"] + " while.exit")
            elif contains_text(line, "STMT for |"):
                for_text = extract_after_prefix_or_empty(line, "STMT for |")
                header_alloc = native_ir_cfg_alloc_label(block_alloc)
                block_alloc = header_alloc["allocator"]
                body_alloc = native_ir_cfg_alloc_label(block_alloc)
                block_alloc = body_alloc["allocator"]
                exit_alloc = native_ir_cfg_alloc_label(block_alloc)
                block_alloc = exit_alloc["allocator"]
                out_lines = method_append(out_lines, "  cfg.block " + header_alloc["label"] + " for.header")
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = call runtime.iter.init " + trim_spaces(for_text))
                iter_reg = reg_idx
                reg_idx = reg_idx + 1
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = cmp iter.has_next v" + str(iter_reg))
                cmp_reg = reg_idx
                reg_idx = reg_idx + 1
                out_lines = method_append(out_lines, "    branch v" + str(cmp_reg) + " -> " + body_alloc["label"] + ", " + exit_alloc["label"])
                out_lines = method_append(out_lines, "  cfg.block " + body_alloc["label"] + " for.body")
                out_lines = method_append(out_lines, "  cfg.block " + exit_alloc["label"] + " for.exit")
            elif contains_text(line, "STMT expr |"):
                expr_text = extract_after_prefix_or_empty(line, "STMT expr |")
                out_lines = method_append(out_lines, "    v" + str(reg_idx) + " = call lower.expr " + trim_spaces(expr_text))
                reg_idx = reg_idx + 1
        idx = idx + 1

    if has_fn == False:
        out_lines = method_append(out_lines, "    call abi.return void")
    out_lines = canonicalize_native_ir_cfg_branches(out_lines)
    out_lines = validate_native_ir_loop_targets(out_lines)
    out_lines = append_native_ir_liveness_section(out_lines)
    out_lines = append_native_ir_regalloc_section(out_lines)
    return join_lines(out_lines)


def emit_native_codegen_ir(input_path, deterministic, target):
    lowered = __tyrion_emit_ir(input_path, "lowered", deterministic)
    return render_native_codegen_ir_from_lowered(input_path, deterministic, target, lowered)


