def emit_linux_aarch64_asm(compiled_payload, deterministic, target):
    state = emitter_state(deterministic)
    payload_label = next_symbol(state, "payload")
    payload_len = len(compiled_payload)
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; linux aarch64 constant-output fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "x8, #64" + "\n"
    out = out + "    " + "mov" + " " + "x0, #1" + "\n"
    out = out + "    " + "adrp" + " " + "x1, " + payload_label + "\n"
    out = out + "    " + "add" + " " + "x1, x1, :lo12:" + payload_label + "\n"
    out = out + "    " + "mov" + " " + "x2, #" + str(payload_len) + "\n"
    out = out + "    " + "svc" + " " + "#0" + "\n"
    out = out + "    " + "mov" + " " + "x8, #93" + "\n"
    out = out + "    " + "mov" + " " + "x0, #0" + "\n"
    out = out + "    " + "svc" + " " + "#0" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(compiled_payload) + "\"" + "\n"
    return out


def emit_darwin_x86_64_int_compare_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    op = plan["op"]
    jump = "jne"
    if op == "<":
        jump = "jl"
    elif op == "<=":
        jump = "jle"
    elif op == ">":
        jump = "jg"
    elif op == ">=":
        jump = "jge"
    elif op == "==":
        jump = "je"
    lhs_expr = plan["lhs_expr"]
    rhs_expr = plan["rhs_expr"]
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; darwin x86_64 integer compare/branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "movq" + " " + "$" + str(lhs_expr["base_value"]) + ", %rax" + "\n"
    if lhs_expr["delta"] > 0:
        out = out + "    " + "addq" + " " + "$" + str(lhs_expr["delta"]) + ", %rax" + "\n"
    elif lhs_expr["delta"] < 0:
        out = out + "    " + "subq" + " " + "$" + str(-lhs_expr["delta"]) + ", %rax" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(rhs_expr["base_value"]) + ", %rbx" + "\n"
    if rhs_expr["delta"] > 0:
        out = out + "    " + "addq" + " " + "$" + str(rhs_expr["delta"]) + ", %rbx" + "\n"
    elif rhs_expr["delta"] < 0:
        out = out + "    " + "subq" + " " + "$" + str(-rhs_expr["delta"]) + ", %rbx" + "\n"
    out = out + "    " + "cmpq" + " " + "%rbx, %rax" + "\n"
    out = out + "    " + jump + " " + true_label + "\n"
    out = out + "    " + "leaq" + " " + false_payload_label + "(%rip), %rdi" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(false_payload_len) + ", %rsi" + "\n"
    out = out + "    " + "call" + " " + runtime_print_stub_label + "\n"
    out = out + "    " + "jmp" + " " + done_label + "\n"
    out = out + true_label + ":\n"
    out = out + "    " + "leaq" + " " + true_payload_label + "(%rip), %rdi" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(true_payload_len) + ", %rsi" + "\n"
    out = out + "    " + "call" + " " + runtime_print_stub_label + "\n"
    out = out + done_label + ":\n"
    out = out + "    " + "movq" + " " + "$0x2000001, %rax" + "\n"
    out = out + "    " + "xorq" + " " + "%rdi, %rdi" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + runtime_print_stub_label + ":\n"
    out = out + "; runtime-abi print-line(ptr=%rdi, len=%rsi) -> %rax" + "\n"
    out = out + "; abi-clobber-policy: preserve callee-saved registers and syscall-clobbered rcx/r11" + "\n"
    out = out + "    " + "pushq" + " " + "%rbp" + "\n"
    out = out + "    " + "movq" + " " + "%rsp, %rbp" + "\n"
    out = out + "    " + "pushq" + " " + "%rbx" + "\n"
    out = out + "    " + "pushq" + " " + "%rcx" + "\n"
    out = out + "    " + "pushq" + " " + "%r11" + "\n"
    out = out + "    " + "movq" + " " + "%rdi, %rbx" + "\n"
    out = out + "    " + "movq" + " " + "%rsi, %r10" + "\n"
    out = out + "    " + "movq" + " " + "$0x2000004, %rax" + "\n"
    out = out + "    " + "movq" + " " + "$1, %rdi" + "\n"
    out = out + "    " + "movq" + " " + "%rbx, %rsi" + "\n"
    out = out + "    " + "movq" + " " + "%r10, %rdx" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + "    " + "popq" + " " + "%r11" + "\n"
    out = out + "    " + "popq" + " " + "%rcx" + "\n"
    out = out + "    " + "popq" + " " + "%rbx" + "\n"
    out = out + "    " + "leave" + " " + "" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + true_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["true_text"]) + "\"" + "\n"
    out = out + false_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["false_text"]) + "\"" + "\n"
    return out


def emit_darwin_x86_64_int_call_abi_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    callee_label = next_symbol(state, "call_target")
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    args = plan["args"]
    expected = plan["expected"]
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; darwin x86_64 call-abi branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "movq" + " " + "$" + str(args[0]) + ", %rdi" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[1]) + ", %rsi" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[2]) + ", %rdx" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[3]) + ", %rcx" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[4]) + ", %r8" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[5]) + ", %r9" + "\n"
    out = out + "; sysv-abi call boundary: reserve outgoing arg area to keep %rsp 16-byte aligned before call" + "\n"
    out = out + "    " + "subq" + " " + "$16, %rsp" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[6]) + ", (%rsp)" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(args[7]) + ", 8(%rsp)" + "\n"
    out = out + "    " + "call" + " " + callee_label + "\n"
    out = out + "    " + "addq" + " " + "$16, %rsp" + "\n"
    out = out + "    " + "cmpq" + " " + "$" + str(expected) + ", %rax" + "\n"
    out = out + "    " + "je" + " " + true_label + "\n"
    out = out + "    " + "leaq" + " " + false_payload_label + "(%rip), %rdi" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(false_payload_len) + ", %rsi" + "\n"
    out = out + "    " + "call" + " " + runtime_print_stub_label + "\n"
    out = out + "    " + "jmp" + " " + done_label + "\n"
    out = out + true_label + ":\n"
    out = out + "    " + "leaq" + " " + true_payload_label + "(%rip), %rdi" + "\n"
    out = out + "    " + "movq" + " " + "$" + str(true_payload_len) + ", %rsi" + "\n"
    out = out + "    " + "call" + " " + runtime_print_stub_label + "\n"
    out = out + done_label + ":\n"
    out = out + "    " + "movq" + " " + "$0x2000001, %rax" + "\n"
    out = out + "    " + "xorq" + " " + "%rdi, %rdi" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + callee_label + ":\n"
    out = out + "; sysv-abi add8(a1..a8) with explicit frame-slot layout" + "\n"
    out = out + "    " + "pushq" + " " + "%rbp" + "\n"
    out = out + "    " + "movq" + " " + "%rsp, %rbp" + "\n"
    out = out + "    " + "pushq" + " " + "%rbx" + "\n"
    out = out + "    " + "subq" + " " + "$64, %rsp" + "\n"
    out = out + "    " + "movq" + " " + "%rdi, -8(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%rsi, -16(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%rdx, -24(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%rcx, -32(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%r8, -40(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "%r9, -48(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "16(%rbp), %rax" + "\n"
    out = out + "    " + "movq" + " " + "%rax, -56(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "24(%rbp), %rax" + "\n"
    out = out + "    " + "movq" + " " + "%rax, -64(%rbp)" + "\n"
    out = out + "    " + "movq" + " " + "-8(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-16(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-24(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-32(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-40(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-48(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-56(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "-64(%rbp), %rax" + "\n"
    out = out + "    " + "addq" + " " + "$64, %rsp" + "\n"
    out = out + "    " + "popq" + " " + "%rbx" + "\n"
    out = out + "    " + "leave" + " " + "" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + runtime_print_stub_label + ":\n"
    out = out + "; runtime-abi print-line(ptr=%rdi, len=%rsi) -> %rax" + "\n"
    out = out + "; abi-clobber-policy: preserve callee-saved registers and syscall-clobbered rcx/r11" + "\n"
    out = out + "    " + "pushq" + " " + "%rbp" + "\n"
    out = out + "    " + "movq" + " " + "%rsp, %rbp" + "\n"
    out = out + "    " + "pushq" + " " + "%rbx" + "\n"
    out = out + "    " + "pushq" + " " + "%rcx" + "\n"
    out = out + "    " + "pushq" + " " + "%r11" + "\n"
    out = out + "    " + "movq" + " " + "%rdi, %rbx" + "\n"
    out = out + "    " + "movq" + " " + "%rsi, %r10" + "\n"
    out = out + "    " + "movq" + " " + "$0x2000004, %rax" + "\n"
    out = out + "    " + "movq" + " " + "$1, %rdi" + "\n"
    out = out + "    " + "movq" + " " + "%rbx, %rsi" + "\n"
    out = out + "    " + "movq" + " " + "%r10, %rdx" + "\n"
    out = out + "    " + "syscall" + " " + "" + "\n"
    out = out + "    " + "popq" + " " + "%r11" + "\n"
    out = out + "    " + "popq" + " " + "%rcx" + "\n"
    out = out + "    " + "popq" + " " + "%rbx" + "\n"
    out = out + "    " + "leave" + " " + "" + "\n"
    out = out + "    " + "ret" + " " + "" + "\n"
    out = out + target["rodata_section"] + "\n"
    out = out + true_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["true_text"]) + "\"" + "\n"
    out = out + false_payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(plan["false_text"]) + "\"" + "\n"
    return out


def emit_darwin_aarch64_int_compare_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    op = plan["op"]
    jump = "b.ne"
    if op == "<":
        jump = "b.lt"
    elif op == "<=":
        jump = "b.le"
    elif op == ">":
        jump = "b.gt"
    elif op == ">=":
        jump = "b.ge"
    elif op == "==":
        jump = "b.eq"
    lhs_expr = plan["lhs_expr"]
    rhs_expr = plan["rhs_expr"]
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; darwin aarch64 integer compare/branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "x9, #" + str(lhs_expr["base_value"]) + "\n"
    if lhs_expr["delta"] > 0:
        out = out + "    " + "add" + " " + "x9, x9, #" + str(lhs_expr["delta"]) + "\n"
    elif lhs_expr["delta"] < 0:
        out = out + "    " + "sub" + " " + "x9, x9, #" + str(-lhs_expr["delta"]) + "\n"
