    exe = "tyrionc"
    print("Usage:")
    print("  " + exe + " <input.ty>")
    print("  " + exe + " <input.ty> -o <output-bin>")
    print("  " + exe + " --input <input.ty> --output <output-bin>")
    print("  " + exe + " --backend=selfhost|tyrionc <input.ty> -o <output-bin>")
    print("  " + exe + " --target=<linux-x86_64|linux-aarch64|darwin-x86_64|darwin-aarch64> --backend=tyrionc <input.ty> -o <exe>")
    print("  " + exe + " --link=<static|static-like|dynamic> --backend=tyrionc <input.ty> -o <exe>")
    print("  " + exe + " --native-mode=auto --backend=tyrionc <input.ty> -o <exe>")
    print("  " + exe + " --ext-static=<off|auto|required> --backend=tyrionc <input.ty> -o <exe>")
    print("  " + exe + " --ext-dir <path> --backend=tyrionc <input.ty> -o <exe>")
    print("  " + exe + " --with-stdlib=<path> --backend=tyrionc <input.ty> -o <exe>")
