def emit_native_launcher_asm_embedded_current_exe_with_payload(output_path, compiled_payload, target):
    out = emit_native_launcher_asm_embedded_current_exe(output_path, target)
    payload_label = "__tyrion_embedded_payload"
    sanitized_payload = sanitize_stage_embedded_payload_text(compiled_payload)
    out = out + target["rodata_section"] + "\n"
    out = out + payload_label + ":\n"
    out = out + ".asciz \"" + asm_escape_string(sanitized_payload) + "\"" + "\n"
    return out


def link_native_launcher_from_asm(asm_source, output_path, deterministic, target, link_mode):
    asm_path = output_path + ".native.s"
    obj_path = output_path + ".native.o"
    if deterministic == False:
        asm_path = temp_native_path(output_path, ".s")
        obj_path = temp_native_path(output_path, ".o")
    write_text_file(asm_path, asm_source)
    as_tool = native_as_tool()
    as_args = []
    as_args = method_append(as_args, "-o")
    as_args = method_append(as_args, obj_path)
    as_args = method_append(as_args, asm_path)
    run_tool_checked(as_tool, as_args)
    ld_tool = native_ld_tool()
    ld_args = []
    ld_args = method_append(ld_args, "--build-id=none")
    if link_mode == "static":
        ld_args = method_append(ld_args, "-static")
    ld_args = method_append(ld_args, "-o")
    ld_args = method_append(ld_args, output_path)
    ld_args = method_append(ld_args, obj_path)
    run_tool_checked(ld_tool, ld_args)
    if deterministic == False:
        __tyrion_run_tool("rm", [asm_path, obj_path])
    return native_linker_flavor(ld_tool)


# PASS CONTRACT: Backend asm emission
# Input: source + precomputed lowering plan + resolved native target.
# Output: target-specific asm annotated with lowering-plan metadata.
# Failure: fail on unsupported target triples.
def lower_to_selfhost_native_asm_with_plan(input_path, output_path, source, compiled_payload, plan, deterministic, target):
    emit_compile_progress("lower_to_selfhost_native_asm:start")
    emit_compile_progress("lower_to_selfhost_native_asm:plan_ready:" + plan["kind"])
    lowering_payload = compiled_payload
    if plan["kind"] == "print-constant":
        lowering_payload = plan["constant_payload"]
    if plan["kind"] == "runtime-hooks":
        emit_compile_progress("lower_to_selfhost_native_asm:emit_embedded_stage_launcher:start")
        asm_text = emit_native_launcher_asm_embedded_current_exe_with_payload(output_path, compiled_payload, target)
        emit_compile_progress("lower_to_selfhost_native_asm:emit_embedded_stage_launcher:done")
        return annotate_asm_with_lowering_plan(asm_text, plan)
    if target["os"] == "linux":
        if target["arch"] == "aarch64":
            if plan["kind"] == "for-range-if-else-branch":
                return annotate_asm_with_lowering_plan(emit_linux_aarch64_for_range_if_else_branch_asm(plan["for_range_if_else_branch_plan"], deterministic, target), plan)
            if plan["kind"] == "loop-break-continue-branch":
                return annotate_asm_with_lowering_plan(emit_linux_aarch64_loop_break_continue_branch_asm(plan["loop_break_continue_branch_plan"], deterministic, target), plan)
            if plan["kind"] == "int-call-abi-branch":
                return annotate_asm_with_lowering_plan(emit_linux_aarch64_int_call_abi_branch_asm(plan["call_abi_branch_plan"], deterministic, target), plan)
            if plan["kind"] == "int-compare-branch":
                return annotate_asm_with_lowering_plan(emit_linux_aarch64_int_compare_branch_asm(plan["branch_plan"], deterministic, target), plan)
            return annotate_asm_with_lowering_plan(emit_linux_aarch64_asm(lowering_payload, deterministic, target), plan)
        if plan["kind"] == "for-range-if-else-branch":
            return annotate_asm_with_lowering_plan(emit_linux_x86_64_for_range_if_else_branch_asm(plan["for_range_if_else_branch_plan"], deterministic, target), plan)
        if plan["kind"] == "loop-break-continue-branch":
            return annotate_asm_with_lowering_plan(emit_linux_x86_64_loop_break_continue_branch_asm(plan["loop_break_continue_branch_plan"], deterministic, target), plan)
        if plan["kind"] == "int-call-abi-branch":
            return annotate_asm_with_lowering_plan(emit_linux_x86_64_int_call_abi_branch_asm(plan["call_abi_branch_plan"], deterministic, target), plan)
        if plan["kind"] == "int-compare-branch":
            return annotate_asm_with_lowering_plan(emit_linux_x86_64_int_compare_branch_asm(plan["branch_plan"], deterministic, target), plan)
        return annotate_asm_with_lowering_plan(emit_linux_x86_64_asm(lowering_payload, deterministic, target), plan)
    if target["os"] == "darwin":
        if target["arch"] == "aarch64":
            if plan["kind"] == "for-range-if-else-branch":
                return annotate_asm_with_lowering_plan(emit_darwin_aarch64_for_range_if_else_branch_asm(plan["for_range_if_else_branch_plan"], deterministic, target), plan)
            if plan["kind"] == "loop-break-continue-branch":
                return annotate_asm_with_lowering_plan(emit_darwin_aarch64_loop_break_continue_branch_asm(plan["loop_break_continue_branch_plan"], deterministic, target), plan)
            if plan["kind"] == "int-call-abi-branch":
                return annotate_asm_with_lowering_plan(emit_darwin_aarch64_int_call_abi_branch_asm(plan["call_abi_branch_plan"], deterministic, target), plan)
            if plan["kind"] == "int-compare-branch":
                return annotate_asm_with_lowering_plan(emit_darwin_aarch64_int_compare_branch_asm(plan["branch_plan"], deterministic, target), plan)
            emit_compile_progress("lower_to_selfhost_native_asm:emit_darwin_aarch64_asm:start")
            asm_text = emit_darwin_aarch64_asm(lowering_payload, deterministic, target)
            emit_compile_progress("lower_to_selfhost_native_asm:emit_darwin_aarch64_asm:done")
            return annotate_asm_with_lowering_plan(asm_text, plan)
        if plan["kind"] == "for-range-if-else-branch":
            return annotate_asm_with_lowering_plan(emit_darwin_x86_64_for_range_if_else_branch_asm(plan["for_range_if_else_branch_plan"], deterministic, target), plan)
        if plan["kind"] == "loop-break-continue-branch":
            return annotate_asm_with_lowering_plan(emit_darwin_x86_64_loop_break_continue_branch_asm(plan["loop_break_continue_branch_plan"], deterministic, target), plan)
        if plan["kind"] == "int-call-abi-branch":
            return annotate_asm_with_lowering_plan(emit_darwin_x86_64_int_call_abi_branch_asm(plan["call_abi_branch_plan"], deterministic, target), plan)
        if plan["kind"] == "int-compare-branch":
            return annotate_asm_with_lowering_plan(emit_darwin_x86_64_int_compare_branch_asm(plan["branch_plan"], deterministic, target), plan)
        emit_compile_progress("lower_to_selfhost_native_asm:emit_darwin_x86_64_asm:start")
        asm_text = emit_darwin_x86_64_asm(lowering_payload, deterministic, target)
        emit_compile_progress("lower_to_selfhost_native_asm:emit_darwin_x86_64_asm:done")
        return annotate_asm_with_lowering_plan(asm_text, plan)
    fail("unsupported backend target: " + target["triple"])


