def emit_linux_aarch64_loop_break_continue_branch_asm(plan, deterministic, target):
    state = emitter_state(deterministic)
    runtime_print_stub_label = next_symbol(state, "runtime_print_stub")
    loop_label = next_symbol(state, "loop")
    after_loop_label = next_symbol(state, "after_loop")
    true_label = next_symbol(state, "true")
    done_label = next_symbol(state, "done")
    true_payload_label = next_symbol(state, "true_payload")
    false_payload_label = next_symbol(state, "false_payload")
    true_payload_len = len(plan["true_text"])
    false_payload_len = len(plan["false_text"])
    out = "# tyrionc-native-asm v0 target=" + target["triple"] + " abi=tyrion-aot-rt/v0 emitter=tyrionc-native-v1\n"
    out = out + "; linux aarch64 loop/break/continue branch fast path" + "\n"
    out = out + target["text_section"] + "\n"
    out = out + ".globl " + target["entry_symbol"] + "\n"
    out = out + target["entry_symbol"] + ":\n"
    out = out + "    " + "mov" + " " + "x19, #0" + "\n"
    out = out + "    " + "mov" + " " + "x20, #0" + "\n"
    out = out + loop_label + ":\n"
    out = out + "    " + "cmp" + " " + "x19, #6" + "\n"
    out = out + "    " + "b.ge" + " " + after_loop_label + "\n"
    out = out + "    " + "add" + " " + "x19, x19, #1" + "\n"
    out = out + "    " + "cmp" + " " + "x19, #2" + "\n"
    out = out + "    " + "b.eq" + " " + loop_label + "\n"
    out = out + "    " + "cmp" + " " + "x19, #5" + "\n"
    out = out + "    " + "b.eq" + " " + after_loop_label + "\n"
    out = out + "    " + "add" + " " + "x20, x20, x19" + "\n"
    out = out + "    " + "b" + " " + loop_label + "\n"
    out = out + after_loop_label + ":\n"
    out = out + "    " + "cmp" + " " + "x20, #8" + "\n"
    out = out + "    " + "b.eq" + " " + true_label + "\n"
    out = out + "    " + "adr" + " " + "x0, " + false_payload_label + "\n"
    out = out + "    " + "mov" + " " + "x1, #" + str(false_payload_len) + "\n"
    out = out + "    " + "bl" + " " + runtime_print_stub_label + "\n"
    out = out + "    " + "b" + " " + done_label + "\n"
    out = out + true_label + ":\n"
    out = out + "    " + "adr" + " " + "x0, " + true_payload_label + "\n"
    out = out + "    " + "mov" + " " + "x1, #" + str(true_payload_len) + "\n"
    out = out + "    " + "bl" + " " + runtime_print_stub_label + "\n"
