def render_selfhost_native_artifact(input_path, output_path, deterministic, source, compiled_payload, target, link_mode, link_strategy_name, link_object_writer, object_writer_probe_metadata, include_compiled_payload, ext_static_mode, ext_static_dir, stdlib_wrapper_path, stdlib_wrapper_applied):
